{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build LanyardApp",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/LanyardApp/Lanyard.App.csproj"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build LanyardClient",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/LanyardClient/Lanyard.Client.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build LanyardClient.Watchdog",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/LanyardClient.Watchdog/LanyardClient.Watchdog.csproj"
            ],
            "problemMatcher": "$msCompile",
            "dependsOn": [
                "Build LanyardClient"
            ]
        },
        {
            "label": "Publish & Package (Velopack)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "publish",
                "src/LanyardClient/Lanyard.Client.csproj",
                "-c", "Release",
                "-r", "win-x64",
                "--self-contained",
                "-o", "./publish"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Pack (Velopack)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "$version = ([xml](Get-Content src/LanyardClient/Lanyard.Client.csproj)).Project.PropertyGroup.Version; vpk pack --packId LanyardClient --packVersion $version --packDir ./publish --mainExe Lanyard.Client.exe -y"
            ],
            "dependsOn": "Publish & Package (Velopack)",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Launch Setup (Velopack)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Start-Process Releases/LanyardClient-win-Setup.exe"
            ],
            "dependsOn": "Pack (Velopack)",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Pack Only (Velopack)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Remove-Item -Recurse -Force -ErrorAction SilentlyContinue ./Releases; $version = ([xml](Get-Content src/LanyardClient/Lanyard.Client.csproj)).Project.PropertyGroup.Version; vpk pack --packId LanyardClient --packVersion $version --packDir ./publish --mainExe Lanyard.Client.exe"
            ],
            "dependsOn": "Publish & Package (Velopack)",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}