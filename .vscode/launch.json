{
    "requireExactSource": false,
    "configurations": [
        {
            "name": "Debug LanyardClient",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}\\src\\Lanyard.Client\\Lanyard.Client.csproj",
            // "preLaunchTask": "Build LanyardClient"
        },  
        {
            "name": "Debug LanyardClient.Watchdog",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}\\src\\Lanyard.Client.Watchdog\\LanyardClient.Watchdog.csproj",
            // "preLaunchTask": "Build LanyardClient.Watchdog"
        },
        {
            "name": "Debug LanyardApp",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}\\src\\Lanyard.Server\\LanyardApp\\Lanyard.App.csproj",
            "launchConfigurationId": "TargetFramework=;https",
            // "preLaunchTask": "Build LanyardApp"
        },
        {
            "name": "Debug LanyardReach (Web)",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}\\src\\Lanyard.Reach\\Lanyard.Reach.Web\\Lanyard.Reach.Web.csproj",
            "launchConfigurationId": "TargetFramework=;https"
        },
        {
            "name": "Debug LanyardReach (Android)",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}\\src\\Lanyard.Reach\\Lanyard.Reach\\Lanyard.Reach.csproj"
        },
        {
            "name": "Run Velopack Release",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Pack Only (Velopack)",
            "program": "${env:LOCALAPPDATA}\\Lanyard.Client\\current\\Lanyard.Client.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal"
        }
    ]
}