@inject IToastService _toastService

<FluentCard AreaRestricted="false">
    <FluentMultiSplitter Class="h-100">
        <FluentMultiSplitterPane Size="30%">
            <FluentToolbar>
                <FluentLabel slot="start" Typo="Typography.PaneHeader">Automation Templates</FluentLabel>
                <FluentButton slot="end" Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size20.FormNew())" OnClick="StartTemplateCreate">
                    New
                </FluentButton>
            </FluentToolbar>

            <FluentDataGrid Items="templates.AsQueryable()" GridTemplateColumns="auto 1fr auto" ShowHover="true">
                <ChildContent>
                    <SelectColumn SelectAll="true" OnSelect="@(x => SelectTemplate(x.Item))" Property="@(x => selectedTemplate is not null && x.Id == selectedTemplate.Id)" TGridItem="AutomationStepTemplateDefinition" SelectMode="DataGridSelectMode.Single" SelectFromEntireRow="true"></SelectColumn>
                    <PropertyColumn Property="x => x.Name" Title="Name"></PropertyColumn>
                    <TemplateColumn Title="Type">
                        @context.Kind
                    </TemplateColumn>
                </ChildContent>
            </FluentDataGrid>
        </FluentMultiSplitterPane>

        <FluentMultiSplitterPane Size="70%" Class="px-2">
            @if (selectedTemplate is null)
            {
                <FluentLabel>Select a template to edit.</FluentLabel>
            }
            else
            {
                <FluentStack Orientation="Orientation.Vertical" Class="h-100 overflow-y-auto" Style="gap: 12px;">
                    <FluentToolbar>
                        <FluentLabel slot="start" Typo="Typography.PaneHeader">Template Editor</FluentLabel>
                        <FluentButton slot="end" Appearance="Appearance.Accent" OnClick="SaveTemplate">Save</FluentButton>
                        <FluentButton slot="end" Appearance="Appearance.Outline" OnClick="DeleteTemplate">Delete</FluentButton>
                    </FluentToolbar>

                    <FluentGrid>
                        <FluentGridItem xs="4">
                            <FluentTextField @bind-Value="selectedTemplate.Name" Label="Template Name" Appearance="FluentInputAppearance.Outline" Required />
                        </FluentGridItem>
                        <FluentGridItem xs="4">
                            <FluentTextArea @bind-Value="selectedTemplate.Description" Label="Description" Appearance="FluentInputAppearance.Outline" />
                        </FluentGridItem>
                        <FluentGridItem xs="4">
                            <FluentSelect @bind-Value="SelectedTemplateKind" TOption="string" Label="Template Kind">
                                <FluentOption Value="Trigger">Trigger</FluentOption>
                                <FluentOption Value="Action">Action</FluentOption>
                            </FluentSelect>
                        </FluentGridItem>
                    </FluentGrid>

                    <FluentDivider></FluentDivider>
                    <FluentLabel Typo="Typography.PaneHeader">Parameters</FluentLabel>

                    @foreach (AutomationStepTemplateParameterDefinition parameter in selectedTemplate.Parameters)
                    {
                        <FluentCard MinimalStyle="true">
                            <FluentGrid>
                                <FluentGridItem xs="3">
                                    <FluentTextField @bind-Value="parameter.Name" Label="Name" Appearance="FluentInputAppearance.Outline" />
                                </FluentGridItem>
                                <FluentGridItem xs="4">
                                    <FluentTextArea @bind-Value="parameter.Description" Label="Description" Appearance="FluentInputAppearance.Outline" />
                                </FluentGridItem>
                                <FluentGridItem xs="3">
                                    <FluentSelect @bind-Value="parameter.DataType" TOption="string" Label="Data Type">
                                        @foreach (string type in dataTypes)
                                        {
                                            <FluentOption Value="@type">@type</FluentOption>
                                        }
                                    </FluentSelect>
                                    <FluentCheckbox @bind-Value="parameter.IsRequired">Required</FluentCheckbox>
                                </FluentGridItem>
                                <FluentGridItem xs="2" Class="d-flex align-items-start justify-content-end mt-4">
                                    <FluentButton Appearance="Appearance.Outline" OnClick="() => RemoveParameter(parameter.Id)">Remove</FluentButton>
                                </FluentGridItem>
                            </FluentGrid>
                        </FluentCard>
                    }

                    <FluentCard MinimalStyle="true">
                        <FluentGrid>
                            <FluentGridItem xs="3">
                                <FluentTextField @bind-Value="newParameter.Name" Label="Name" Appearance="FluentInputAppearance.Outline" />
                            </FluentGridItem>
                            <FluentGridItem xs="4">
                                <FluentTextArea @bind-Value="newParameter.Description" Label="Description" Appearance="FluentInputAppearance.Outline" />
                            </FluentGridItem>
                            <FluentGridItem xs="3">
                                <FluentSelect @bind-Value="newParameter.DataType" TOption="string" Label="Data Type">
                                    @foreach (string type in dataTypes)
                                    {
                                        <FluentOption Value="@type">@type</FluentOption>
                                    }
                                </FluentSelect>
                                <FluentCheckbox @bind-Value="newParameter.IsRequired">Required</FluentCheckbox>
                            </FluentGridItem>
                            <FluentGridItem xs="2" Class="d-flex align-items-start justify-content-end mt-4">
                                <FluentButton Appearance="Appearance.Accent" OnClick="AddParameter">Add</FluentButton>
                            </FluentGridItem>
                        </FluentGrid>
                    </FluentCard>
                </FluentStack>
            }
        </FluentMultiSplitterPane>
    </FluentMultiSplitter>
</FluentCard>

@code {
    private readonly string[] dataTypes = ["String", "Integer", "Float", "Boolean", "DateTime", "File"];
    private readonly List<AutomationStepTemplateDefinition> templates = [];
    private AutomationStepTemplateDefinition? selectedTemplate;
    private AutomationStepTemplateParameterDefinition newParameter = CreateEmptyParameter();

    protected override void OnInitialized()
    {
        SeedTemplates();
    }

    private void StartTemplateCreate()
    {
        selectedTemplate = new AutomationStepTemplateDefinition
        {
            Id = Guid.Empty,
            Name = "New Template",
            Description = string.Empty,
            Kind = AutomationStepKind.Trigger,
            Parameters = []
        };

        newParameter = CreateEmptyParameter();
    }

    private void SelectTemplate(AutomationStepTemplateDefinition template)
    {
        selectedTemplate = CloneTemplate(template);
        newParameter = CreateEmptyParameter();
    }

    private void AddParameter()
    {
        if (selectedTemplate is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(newParameter.Name))
        {
            _toastService.ShowWarning("Parameter name is required.");
            return;
        }

        selectedTemplate.Parameters.Add(new AutomationStepTemplateParameterDefinition
        {
            Id = Guid.NewGuid(),
            Name = newParameter.Name,
            Description = newParameter.Description,
            DataType = newParameter.DataType,
            IsRequired = newParameter.IsRequired
        });

        newParameter = CreateEmptyParameter();
    }

    private void RemoveParameter(Guid parameterId)
    {
        if (selectedTemplate is null)
        {
            return;
        }

        AutomationStepTemplateParameterDefinition? parameter = selectedTemplate.Parameters.FirstOrDefault(x => x.Id == parameterId);

        if (parameter is not null)
        {
            selectedTemplate.Parameters.Remove(parameter);
        }
    }

    private void SaveTemplate()
    {
        if (selectedTemplate is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedTemplate.Name))
        {
            _toastService.ShowWarning("Template name is required.");
            return;
        }

        if (selectedTemplate.Id == Guid.Empty)
        {
            selectedTemplate.Id = Guid.NewGuid();
            templates.Add(CloneTemplate(selectedTemplate));
        }
        else
        {
            AutomationStepTemplateDefinition? existing = templates.FirstOrDefault(x => x.Id == selectedTemplate.Id);

            if (existing is null)
            {
                templates.Add(CloneTemplate(selectedTemplate));
            }
            else
            {
                existing.Name = selectedTemplate.Name;
                existing.Description = selectedTemplate.Description;
                existing.Kind = selectedTemplate.Kind;
                existing.Parameters = selectedTemplate.Parameters.Select(x => new AutomationStepTemplateParameterDefinition
                {
                    Id = x.Id,
                    Name = x.Name,
                    Description = x.Description,
                    DataType = x.DataType,
                    IsRequired = x.IsRequired
                }).ToList();
            }
        }

        _toastService.ShowSuccess("Template saved.");
    }

    private void DeleteTemplate()
    {
        if (selectedTemplate is null || selectedTemplate.Id == Guid.Empty)
        {
            return;
        }

        AutomationStepTemplateDefinition? existing = templates.FirstOrDefault(x => x.Id == selectedTemplate.Id);

        if (existing is not null)
        {
            templates.Remove(existing);
        }

        selectedTemplate = null;
        _toastService.ShowSuccess("Template removed.");
    }

    private void SeedTemplates()
    {
        templates.Add(new AutomationStepTemplateDefinition
        {
            Id = Guid.NewGuid(),
            Name = "Schedule Trigger",
            Description = "Starts on a schedule.",
            Kind = AutomationStepKind.Trigger,
            Parameters =
            [
                new AutomationStepTemplateParameterDefinition { Id = Guid.NewGuid(), Name = "Cron", DataType = "String", IsRequired = true }
            ]
        });

        templates.Add(new AutomationStepTemplateDefinition
        {
            Id = Guid.NewGuid(),
            Name = "Send Notification",
            Description = "Sends a notification.",
            Kind = AutomationStepKind.Action,
            Parameters =
            [
                new AutomationStepTemplateParameterDefinition { Id = Guid.NewGuid(), Name = "Message", DataType = "String", IsRequired = true }
            ]
        });
    }

    private string SelectedTemplateKind
    {
        get
        {
            if (selectedTemplate is null)
            {
                return "Trigger";
            }

            return selectedTemplate.Kind == AutomationStepKind.Action ? "Action" : "Trigger";
        }
        set
        {
            if (selectedTemplate is null)
            {
                return;
            }

            selectedTemplate.Kind = string.Equals(value, "Action", StringComparison.OrdinalIgnoreCase)
                ? AutomationStepKind.Action
                : AutomationStepKind.Trigger;
        }
    }

    private static AutomationStepTemplateParameterDefinition CreateEmptyParameter()
    {
        return new AutomationStepTemplateParameterDefinition
        {
            Id = Guid.NewGuid(),
            Name = string.Empty,
            Description = string.Empty,
            DataType = "String",
            IsRequired = false
        };
    }

    private static AutomationStepTemplateDefinition CloneTemplate(AutomationStepTemplateDefinition template)
    {
        return new AutomationStepTemplateDefinition
        {
            Id = template.Id,
            Name = template.Name,
            Description = template.Description,
            Kind = template.Kind,
            Parameters = template.Parameters.Select(parameter => new AutomationStepTemplateParameterDefinition
            {
                Id = parameter.Id,
                Name = parameter.Name,
                Description = parameter.Description,
                DataType = parameter.DataType,
                IsRequired = parameter.IsRequired
            }).ToList()
        };
    }
}
