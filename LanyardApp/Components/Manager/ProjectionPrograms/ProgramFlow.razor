@using Lanyard.App.Services
@using Lanyard.Infrastructure.Models
@using Lanyard.Application.Services

@inject DragStateService DragState
@inject IToastService _toastService
@inject IProjectionProgramService _projectionProgramService

<FluentStack class="text-center flow-scroll" Orientation="Orientation.Vertical" VerticalAlignment="VerticalAlignment.Top" HorizontalAlignment="HorizontalAlignment.Center">
    <FluentCard MinimalStyle="true" Class="py-4" draggable="false" @ondragover:preventDefault @ondrop="(e) => OnDropAtIndex(e, 0)">START</FluentCard>

    <FluentStack HorizontalAlignment="HorizontalAlignment.Center" class="w-100 h-auto overflow-scroll" @ondragover:preventDefault @ondrop="(e) => OnDropAtIndex(e, 0)">
        <FluentDivider Orientation="Orientation.Vertical" Style="height: 25px;"></FluentDivider>
    </FluentStack>

    @if (SelectedProgram?.ProjectionProgramSteps != null)
    {
        int index = 0;

        foreach (ProjectionProgramStep step in SelectedProgram.ProjectionProgramSteps.OrderBy(x=> x.SortOrder))
        {
            Dictionary<Guid, ProjectionProgramParameterValue> parameterValueDict = step.ParameterValues.ToDictionary(x => x.ParameterId);

            <ProjectionStepOptionsMenu AnchorId="@($"menu-btn-step-{step.Id}")" ProjectionProgramStep="step" OnDeleteButtonClicked="DeleteProjectionProgramStep"></ProjectionStepOptionsMenu>

            <FluentCard MinimalStyle="true" Class="py-4" draggable="false" @ondragover:preventDefault @ondrop="(e) => OnDropAtIndex(e, index)" id="@($"menu-btn-step-{step.Id}")">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Center">
                    <div>
                        @step.Template?.Name
                    </div>
                </FluentStack>
                
                @if (step.Template?.Parameters.Any() == true)
                {
                    <FluentAccordion>
                        <FluentAccordionItem class="mt-2" Expanded="false">
                            <HeadingTemplate>
                                <FluentIcon Value="@(new Icons.Regular.Size20.TaskListRtl())"></FluentIcon>
                                Parameters (@step.Template.Parameters.Count)
                            </HeadingTemplate>
                            <ChildContent>
                                <FluentGrid>
                                @foreach (ProjectionProgramStepTemplateParameter parameter in step.Template.Parameters)
                                {
                                    if (!parameterValueDict.TryGetValue(parameter.Id, out ProjectionProgramParameterValue? paramValue))
                                    {
                                        continue;
                                    }

                                    <FluentGridItem xs="4">
                                    <div>
                                        <FluentTextField @bind-Value="@paramValue.Value" 
                                                       Label="@parameter.Name" 
                                                       Appearance="FluentInputAppearance.Outline" 
                                                       Required="@parameter.IsRequired"></FluentTextField>
                                    </div>
                                    </FluentGridItem>
                                }
                                </FluentGrid>
                            </ChildContent>
                        </FluentAccordionItem>
                    </FluentAccordion>
                }
            </FluentCard>
            <FluentDivider Orientation="Orientation.Vertical" Style="height: 25px;" @ondragover:preventDefault @ondrop="(e) => OnDropAtIndex(e, index + 1)"></FluentDivider>
            index++;
        }
    }

    <FluentCard MinimalStyle="true" Class="py-4" draggable="false" @ondragover:preventDefault @ondrop="(e) => OnDropAtEnd(e)">END</FluentCard>
</FluentStack>

@code{
    [Parameter]
    public ProjectionProgram? SelectedProgram { get; set; }

    [Parameter]
    public EventCallback<ProjectionProgram> OnSave { get; set; }

    [Parameter]
    public EventCallback OnStepsChanged { get; set; }

    public bool CanSave => SelectedProgram?.ProjectionProgramSteps?.Count > 0;

    private void OnDropAtIndex(DragEventArgs e, int insertIndex)
    {
        if (!DragState.HasDrag || DragState.CurrentTemplate is null || SelectedProgram is null)
        {
            if (SelectedProgram is null)
            {
                _toastService.ShowWarning("Please select a projection program to add steps to!");
            }
            return;
        }

        ProjectionProgramStep newStep = CreateNewStep(DragState.CurrentTemplate, insertIndex, SelectedProgram.Id);
        InsertStepAt(insertIndex, newStep);

        DragState.Clear();
        _ = NotifyStepsChangedAsync();
    }

    private void OnDropAtEnd(DragEventArgs e)
    {
        if (!DragState.HasDrag || DragState.CurrentTemplate is null || SelectedProgram is null)
        {
            if (SelectedProgram is null)
            {
                _toastService.ShowWarning("Please select a projection program to add steps to!");
            }
            return;
        }

        int insertIndex = SelectedProgram.ProjectionProgramSteps.Count;
        ProjectionProgramStep newStep = CreateNewStep(DragState.CurrentTemplate, insertIndex, SelectedProgram.Id);
        InsertStepAt(insertIndex, newStep);

        DragState.Clear();
        _ = NotifyStepsChangedAsync();
    }

    private ProjectionProgramStep CreateNewStep(ProjectionProgramStepTemplate template, int sortOrder, Guid programId)
    {
        ProjectionProgramStep newStep = new()
        {
            Id = Guid.NewGuid(),
            Template = template,
            TemplateId = template.Id,
            SortOrder = sortOrder,
            IsActive = true,
            ProjectionProgramId = programId,
            ParameterValues = new List<ProjectionProgramParameterValue>()
        };

        if (template.Parameters?.Any() == true)
        {
            foreach (ProjectionProgramStepTemplateParameter parameter in template.Parameters)
            {
                newStep.ParameterValues.Add(new ProjectionProgramParameterValue
                {
                    Id = Guid.NewGuid(),
                    ParameterId = parameter.Id,
                    Parameter = parameter,
                    ProjectionProgramStepId = newStep.Id,
                    Value = string.Empty
                });
            }
        }

        return newStep;
    }

    private void InsertStepAt(int index, ProjectionProgramStep newStep)
    {
        if (SelectedProgram is null)
        {
            return;
        }

        index = Math.Clamp(index, 0, SelectedProgram.ProjectionProgramSteps.Count);

        SelectedProgram.ProjectionProgramSteps.Insert(index, newStep);

        for (int i = 0; i < SelectedProgram.ProjectionProgramSteps.Count; i++)
        {
            SelectedProgram.ProjectionProgramSteps[i].SortOrder = i;
        }
    }

    private async Task NotifyStepsChangedAsync()
    {
        await OnStepsChanged.InvokeAsync();
    }

    private async Task DeleteProjectionProgramStep(ProjectionProgramStep step)
    {
        if (SelectedProgram is null)
        {
            return;
        }

        Result<bool> deleteResult = await _projectionProgramService.DeleteProjectionProgramStepAsync(step.Id);

        if (!deleteResult.IsSuccess)
        {
            _toastService.ShowError($"Failed to delete projection program step: {deleteResult.Error}");
            return;
        }

        SelectedProgram.ProjectionProgramSteps.RemoveAll(x => x.Id == step.Id);

        for (int i = 0; i < SelectedProgram.ProjectionProgramSteps.Count; i++)
        {
            SelectedProgram.ProjectionProgramSteps[i].SortOrder = i;
        }

        _toastService.ShowSuccess("Projection program step deleted.");

        await NotifyStepsChangedAsync();
    }
}