@page "/staff/kiosk/{clientId}/{projectionProgramId}"

@using Lanyard.Application.Services
@using Lanyard.App.Components.Kiosk

@inject IProjectionProgramService _projectionProgramService
@inject IClientService _clientService
@inject IToastService _toastService

<PageTitle>Kiosk</PageTitle>

@if (projectionProgram == null || clientProjectionSettings == null)
{
    <FluentCard Height="auto">
        Loading..
        <FluentProgress Width="200px"></FluentProgress>

        <FluentLabel Typo="Typography.H6">Client Id: @clientId, Projection Program Id: @projectionProgramId</FluentLabel>
    </FluentCard>
}
else
{
    <KioskDisplay ProjectionProgram="@projectionProgram" RepeatCount="clientProjectionSettings.RepeatNumberOfTimes" RepeatInfinitely="clientProjectionSettings.RepeatInfinitely"></KioskDisplay>

    <KioskDebugInfo Hidden="@(clientProjectionSettings.ShowDebugMode)" CurrentStep="CurrentStep" StepsCount="projectionProgram.ProjectionProgramSteps.Count()"></KioskDebugInfo>
}

<FluentDesignTheme @bind-Mode="@themeMode" StorageName="kiosk-theme" />

@code {
    [Parameter]
    public string clientId { get; set; } = string.Empty;

    [Parameter]
    public string projectionProgramId { get; set; } = string.Empty;

    public ProjectionProgramStep? CurrentStep { get; set; } = null;

    private ClientProjectionSettings? clientProjectionSettings { get; set; } = null;

    private ProjectionProgram? projectionProgram { get; set; } = null;

    public DesignThemeModes themeMode { get; set; }

    protected async override Task OnInitializedAsync()
    {
        Result<ProjectionProgram> getResult = await _projectionProgramService.GetProjectionProgramAsync(Guid.Parse(projectionProgramId));

        Result<IEnumerable<ClientProjectionSettings>> getResult1 = await _clientService.GetClientProjectionSettingsAsync(Guid.Parse(clientId));

        if (getResult1.IsSuccess)
        {
            clientProjectionSettings = getResult1.Data!.Where(x => x.ProjectionProgramId == Guid.Parse(projectionProgramId)).FirstOrDefault();
        }
        else
        {
            if (getResult1.Error != null)
            {
                _toastService.ShowError(getResult1.Error);
            }

            return;
        }

        if (getResult.IsSuccess)
        {
            projectionProgram = getResult.Data!;
        }
        else
        {
            if (getResult.Error != null)
            {
                _toastService.ShowError(getResult.Error);
            }

            return;
        }

        themeMode = clientProjectionSettings!.IsDarkTheme ? DesignThemeModes.Dark : DesignThemeModes.Light;
    }
}