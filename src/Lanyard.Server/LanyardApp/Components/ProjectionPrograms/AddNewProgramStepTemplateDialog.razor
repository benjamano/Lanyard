@using Lanyard.Application.Services

@inject IProjectionProgramService _projectionService

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size24.WindowNew())" />
            <FluentText Typo="Typography.PaneHeader">Create new Step Template</FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        <EditForm Model="newTemplate" OnValidSubmit="HandleCreate">
            <DataAnnotationsValidator />
            <FluentValidationSummary />

            <FluentGrid Spacing="3">
                <FluentGridItem Xs="4">
                    <FluentTextInput Class="w-100" @bind-Value="newTemplate.Name" Label="Template Name" Appearance="TextInputAppearance.Outline" Required="true" />
                </FluentGridItem>
                <FluentGridItem Xs="4">
                    <FluentTextArea Class="w-100" @bind-Value="newTemplate.Description" Label="Template Description" Appearance="TextAreaAppearance.Outline" />
                </FluentGridItem>
            </FluentGrid>

            <FluentGrid class="mt-2" Justify="JustifyContent.FlexStart" Spacing="3">
                <FluentGridItem Xs="4">
                    <FluentTextInput Class="w-100" @bind-Value="newParameter.Name" Label="Parameter Name" Appearance="TextInputAppearance.Outline" Required="true" />
                </FluentGridItem>

                <FluentGridItem Xs="4">
                    <FluentSelect Class="w-100" @bind-Value="newParameter.DataType" TOption="string" TValue="string" Label="Parameter Data Type" Required="true">
                        <FluentOption Value="@("String")">String</FluentOption>
                        <FluentOption Value="@("Integer")">Integer</FluentOption>
                        <FluentOption Value="@("Float")">Float</FluentOption>
                        <FluentOption Value="@("Boolean")">Boolean</FluentOption>
                        <FluentOption Value="@("DateTime")">DateTime</FluentOption>
                        <FluentOption Value="@("File")">File</FluentOption>
                        <FluentOption Value="@("VideoFile")">VideoFile</FluentOption>
                        <FluentOption Value="@("Dashboard")">Dashboard</FluentOption>
                    </FluentSelect>
                </FluentGridItem>

                <FluentGridItem Xs="4">
                    <FluentButton Appearance="ButtonAppearance.Outline" IconStart="new Icons.Regular.Size20.FormNew()" OnClick="HandleAddParameter">Add Parameter</FluentButton>
                </FluentGridItem>
            </FluentGrid>

            <FluentDataGrid TGridItem="ProjectionProgramStepTemplateParameter" Items="@newTemplate.Parameters.AsQueryable()">
                <ChildContent>
                    <PropertyColumn Property="x => x.Name" TProp="string" TGridItem="ProjectionProgramStepTemplateParameter" Title="Name" />
                    <PropertyColumn Property="x => x.DataType" TProp="string" TGridItem="ProjectionProgramStepTemplateParameter" Title="Data Type" />
                </ChildContent>
                <EmptyContent>
                    No Parameters Added!
                </EmptyContent>
            </FluentDataGrid>
        </EditForm>
    </ChildContent>
    <ActionTemplate>
        <FluentButton OnClick="HandleCreate" Loading="@isCreating" Disabled="@finishButtonIsDisabled" IconStart="new Icons.Regular.Size20.Save()">Create</FluentButton>
        <FluentButton OnClick="CancelDialog" Loading="@isCreating" IconStart="new Icons.Regular.Size20.CalendarCancel()">Cancel</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code {
    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    private bool isCreating = false;
    private bool finishButtonIsDisabled = false;

    private ProjectionProgramStepTemplateParameter newParameter = new()
    {
        TemplateId = Guid.Empty,
        Name = "New Parameter",
        DataType = "String"
    };

    private ProjectionProgramStepTemplate newTemplate = new()
    {
        Name = "New Template",
        IsActive = true,
        Parameters = []
    };

    private async Task HandleCreate()
    {
        isCreating = true;

        Result<ProjectionProgramStepTemplate> result = await _projectionService.CreateProjectionProgramStepTemplateAsync(newTemplate);

        if (result.IsSuccess)
        {
            await Dialog.CloseAsync(DialogResult.Ok(result.Data));
        }
        else
        {
            finishButtonIsDisabled = false;
            isCreating = false;
        }
    }

    private void HandleAddParameter()
    {
        newTemplate.Parameters.Add(newParameter);

        newParameter = new ProjectionProgramStepTemplateParameter
        {
            TemplateId = Guid.Empty,
            Name = "New Parameter",
            DataType = "String"
        };
    }

    private async Task CancelDialog()
    {
        await Dialog.CloseAsync();
    }
}
