<FluentButton IconStart="new Icons.Regular.Size20.TabDesktopNewPage()"
    OnClick="() => OpenCreateNewProgramStepTemplateDialog()"
    Class="mx-auto">Add New Template
</FluentButton>

@code {
    [Parameter]
    public EventCallback<ProjectionProgramStepTemplate> OnTemplateCreated { get; set; }

    private async Task OpenCreateNewProgramStepTemplateDialog()
    {
        DialogResult result = await _dialogService.ShowDialogAsync<AddNewProgramStepTemplateDialog>(options =>
        {
            options.Width = "50%";
            options.Modal = true;
        });

        await OnTemplateCreated.InvokeAsync(result.Value as ProjectionProgramStepTemplate);
    }
}
