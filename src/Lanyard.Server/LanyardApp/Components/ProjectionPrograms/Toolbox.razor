@using Lanyard.Application.Services
@using Lanyard.App.Services
@using Lanyard.App.Components.Kiosk

@inject IProjectionProgramService _projectionService
@inject IToastService _toastService
@inject DragStateService DragState

<FluentStack Orientation="Orientation.Vertical" Style="height:100%;">
    <FluentStack class="ps-3" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentText Typo="Typography.PaneHeader">
            <FluentIcon Value="@(new Icons.Regular.Size24.Toolbox())" Margin="@Margin.End2"/>
            Toolbox
        </FluentText>
        <FluentDivider Orientation="Orientation.Horizontal" Class="w-100"></FluentDivider>

        @if (isLoading)
        {
            <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Class="mt-4">
                <FluentSpinner />
            </FluentStack>
        }
        else if (stepTemplates.Count == 0)
        {
            <FluentText Class="mt-4 text-center" Typo="Typography.Body">No templates available</FluentText>
        }
        else
        {
            foreach (ProjectionProgramStepTemplate template in stepTemplates)
            {
                <FluentCard Appearance="CardAppearance.Filled" Class="toolbox-card" draggable="true" @ondragstart="(e) => OnDragStart(e, template)" @ondragend="OnDragEnd">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Class="toolbox-card-header">
                        <FluentIcon Value="@GetTemplateIcon(template.Name)" Color="Color.Primary" Class="toolbox-card-icon" />
                        <FluentText Typo="Typography.H6" Class="toolbox-card-title">@template.Name</FluentText>
                    </FluentStack>
                    @if (!string.IsNullOrWhiteSpace(template.Description))
                    {
                        <FluentText Class="toolbox-card-description" Typo="Typography.Body">@template.Description</FluentText>
                    }
                </FluentCard>
            }
        }
    </FluentStack>

    <FluentStack VerticalAlignment="VerticalAlignment.Center" HorizontalAlignment="HorizontalAlignment.Right" class="mt-2">
        <FluentButton Disabled="@(!ShowSaveButton || IsSaving)" 
                     OnClick="HandleSave" 
                     Appearance="ButtonAppearance.Primary" 
                     IconStart="new Icons.Regular.Size20.Save()"
                     Loading="@IsSaving">
            Save
        </FluentButton>
    </FluentStack>
</FluentStack>

@code{
    [Parameter]
    public EventCallback OnSaveClicked { get; set; }

    [Parameter]
    public bool ShowSaveButton { get; set; }

    [Parameter]
    public bool IsSaving { get; set; }

    private List<ProjectionProgramStepTemplate> stepTemplates = new();
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadStepTemplatesAsync();
    }

    private async Task LoadStepTemplatesAsync()
    {
        isLoading = true;

        Result<IEnumerable<ProjectionProgramStepTemplate>> getResult = await _projectionService.GetProjectionProgramStepTemplatesAsync();

        if (!getResult.IsSuccess)
        {
            _toastService.ShowError($"An error occurred when fetching projection program step templates: {getResult.Error}");
            stepTemplates = new();
        }
        else
        {
            stepTemplates = getResult.Data!.ToList();
        }

        isLoading = false;
    }

    private static Icon GetTemplateIcon(string templateName) => templateName switch
    {
        KioskTemplateConstants.TemplateNames.ShowText => new Icons.Regular.Size24.TextFont(),
        KioskTemplateConstants.TemplateNames.PlayVideo => new Icons.Regular.Size24.Video(),
        KioskTemplateConstants.TemplateNames.Delay => new Icons.Regular.Size24.Timer(),
        KioskTemplateConstants.TemplateNames.Dashboard => new Icons.Regular.Size24.SlideGrid(),
        KioskTemplateConstants.TemplateNames.LiveCapture => new Icons.Regular.Size24.Camera(),
        _ => new Icons.Regular.Size24.PuzzlePiece()
    };

    private void OnDragStart(DragEventArgs e, ProjectionProgramStepTemplate template)
    {
        DragState.StartDrag(template, source: this);
    }

    private void OnDragEnd(DragEventArgs e)
    {
        DragState.Clear();
    }

    private async Task HandleSave()
    {
        await OnSaveClicked.InvokeAsync();
    }
}