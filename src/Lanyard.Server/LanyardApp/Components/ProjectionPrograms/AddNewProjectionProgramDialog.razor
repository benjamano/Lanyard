@using Lanyard.Application.Services

@inject IProjectionProgramService _projectionService
@inject IToastService _toastService

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size24.WindowNew())" />
            <FluentText Typo="Typography.PaneHeader">Create new Projection Program</FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        <EditForm Model="newProgram" OnValidSubmit="HandleCreate">
            <DataAnnotationsValidator />
            <FluentValidationSummary />
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <FluentTextInput Class="w-100" @bind-Value="newProgram.Name" Label="Program Name" Appearance="TextInputAppearance.Outline" Required="true" />
                <FluentTextArea Class="w-100" @bind-Value="newProgram.Description" Label="Description" Appearance="TextAreaAppearance.Outline" />
            </FluentStack>
        </EditForm>
    </ChildContent>
    <ActionTemplate>
        <FluentButton OnClick="HandleCreate" Loading="@isCreating" Disabled="@finishButtonIsDisabled" IconStart="new Icons.Regular.Size20.Save()">Create</FluentButton>
        <FluentButton OnClick="CancelDialog" Loading="@isCreating" IconStart="new Icons.Regular.Size20.CalendarCancel()">Cancel</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code {
    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    private bool isCreating = false;
    private bool finishButtonIsDisabled = false;

    private ProjectionProgram newProgram = new()
    {
        Name = "New Program",
        IsActive = true,
    };

    private async Task HandleCreate()
    {
        isCreating = true;

        Result<ProjectionProgram> result = await _projectionService.CreateProjectionProgramAsync(newProgram);

        if (result.IsSuccess)
        {
            _toastService.ShowSuccess("New Program created Successfully!");
            await Dialog.CloseAsync(DialogResult.Ok(result.Data));
        }
        else
        {
            finishButtonIsDisabled = false;
            isCreating = false;
            _toastService.ShowError($"An error occured when creating the program, {result.Error}");
        }
    }

    private async Task CancelDialog()
    {
        await Dialog.CloseAsync();
    }
}
