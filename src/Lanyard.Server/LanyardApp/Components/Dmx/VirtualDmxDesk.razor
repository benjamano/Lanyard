@implements IDisposable

@inject IDmxService _dmxService

<FluentCard Height="auto" Class="p-0">
    @if (_isLoading)
    {
        <div class="p-4">
            <FluentLabel>Loading channels...</FluentLabel>
            <FluentProgress />
        </div>
    }
    else
    {
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="0">

            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8" Class="p-3"
                         Style="border-bottom: 1px solid var(--neutral-stroke-rest);">
                <FluentButton IconStart="new Icons.Regular.Size20.ChevronDoubleLeft()"
                              Appearance="Appearance.Neutral"
                              Disabled="@(_currentPage == 1)"
                              OnClick="() => GoToPage(1)" />
                <FluentButton IconStart="new Icons.Regular.Size20.ChevronLeft()"
                              Appearance="Appearance.Neutral"
                              Disabled="@(_currentPage == 1)"
                              OnClick="() => GoToPage(_currentPage - 1)" />

                <FluentLabel Style="min-width: 140px; text-align: center;">
                    Ch @PageFirstChannel-@PageLastChannel &nbsp;/&nbsp; Page @_currentPage of @TotalPages
                </FluentLabel>

                <FluentButton IconStart="new Icons.Regular.Size20.ChevronRight()"
                              Appearance="Appearance.Neutral"
                              Disabled="@(_currentPage == TotalPages)"
                              OnClick="() => GoToPage(_currentPage + 1)" />
                <FluentButton IconStart="new Icons.Regular.Size20.ChevronDoubleRight()"
                              Appearance="Appearance.Neutral"
                              Disabled="@(_currentPage == TotalPages)"
                              OnClick="() => GoToPage(TotalPages)" />

                <FluentSelect TOption="int"
                              Items="@_pageSizeOptions"
                              OptionText="@(n => $"{n} / page")"
                              OptionValue="@(n => n.ToString())"
                              SelectedOption="@_pageSize"
                              SelectedOptionChanged="@OnPageSizeChanged"
                              Style="width: 120px;" />
            </FluentStack>

            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4" HorizontalAlignment="HorizontalAlignment.Left"
                         Style="overflow-x: auto; scrollbar-width: auto; scrollbar-color: var(--accent-fill-rest) var(--neutral-fill-rest);"
                         Class="p-4">
                @foreach (KeyValuePair<int, int> channel in PagedChannels)
                {
                    <FluentCard @key="channel.Key" Height="auto" MinimalStyle="true">
                        <FluentStack Orientation="Orientation.Vertical"
                                     HorizontalAlignment="HorizontalAlignment.Center" VerticalGap="2">
                            <FluentBadge Style="font-variant-numeric: tabular-nums; text-align: center;"
                                         Class="mb-2" Appearance="Appearance.Neutral">
                                @channel.Key
                            </FluentBadge>
                            <FluentSlider @key="channel.Key"
                                          Orientation="Orientation.Vertical"
                                          Disabled="@(ClientId == null || !IsEditModeEnabled)"
                                          TValue="int"
                                          Value="@(255 - channel.Value)"
                                          Min="0" Max="255" Step="1"
                                          ValueChanged="(int newValue) => UpdateChannelValue(newValue, channel.Key)"
                                          Class="mb-2 ps-3"
                                          Style="min-width: 30px;">
                                @if (channel.Key == PageFirstChannel)
                                {
                                    <FluentSliderLabel Position="255" TValue="int">0</FluentSliderLabel>
                                    <FluentSliderLabel Position="127" TValue="int">127</FluentSliderLabel>
                                    <FluentSliderLabel Position="0" TValue="int">255</FluentSliderLabel>
                                }
                            </FluentSlider>
                            <FluentBadge Style="font-variant-numeric: tabular-nums; text-align: center;"
                                         Class="mt-2" Appearance="Appearance.Neutral">
                                @channel.Value
                            </FluentBadge>
                            <FluentButton IconStart="new Icons.Regular.Size20.Dismiss()"
                                          Appearance="Appearance.Neutral"
                                          OnClick="() => UpdateChannelValue(0, channel.Key)"
                                          Disabled="@(ClientId == null || !IsEditModeEnabled)"
                                          Class="mt-2" />
                        </FluentStack>
                    </FluentCard>
                }
            </FluentStack>
        </FluentStack>
    }
</FluentCard>

@code {
    [Parameter]
    public Guid? ClientId { get; set; }

    [Parameter]
    public bool IsEditModeEnabled { get; set; } = false;

    [Parameter]
    public bool IsBlindModeEnabled { get; set; } = false;

    // Key: Channel number (1–512), Value: Channel value (0–255)
    private Dictionary<int, int> channelValues = new();
    private bool _isLoading = true;

    private int _currentPage = 1;
    private int _pageSize = 32;
    private readonly List<int> _pageSizeOptions = new() { 16, 32, 64, 128 };

    private int TotalPages => (int)Math.Ceiling(channelValues.Count / (double)_pageSize);
    private int PageFirstChannel => (_currentPage - 1) * _pageSize + 1;
    private int PageLastChannel => Math.Min(_currentPage * _pageSize, channelValues.Count);

    private IEnumerable<KeyValuePair<int, int>> PagedChannels =>
        channelValues
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize);

    protected override async Task OnInitializedAsync()
    {
        _dmxService.OnChannelValueChanged += HandleChannelValueChanged;
    }
    
    private void HandleChannelValueChanged(Guid clientId, int channel, byte value)
    {
        if (IsBlindModeEnabled == true)
        {
            return;
        }

        if (ClientId != null && clientId == ClientId)
        {
            channelValues[channel] = value;

            InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadChannelValues();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadChannelValues();
    }

    private async Task LoadChannelValues()
    {
        _isLoading = true;
        StateHasChanged();

        Result<IEnumerable<Infrastructure.Models.Dmx.DmxChannel>>? channelValuesResult = await _dmxService.GetDmxChannelsAsync(ClientId ?? Guid.Empty);

        if (channelValuesResult.IsSuccess && channelValuesResult.Data != null)
        {
            channelValues = channelValuesResult.Data.ToDictionary(kvp => kvp.Address, kvp => (int)kvp.Value);
        }

        _currentPage = 1;
        _isLoading = false;

        StateHasChanged();
    }

    private void GoToPage(int page)
    {
        _currentPage = Math.Clamp(page, 1, TotalPages);
    }

    private void OnPageSizeChanged(int newSize)
    {
        _pageSize = newSize;
        _currentPage = 1;
    }

    public void CreateChannels()
    {
        channelValues = Enumerable.Range(1, 512)
            .ToDictionary(i => i, _ => 0);
        _currentPage = 1;

        StateHasChanged();
    }

    private void UpdateChannelValue(int newValue, int channelNumber)
    {
        if (ClientId != null)
        {
            channelValues[channelNumber] = newValue;

            _dmxService.UpdateChannelValue(ClientId.Value, channelNumber, (byte)(255 - newValue));
        }
    }

    public void Dispose()
    {
        _dmxService.OnChannelValueChanged -= HandleChannelValueChanged;
    }
}