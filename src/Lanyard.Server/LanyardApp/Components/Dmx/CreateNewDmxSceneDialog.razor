@using System.ComponentModel.DataAnnotations

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="new Icons.Regular.Size24.WindowApps()" Margin="@Margin.End2"/>
            <FluentText Size="@TextSize.Size500">Create new DMX scene</FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        <EditForm EditContext="@_editContext">
            <DataAnnotationsValidator />
            <FluentTextInput Label="Scene name"
                             Value="@Content.SceneName"
                             ValueChanged="@(value => Content.SceneName = value)"
                             Style="width: 100%;" />
            <FluentValidationSummary />
        </EditForm>
    </ChildContent>
    <ActionTemplate>
        <FluentButton Appearance="ButtonAppearance.Primary"
                      Disabled="@(!_editContext.Validate())"
                      OnClick="@SaveAsync">
            Save
        </FluentButton>
        <FluentButton OnClick="@CancelAsync">Cancel</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code
{
    private EditContext _editContext = default!;

    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    public CreateNewDmxSceneDialogModel Content { get; set; } = new();

    public class CreateNewDmxSceneDialogModel
    {
        [Required(ErrorMessage = "Scene name is required.")]
        public string SceneName { get; set; } = string.Empty;
    }

    protected override void OnInitialized()
    {
        _editContext = new EditContext(Content);
    }

    private async Task SaveAsync()
    {
        if (_editContext.Validate())
        {
            await Dialog.CloseAsync(Content.SceneName);
        }
    }

    private async Task CancelAsync()
    {
        await Dialog.CancelAsync();
    }
}
