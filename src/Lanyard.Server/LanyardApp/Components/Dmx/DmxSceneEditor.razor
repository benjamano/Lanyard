@using Lanyard.Infrastructure.Models.Dmx
@using Lanyard.App.Components.Dialogs

@inject IDmxSceneService _dmxSceneService
@inject IToastService _toastService

@if (OpenScene != null)
{
    <FluentStack Orientation="@Orientation.Vertical"
                    VerticalGap="8"
                    Height="100%">
        <FluentCard Appearance="@CardAppearance.Default" Width="100%">
            <FluentStack HorizontalAlignment="@HorizontalAlignment.SpaceBetween">
                <FluentStack Orientation="@Orientation.Horizontal" 
                                HorizontalAlignment="HorizontalAlignment.Start" 
                                VerticalAlignment="VerticalAlignment.Stretch"
                                HorizontalGap="4">
                    
                    <FluentStack Width="auto">
                        <FluentGrid>
                            <FluentGridItem HiddenWhen="@GridItemHidden.SmAndDown">
                                <FluentButton IconStart="new Icons.Regular.Size20.ChevronDoubleRight()"
                                            Appearance="ButtonAppearance.Subtle"
                                            OnClick="@OnClose" />
                            </FluentGridItem>
                            <FluentGridItem HiddenWhen="@GridItemHidden.MdAndUp">
                                <FluentButton IconStart="new Icons.Regular.Size20.Dismiss()"
                                            Appearance="ButtonAppearance.Subtle"
                                            OnClick="@OnClose" />
                            </FluentGridItem>
                        </FluentGrid>
                    </FluentStack>
                    
                    <FluentText Size="TextSize.Size500"
                                Color="Color.Default">
                        Scene - @OpenScene.Name
                    </FluentText>
                </FluentStack>
                
                <FluentButton IconStart="new Icons.Regular.Size20.BinRecycle()"
                                Appearance="ButtonAppearance.Transparent"
                                Disabled="@(!IsEditModeEnabled)"
                                OnClick="@(() => DeleteScene(OpenScene))" 
                                Tooltip="Delete Scene"/>
            </FluentStack>
        </FluentCard>

        <DmxSceneSettings OpenScene="@OpenScene" OnSceneEdited="@OnSceneEdited"/>

        <FluentCard Height="100%">
                <FluentDataGrid Items="@sceneSteps?.AsQueryable()"
                                Loading="@((sceneSteps == null))"
                                ShowHover="@IsEditModeEnabled"
                                StripedRows="false"
                                TGridItem="DmxSceneStep"
                                RowSize="@DataGridRowSize.Medium"
                                OnRowClick="@((context) => OnRowClick(context.Item))"
                                GridTemplateColumns="@gridTemplateColumns"
                                AutoItemsPerPage="true">
                    <ChildContent>
                        <SelectColumn TGridItem="DmxSceneStep" 
                                        SelectMode="@DataGridSelectMode.Single"
                                        SelectFromEntireRow="true"
                                        SelectedItems="@selectedStep" 
                                        Selectable="@((x) => IsEditModeEnabled)"/>
                        <PropertyColumn Property="x=> x.StepNumber" 
                                        Title="#" 
                                        Sortable="true"
                                        InitialSortDirection="@DataGridSortDirection.Ascending" />
                        <TemplateColumn Title="Duration">
                            <ChildContent>
                                @if (editingStepDuration == context && IsEditModeEnabled)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="4">
                                        <FluentTextInput Value="@durationEditText"
                                                        ValueChanged="@((v) => durationEditText = v)"
                                                        Pattern="^([0-1]?[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$"
                                                        Placeholder="hh:mm:ss"
                                                        Style="min-width: 80px;"
                                                        Disabled="@(!IsEditModeEnabled)" />
                                        <FluentButton Appearance="ButtonAppearance.Transparent"
                                                      IconStart="new Icons.Regular.Size20.Checkmark()"
                                                      Tooltip="Save"
                                                      OnClick="@(async () => await OnStepDurationChanged(context, durationEditText))" 
                                                      Disabled="@(!IsEditModeEnabled)" />
                                        <FluentButton Appearance="ButtonAppearance.Transparent"
                                                      IconStart="new Icons.Regular.Size20.Dismiss()"
                                                      Tooltip="Cancel"
                                                      OnClick="@(() => editingStepDuration = null)" 
                                                      Disabled="@(!IsEditModeEnabled)" />
                                    </FluentStack>
                                }
                                else
                                {
                                    <FluentButton Appearance="@ButtonAppearance.Transparent" 
                                                    OnClick="@(() => { editingStepBeats = null; editingStepDuration = context; durationEditText = context.Duration.ToString(@"hh\:mm\:ss"); })"
                                                    Disabled="@(!IsEditModeEnabled)"
                                                    Padding="@Padding.Start0"
                                                    Margin="@Margin.Start0">
                                        @context.Duration.ToString("hh\\:mm\\:ss")
                                    </FluentButton>
                                }
                            </ChildContent>
                        </TemplateColumn>
                        <TemplateColumn Title="Beats">
                            <ChildContent>
                                @if (editingStepBeats == context && IsEditModeEnabled && OpenScene.BpmSyncEnabled)
                                {
                                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="4">
                                        <FluentNumberInput TValue="double"
                                                        Value="@beatsEditValue"
                                                        ValueChanged="@((double v) => beatsEditValue = v)"
                                                        Min="0.25"
                                                        Max="64"
                                                        Step="0.25"
                                                        Width="70px" />
                                        <FluentButton Appearance="ButtonAppearance.Transparent"
                                                      IconStart="new Icons.Regular.Size20.Checkmark()"
                                                      Tooltip="Save"
                                                      OnClick="@(async () => await OnStepBeatsChanged(context, beatsEditValue))" />
                                        <FluentButton Appearance="ButtonAppearance.Transparent"
                                                      IconStart="new Icons.Regular.Size20.Dismiss()"
                                                      Tooltip="Cancel"
                                                      OnClick="@(() => editingStepBeats = null)" />
                                    </FluentStack>
                                }
                                else
                                {
                                    @* Beats only apply while BPM Sync is on; keep the value visible
                                       but inert (and dimmed) when it is off, so the grid doesn't reflow. *@
                                    <FluentButton Appearance="@ButtonAppearance.Transparent"
                                                    OnClick="@(() => { editingStepDuration = null; editingStepBeats = context; beatsEditValue = context.Beats; })"
                                                    Disabled="@(!IsEditModeEnabled || !OpenScene.BpmSyncEnabled)"
                                                    Tooltip="@(OpenScene.BpmSyncEnabled ? "Beats this step holds while synced" : "Enable BPM Sync in scene settings to use beats")"
                                                    Padding="@Padding.Start0"
                                                    Margin="@Margin.Start0"
                                                    Style="@(OpenScene.BpmSyncEnabled ? null : "opacity: 0.5;")">
                                        @context.Beats
                                    </FluentButton>
                                }
                            </ChildContent>
                        </TemplateColumn>
                        <TemplateColumn>
                            <ChildContent>
                                <FluentStack Orientation="@Orientation.Horizontal"
                                                HorizontalAlignment="HorizontalAlignment.Center"
                                                VerticalAlignment="VerticalAlignment.Center"
                                                HorizontalGap="4">
                                    <FluentButton Appearance="ButtonAppearance.Transparent"
                                                IconStart="new Icons.Regular.Size20.BinRecycle()"
                                                Tooltip="Delete Step"
                                                OnClick="@(() => DeleteStep(context))"
                                                Disabled="@(!IsEditModeEnabled)" />
                                </FluentStack>
                            </ChildContent>
                            <HeaderCellItemTemplate>
                                <FluentButton Appearance="ButtonAppearance.Transparent" 
                                                IconStart="new Icons.Regular.Size20.AddCircle()" 
                                                Tooltip="Add Step"
                                                OnClick="AddStep"
                                                Disabled="@(!IsEditModeEnabled)" />
                            </HeaderCellItemTemplate>
                        </TemplateColumn>
                    </ChildContent>
                    <EmptyContent>
                        <FluentStack Orientation="Orientation.Vertical" 
                                        HorizontalAlignment="HorizontalAlignment.Center" 
                                        VerticalAlignment="VerticalAlignment.Center"
                                        Height="100%">
                            <FluentText Size="TextSize.Size400">No steps found for this scene.</FluentText>
                        </FluentStack>
                    </EmptyContent>
                </FluentDataGrid>
        </FluentCard>
    </FluentStack>
}

@code {
    [Parameter]
    public required Guid? ClientId { get; set; }

    [Parameter]
    public required DmxScene? OpenScene { get; set; }

    [Parameter]
    public required bool IsEditModeEnabled { get; set; }

    [Parameter]
    public required EventCallback OnClose { get; set; }

    [Parameter]
    public required EventCallback<DmxScene> OnSceneDeleted { get; set; }

    [Parameter]
    public EventCallback<DmxSceneStep?> OnEditingStepChanged { get; set; }

    [Parameter]
    public EventCallback<DmxScene> OnSceneEdited { get; set; }

    private List<DmxSceneStep>? sceneSteps = null;

    private List<DmxSceneStep> selectedStep = new();
    private DmxSceneStep? editingStepDuration = null;
    private string durationEditText = string.Empty;
    private DmxSceneStep? editingStepBeats = null;
    private double beatsEditValue = 1;
    private Guid? _loadedSceneId;

    // The editor panel is too narrow to fit an inline editor (input + save/cancel buttons)
    // in both the Duration and Beats columns at once, so the column being edited borrows
    // width from the other; only one inline editor is ever open at a time. Plain fr units
    // don't work here: each column's auto (min-content) floor wins in a container this
    // narrow, so the editor input collapses. minmax() pixel minimums override that floor.
    private string gridTemplateColumns => editingStepBeats != null
        ? "36px 56px minmax(70px, 1fr) minmax(150px, 3fr) 44px"
        : "36px 56px minmax(150px, 3fr) minmax(52px, 1fr) 44px";

    protected override async Task OnParametersSetAsync()
    {
        if (ClientId.HasValue && OpenScene != null && OpenScene.Id != _loadedSceneId)
        {
            _loadedSceneId = OpenScene.Id;
            editingStepDuration = null;
            editingStepBeats = null;
            selectedStep.Clear();
            await OnEditingStepChanged.InvokeAsync(null);
            Result<List<DmxSceneStep>> result = await _dmxSceneService.GetSceneStepsAsync(OpenScene.Id);

            if (result.IsSuccess)
            {
                sceneSteps = result.Data;
            }
            else
            {
                _toastService.ShowError($"Failed to load scene steps: {result.Error}");

                sceneSteps = new List<DmxSceneStep>();
            }
        }
    }

    private async Task DeleteScene(DmxScene scene)
    {
        DialogResult result = await _dialogService.ShowDialogAsync<ConfirmationDialog>(options =>
        {
            options.Header.Title = "Delete Scene";
            options.Width = "450px";
            options.Modal = true;
            options.Parameters.Add(nameof(ConfirmationDialog.Message), $"Are you sure you want to delete '{scene.Name}'? This action cannot be undone.");
            options.Parameters.Add(nameof(ConfirmationDialog.ConfirmText), "Delete");
        });

        if (!result.Cancelled && result.Value is true)
        {
            Result<bool> deleteResult = await _dmxSceneService.DeleteSceneAsync(scene.Id);
            
            if (deleteResult.IsSuccess)
            {
                await OnSceneDeleted.InvokeAsync(scene);

                _toastService.ShowSuccess($"Scene '{scene.Name}' deleted successfully.");
            }
            else
            {
                _toastService.ShowError($"Failed to delete scene '{scene.Name}': {deleteResult.Error}");
            }
        }
    }

    private async Task DeleteStep(DmxSceneStep step)
    {
        DialogResult result = await _dialogService.ShowDialogAsync<ConfirmationDialog>(options =>
        {
            options.Header.Title = "Delete Step";
            options.Width = "450px";
            options.Modal = true;
            options.Parameters.Add(nameof(ConfirmationDialog.Message), $"Are you sure you want to delete step '{step.StepNumber}'? This action cannot be undone.");
            options.Parameters.Add(nameof(ConfirmationDialog.ConfirmText), "Delete");
        });

        if (!result.Cancelled && result.Value is true)
        {
            Result<bool> deleteResult = await _dmxSceneService.DeleteSceneStepAsync(step.Id);
            
            if (deleteResult.IsSuccess)
            {
                sceneSteps?.Remove(step);

                if (selectedStep.Remove(step))
                {
                    await OnEditingStepChanged.InvokeAsync(null);
                }

                await OnSceneEdited.InvokeAsync(OpenScene);

                StateHasChanged();

                _toastService.ShowSuccess($"Step {step.StepNumber} deleted successfully.");
            }
            else
            {
                _toastService.ShowError($"Failed to delete step '{step.StepNumber}': {deleteResult.Error}");
            }
        }
    }

    private async Task AddStep()
    {
        Result<DmxSceneStep> result = await _dmxSceneService.CreateSceneStepAsync(OpenScene!.Id);

        if (result.IsSuccess && result.Data != null)
        {
            sceneSteps?.Add(result.Data);

            await OnSceneEdited.InvokeAsync(OpenScene);

            StateHasChanged();
        }
        else
        {
            _toastService.ShowError($"Failed to add step: {result.Error}");
        }
    }

    private async Task OnRowClick(DmxSceneStep? step)
    {
        if (!IsEditModeEnabled)
        {
            return;
        }

        selectedStep.Clear();

        if (step != null)
        {
            selectedStep.Add(step);
        }

        await OnEditingStepChanged.InvokeAsync(step);

        StateHasChanged();
    }

    private async Task OnStepDurationChanged(DmxSceneStep step, string? rawValue)
    {
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            editingStepDuration = null;
            return;
        }

        if (!TimeSpan.TryParseExact(rawValue.Trim(), @"hh\:mm\:ss", null, out TimeSpan parsed))
        {
            _toastService.ShowError("Invalid duration format. Use hh:mm:ss (e.g. 00:01:30).");
            return;
        }

        Result<bool> result = await _dmxSceneService.UpdateSceneStepDurationAsync(step.Id, parsed);

        if (result.IsSuccess)
        {
            step.Duration = parsed;
            editingStepDuration = null;
            
            sceneSteps?.Where(s => s.Id == step.Id).ToList().ForEach(s => s.Duration = parsed);

            await OnSceneEdited.InvokeAsync(OpenScene);

            StateHasChanged();
        }
        else
        {
            _toastService.ShowError($"Failed to update step duration: {result.Error}");
        }
    }

    private async Task OnStepBeatsChanged(DmxSceneStep step, double beats)
    {
        if (beats is < 0.25 or > 64)
        {
            _toastService.ShowError("Beats must be between 0.25 and 64.");
            return;
        }

        Result<bool> result = await _dmxSceneService.UpdateSceneStepBeatsAsync(step.Id, beats);

        if (result.IsSuccess)
        {
            step.Beats = beats;
            editingStepBeats = null;

            sceneSteps?.Where(s => s.Id == step.Id).ToList().ForEach(s => s.Beats = beats);

            await OnSceneEdited.InvokeAsync(OpenScene);

            StateHasChanged();
        }
        else
        {
            _toastService.ShowError($"Failed to update step beats: {result.Error}");
        }
    }

    private void CloseEditor()
    {
        selectedStep = [];
        editingStepDuration = null;
        editingStepBeats = null;

        OnClose.InvokeAsync();
    }
}