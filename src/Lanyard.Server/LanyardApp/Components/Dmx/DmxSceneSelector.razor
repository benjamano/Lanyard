@using Lanyard.Infrastructure.DTO.Dmx
@using Lanyard.Infrastructure.Models.Dmx
@implements IDisposable

@inject IDmxSceneService _dmxSceneService
@inject IDmxSceneRunnerService _sceneRunner
@inject IDialogService _dialogService
@inject IToastService _toastService

<div>
    <FluentCard Class="mt-2" Height="100%">
        <FluentStack HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center">
            <FluentText Size="TextSize.Size600"
                        Color="Color.Default">
                Scenes
            </FluentText>
            <FluentButton IconStart="new Icons.Regular.Size20.AddCircle()"
                        Appearance="ButtonAppearance.Primary"
                        Disabled="@(ClientId == null || !IsEditModeEnabled)"
                        OnClick="CreateNewScene"
                        Class="ms-2"> 
                        Add Scene
            </FluentButton>
        </FluentStack>
        <FluentDivider Class="my-3" />
        <FluentStack Orientation="Orientation.Horizontal" 
                        HorizontalAlignment="HorizontalAlignment.Left" 
                        Wrap="true"
                        Style="min-height: 50px;">
            @if (ClientId == null)
            {
                <FluentText Size="TextSize.Size400">Select a client to view scenes.</FluentText>
            }
            else if (scenes == null)
            {
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Center">
                    Loading... <FluentSpinner Size="SpinnerSize.Tiny"></FluentSpinner>
                </FluentStack>
            }
            else if (!scenes.Any())
            {
                <FluentText Size="TextSize.Size400">No scenes found for this client.</FluentText>
            }
            else
            {
                @foreach (DmxSceneDTO scene in scenes)
                {
                    bool isRunning = runningSceneIds.Contains(scene.Id);
                    int progressValue = GetSceneProgress(scene);

                    <div style="display: flex; align-items: center; gap: 2px;">
                        <FluentButton Appearance="@ButtonAppearance.Default"
                                        Padding="@Padding.All0"
                                        Disabled="@(!IsEditModeEnabled)"
                                        Class="@($"{(isRunning ? "scene-running" : "")} {(CurrentlyOpenScene != null && CurrentlyOpenScene.Id == scene.Id ? "scene-open" : "")}")"
                                        Style="width: 120px; height: 50px;"
                                        OnClick="@(() => OnOpenScene.InvokeAsync(scene))">
                            <FluentStack Orientation="Orientation.Vertical"
                                            HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                                            VerticalAlignment="VerticalAlignment.Center"
                                            Padding="@Padding.All0">
                                <FluentText Padding="@Padding.All2">@scene.Name</FluentText>

                                @if (isRunning)
                                {
                                    <FluentProgressBar Min="0"
                                                        Max="100"
                                                        Value="@progressValue"
                                                        Width="100%" />
                                }
                            </FluentStack>
                        </FluentButton>
                        @if (scene.IsMomentary)
                        {
                            @* Handlers sit on the wrapper, not the FluentButton: the web
                               component only surfaces OnClick. *@
                            <div @onpointerdown="@((PointerEventArgs e) => StartMomentaryAsync(scene, e))"
                                    @onpointerup="@(() => StopMomentary(scene))"
                                    @onpointerleave="@(() => StopMomentary(scene))"
                                    @oncontextmenu:preventDefault="true"
                                    style="touch-action: none;">
                                <FluentButton IconStart="@(new Icons.Regular.Size20.FlashPlay())"
                                                Appearance="@(isRunning ? ButtonAppearance.Primary : ButtonAppearance.Transparent)"
                                                Disabled="@(ClientId == null)"
                                                Tooltip="Hold to run scene" />
                            </div>
                        }
                        else
                        {
                            <FluentButton IconStart="@(isRunning ? new Icons.Filled.Size20.Stop() : new Icons.Regular.Size20.Play())"
                                            Appearance="ButtonAppearance.Transparent"
                                            Disabled="@(ClientId == null)"
                                            Tooltip="@(isRunning ? "Stop Scene" : "Run Scene")"
                                            OnClick="@(() => ToggleScene(scene, isRunning))" />
                        }
                    </div>
                }
            }
        </FluentStack>
    </FluentCard>
</div>

@code {
    [Parameter]
    public Guid? ClientId { get; set; }

    [Parameter]
    public bool IsEditModeEnabled { get; set; } = false;

    [Parameter]
    public Guid? DeletedSceneId { get; set; }

    [Parameter]
    public EventCallback<DmxScene> OnOpenScene { get; set; }

    [Parameter]
    public DmxScene? CurrentlyOpenScene { get; set; }

    [Parameter]
    public Guid? EditedSceneId { get; set; }

    private List<DmxSceneDTO> scenes = [];

    private List<Guid> runningSceneIds = [];

    // Key: sceneId, Value: the step number playback last advanced to (drives the progress bar).
    private readonly Dictionary<Guid, int> sceneStepProgress = [];

    private Guid? previousClientId;

    private Guid? previousDeletedSceneId;

    // The scene currently held down on a momentary button, if any.
    private Guid? momentaryHeldSceneId;

    protected override void OnInitialized()
    {
        _sceneRunner.OnSceneStarted += HandleSceneStarted;
        _sceneRunner.OnSceneStopped += HandleSceneStopped;
        _sceneRunner.OnSceneStepAdvanced += HandleSceneStepAdvanced;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ClientId != previousClientId)
        {
            previousClientId = ClientId;

            if (ClientId != null)
            {
                await LoadScenes(ClientId.Value);
            }
            else
            {
                scenes = [];
                runningSceneIds = [];
            }
        }

        if (DeletedSceneId != null && DeletedSceneId != previousDeletedSceneId)
        {
            previousDeletedSceneId = DeletedSceneId;

            scenes.RemoveAll(scene => scene.Id == DeletedSceneId.Value);
            runningSceneIds.Remove(DeletedSceneId.Value);
        }

        if (EditedSceneId != null)
        {
            DmxSceneDTO? editedScene = scenes.FirstOrDefault(scene => scene.Id == EditedSceneId.Value);

            if (editedScene != null)
            {
                Result<DmxSceneDTO>? result = await _dmxSceneService.GetSceneByIdAsync(EditedSceneId.Value);

                if (result.IsSuccess && result.Data != null)
                {
                    int index = scenes.FindIndex(scene => scene.Id == EditedSceneId.Value);
                    scenes[index] = result.Data;
                }
                else
                {
                    _toastService.ShowError($"Failed to load updated scene: {result.Error}");
                }
            }
        }
    }

    private async Task LoadScenes(Guid clientId)
    {
        Result<IEnumerable<DmxSceneDTO>>? scenesResult = await _dmxSceneService.GetScenesForClientAsync(clientId);    

        if (scenesResult.IsSuccess && scenesResult.Data != null)
        {
            scenes = scenesResult.Data.ToList();

            runningSceneIds = scenesResult.Data.Where(s => s.IsRunning).Select(s => s.Id).ToList();
        }
        else
        {
            _toastService.ShowError($"Failed to load scenes: {scenesResult.Error}");
        }
    }

    private void HandleSceneStarted(Guid clientId, Guid sceneId)
    {
        if (clientId != ClientId) {
            return;
        }

        runningSceneIds.Add(sceneId);

        InvokeAsync(StateHasChanged);
    }

    private void HandleSceneStopped(Guid clientId, Guid sceneId)
    {
        if (clientId != ClientId) {
            return;
        }

        runningSceneIds.Remove(sceneId);
        sceneStepProgress.Remove(sceneId);

        InvokeAsync(StateHasChanged);
    }

    private void HandleSceneStepAdvanced(Guid clientId, Guid sceneId, int stepNumber)
    {
        if (clientId != ClientId) {
            return;
        }

        sceneStepProgress[sceneId] = stepNumber;

        InvokeAsync(StateHasChanged);
    }

    private int GetSceneProgress(DmxSceneDTO scene)
    {
        if (scene.StepCount <= 0 || !sceneStepProgress.TryGetValue(scene.Id, out int stepNumber))
        {
            return 0;
        }

        return (int)Math.Round(stepNumber / (double)scene.StepCount * 100);
    }

    private async Task ToggleScene(DmxSceneDTO scene, bool isRunning)
    {
        if (ClientId == null)
        {
            return;
        }

        if (isRunning)
        {
            _sceneRunner.StopScene(scene.Id);

            return;
        }

        Result<bool> startResult = await _sceneRunner.StartSceneAsync(ClientId.Value, scene.Id);

        if (!startResult.IsSuccess)
        {
            _toastService.ShowError($"Failed to start scene '{scene.Name}': {startResult.Error}");
        }
    }

    private async Task StartMomentaryAsync(DmxSceneDTO scene, PointerEventArgs e)
    {
        // Button 0 is the left button. Without this, right-clicking fires the scene.
        if (ClientId == null || e.Button != 0)
        {
            return;
        }

        momentaryHeldSceneId = scene.Id;

        Result<bool> startResult = await _sceneRunner.StartSceneAsync(ClientId.Value, scene.Id);

        if (!startResult.IsSuccess)
        {
            momentaryHeldSceneId = null;

            _toastService.ShowError($"Failed to start scene '{scene.Name}': {startResult.Error}");
        }
    }

    private void StopMomentary(DmxSceneDTO scene)
    {
        // pointerup and pointerleave both fire on a normal release-then-exit, and stray
        // leaves are common — without this guard the second call would stop whatever
        // scene happened to be held next.
        if (momentaryHeldSceneId != scene.Id)
        {
            return;
        }

        momentaryHeldSceneId = null;

        _sceneRunner.StopScene(scene.Id);
    }

    public async Task CreateNewScene()
    {
        DialogResult result = await _dialogService.ShowDialogAsync<CreateNewDmxSceneDialog>(options =>
        {
            options.Modal = true;
        });

        if (!result.Cancelled && result.Value is string sceneName)
        {
            Result<DmxScene>? createResult = await _dmxSceneService.CreateSceneAsync(ClientId!.Value, sceneName);

            if (createResult.IsSuccess && createResult.Data != null)
            {
                _toastService.ShowSuccess($"Scene '{sceneName}' created successfully.");

                DmxScene created = createResult.Data;

                scenes.Add(new DmxSceneDTO
                {
                    Id = created.Id,
                    Name = created.Name,
                    ClientId = created.ClientId,
                    Loop = created.Loop,
                    IsMomentary = created.IsMomentary,
                    CreateByUserId = created.CreateByUserId,
                    CreateDate = created.CreateDate,
                    IsRunning = false,
                    StepCount = 0
                });

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                _toastService.ShowError($"Failed to create scene: {createResult.Error}");
            }
        }
    }

    public void Dispose()
    {
        _sceneRunner.OnSceneStarted -= HandleSceneStarted;
        _sceneRunner.OnSceneStopped -= HandleSceneStopped;
        _sceneRunner.OnSceneStepAdvanced -= HandleSceneStepAdvanced;
    }
}