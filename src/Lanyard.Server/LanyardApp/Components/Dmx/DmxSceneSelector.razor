@using Lanyard.Infrastructure.DTO.Dmx
@using Lanyard.Infrastructure.Models.Dmx

@inject IDmxSceneService _dmxSceneService
@inject IDialogService _dialogService
@inject IToastService _toastService

<div>
    <FluentCard Class="mt-2" Height="100%">
        <FluentStack HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center">
            <FluentText Size="TextSize.Size600"
                        Color="Color.Default">
                Scenes
            </FluentText>
            <FluentButton IconStart="new Icons.Regular.Size20.AddCircle()"
                        Appearance="ButtonAppearance.Primary"
                        Disabled="@(ClientId == null || !IsEditModeEnabled)"
                        OnClick="CreateNewScene"
                        Class="ms-2"> 
                        Add Scene
            </FluentButton>
        </FluentStack>
        <FluentDivider Class="my-3" />
        <FluentStack Orientation="Orientation.Horizontal" 
                        HorizontalAlignment="HorizontalAlignment.Left" 
                        Wrap="true"
                        Style="min-height: 50px;">
            @if (ClientId == null)
            {
                <FluentText Size="TextSize.Size400">Select a client to view scenes.</FluentText>
            }
            else if (scenes == null)
            {
                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Center">
                    Loading... <FluentSpinner Size="SpinnerSize.Tiny"></FluentSpinner>
                </FluentStack>
            }
            else if (!scenes.Any())
            {
                <FluentText Size="TextSize.Size400">No scenes found for this client.</FluentText>
            }
            else
            {
                @foreach (DmxScene scene in scenes)
                {
                    bool isRunning = runningSceneIds.Contains(scene.Id);
                    int progressValue = 0;

                    <FluentButton Appearance="@ButtonAppearance.Default"
                                    Padding="@Padding.All0"
                                    Disabled="@(!IsEditModeEnabled)"
                                    Class="@($"{(isRunning ? "scene-running" : "")} {(CurrentlyOpenScene != null && CurrentlyOpenScene.Id == scene.Id ? "scene-open" : "")}")"
                                    Style="width: 120px; height: 50px;"
                                    OnClick="@(() => OnOpenScene.InvokeAsync(scene))">
                        <FluentStack Orientation="Orientation.Vertical" 
                                        HorizontalAlignment="HorizontalAlignment.SpaceBetween" 
                                        VerticalAlignment="VerticalAlignment.Center"
                                        Padding="@Padding.All0">
                            <FluentText Padding="@Padding.All2">@scene.Name</FluentText>

                            @if (isRunning)
                            {
                                <FluentProgressBar Value="@progressValue"
                                                    Width="100%" />
                            }
                        </FluentStack>
                    </FluentButton>
                }
            }
        </FluentStack>
    </FluentCard>
</div>

@code {
    [Parameter]
    public Guid? ClientId { get; set; }

    [Parameter]
    public bool IsEditModeEnabled { get; set; } = false;

    [Parameter]
    public Guid? DeletedSceneId { get; set; }

    [Parameter]
    public EventCallback<DmxScene> OnOpenScene { get; set; }

    [Parameter]
    public DmxScene? CurrentlyOpenScene { get; set; }

    private List<DmxScene> scenes = [];

    private List<Guid> runningSceneIds = [];

    private Guid? previousClientId;

    private Guid? previousDeletedSceneId;

    protected override async Task OnParametersSetAsync()
    {
        if (ClientId != previousClientId)
        {
            previousClientId = ClientId;

            if (ClientId != null)
            {
                await LoadScenes(ClientId.Value);
            }
            else
            {
                scenes = [];
                runningSceneIds = [];
            }
        }

        if (DeletedSceneId != null && DeletedSceneId != previousDeletedSceneId)
        {
            previousDeletedSceneId = DeletedSceneId;

            scenes.RemoveAll(scene => scene.Id == DeletedSceneId.Value);
            runningSceneIds.Remove(DeletedSceneId.Value);
        }
    }

    private async Task LoadScenes(Guid clientId)
    {
        Result<IEnumerable<DmxSceneDTO>>? scenesResult = await _dmxSceneService.GetScenesForClientAsync(clientId);    

        if (scenesResult.IsSuccess && scenesResult.Data != null)
        {
            scenes = scenesResult.Data.Cast<DmxScene>().ToList();

            runningSceneIds = scenesResult.Data.Where(s => s.IsRunning).Select(s => s.Id).ToList();
        }
        else
        {
            _toastService.ShowError($"Failed to load scenes: {scenesResult.Error}");
        }
    }

    private void HandleSceneStarted(Guid clientId, Guid sceneId)
    {
        if (clientId != ClientId) {
            return;
        }

        runningSceneIds.Add(sceneId);

        InvokeAsync(StateHasChanged);
    }

    private void HandleSceneStopped(Guid clientId, Guid sceneId)
    {
        if (clientId != ClientId) {
            return;
        }

        runningSceneIds.Remove(sceneId);

        InvokeAsync(StateHasChanged);
    }

    public async Task CreateNewScene()
    {
        DialogResult result = await _dialogService.ShowDialogAsync<CreateNewDmxSceneDialog>(options =>
        {
            options.Modal = true;
        });

        if (!result.Cancelled && result.Value is string sceneName)
        {
            Result<DmxScene>? createResult = await _dmxSceneService.CreateSceneAsync(ClientId!.Value, sceneName);

            if (createResult.IsSuccess && createResult.Data != null)
            {
                _toastService.ShowSuccess($"Scene '{sceneName}' created successfully.");

                scenes.Add(createResult.Data);

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                _toastService.ShowError($"Failed to create scene: {createResult.Error}");
            }
        }
    }
}