@page "/manage/dashboards/{DashboardId:guid}"
@using Lanyard.App.Components.Dashboards
@using Lanyard.App.Components.Dialogs

<PageTitle>Edit Dashboard</PageTitle>

@inject IDashboardService DashboardService
@inject NavigationManager NavigationManager

@if (Dashboard != null)
{
    CardAppearance cardAppearance = IsPreviewing ? CardAppearance.Default : CardAppearance.Default;
    string padding = IsPreviewing ? Padding.All0 : Padding.All3;

    <FluentCard Appearance="cardAppearance" Padding="@padding">
        <FluentStack Orientation="@Orientation.Horizontal" VerticalAlignment="@VerticalAlignment.Center" HorizontalAlignment="@HorizontalAlignment.Start">
            @if (IsEditingDashboardName)
            {
                <EditForm Model="@Dashboard" OnValidSubmit="async () => IsEditingDashboardName = false">
                    <FluentTextInput Placeholder="Name" @bind-Value="Dashboard.Name" Required="true">
                        <StartTemplate>
                            <FluentIcon Value="new Icons.Regular.Size20.TextEditStyle()"/>
                        </StartTemplate>
                    </FluentTextInput>
                </EditForm>
            }
            else if (!IsPreviewing)
            {
                <FluentButton Appearance="@ButtonAppearance.Subtle" OnClick="() => IsEditingDashboardName = IsPreviewing ? false : true">
                    @Dashboard.Name
                </FluentButton>
            }
            else
            {
                <FluentText Padding="@Padding.Horizontal2">
                    @Dashboard.Name
                </FluentText>
            }

            @{
                Icon previewIcon = IsPreviewing ? new Icons.Filled.Size24.PreviewLink() : new Icons.Regular.Size24.PreviewLink();
            }

            <FluentButton Appearance="ButtonAppearance.Transparent" 
                            IconStart="new Icons.Regular.Size24.Save()"
                            Tooltip="Save Dashboard"
                            OnClick="SaveDashboardAsync">
            </FluentButton>

            <FluentButton Appearance="ButtonAppearance.Transparent" 
                            IconStart="previewIcon"
                            OnClick="() => IsPreviewing = !IsPreviewing"
                            Tooltip="Toggle Preview Dashboard">
            </FluentButton>

            <FluentButton Appearance="ButtonAppearance.Transparent" 
                            Id="DashboardWidgetList"
                            IconStart="new Icons.Regular.Size24.AddCircle()">
            </FluentButton>
            <FluentMenu Trigger="DashboardWidgetList">
                <FluentMenuList>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new DigitalClockWidget())">
                        Digital Clock
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new TextAreaWidget())">
                        Text Area
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new ClientZoneLaserGameStatusWidget())">
                        Laser Game Status
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new ClientZoneLaserScoreboardWidget())">
                        Laser Scoreboard
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new ButtonWidget())">
                        Button
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new MusicPlaylistSelectorWidget())">
                        Music Playlist Selector
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new MusicTimelineWidget())">
                        Music Timeline
                    </FluentMenuItem>
                    <FluentMenuItem OnClick="() => Dashboard.Widgets.Add(new AutomationRuleStatusWidget())">
                        Automation Rule Status
                    </FluentMenuItem>
                </FluentMenuList>
            </FluentMenu>

            <FluentButton Appearance="ButtonAppearance.Transparent" 
                            IconStart="new Icons.Regular.Size24.BinRecycle()"
                            OnClick="DeleteDashboardAsync"
                            Tooltip="Delete Dashboard">
            </FluentButton>
        </FluentStack>
    </FluentCard>

    <DashboardGrid Widgets="Dashboard.Widgets" PreviewMode="IsPreviewing"/>
}
else
{
    <FluentStack HorizontalAlignment="@HorizontalAlignment.Center" Padding="@Padding.All3">
        <FluentSpinner/>
    </FluentStack>
}

@code {
    [Parameter]
    public Guid DashboardId { get; set; } = Guid.Empty;

    public Dashboard? Dashboard { get; set; } = null;

    public bool IsPreviewing = true;

    public bool IsEditingDashboardName = false;

    protected override async Task OnInitializedAsync()
    {
        Result<Dashboard> result = await DashboardService.GetDashboardAsync(DashboardId);

        if (result.IsSuccess && result.Data != null)
        {
            Dashboard = result.Data;
        }
        else
        {
            _toastService.ShowError($"Failed to load the dashboard, {result.Error}");
        }
    }

    private async Task SaveDashboardAsync()
    {
        if (Dashboard == null)
        {
            return;
        }

        Result<bool> result = await DashboardService.SaveDashboardAsync(Dashboard);

        if (!result.IsSuccess)
        {
            _toastService.ShowError($"Failed to save the dashboard, {result.Error}");

            return;
        }

        IsEditingDashboardName = false;

        _toastService.ShowSuccess("Dashboard saved successfully.");
    }

    private async Task DeleteDashboardAsync()
    {
        if (Dashboard == null)
        {
            return;
        }

        DialogResult result = await _dialogService.ShowDialogAsync<ConfirmationDialog>(options =>
        {
            options.Header.Title = "Delete Dashboard";
            options.Width = "450px";
            options.Modal = true;
            options.Parameters.Add(nameof(ConfirmationDialog.Message), $"Are you sure you want to delete '{Dashboard.Name}'? This action cannot be undone.");
            options.Parameters.Add(nameof(ConfirmationDialog.ConfirmText), "Delete");
        });

        if (!result.Cancelled && result.Value is true)
        {
            Result<bool> deleteResult = await DashboardService.DeleteDashboardAsync(Dashboard.Id);
            
            if (deleteResult.IsSuccess)
            {
                _toastService.ShowSuccess($"Dashboard '{Dashboard.Name}' deleted successfully.");

                NavigationManager.NavigateTo("/manage/dashboards");
            }
            else
            {
                _toastService.ShowError($"Failed to delete dashboard '{Dashboard.Name}': {deleteResult.Error}");
            }
        }
    }
}