@page "/manage/projectiontemplates"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Lanyard.Application.Services

@inject IProjectionProgramService _projectionProgramService
@inject IToastService _toastService

<PageTitle>Projection Templates</PageTitle>

<FluentCard>
    <FluentMultiSplitter Height="100%">
        <FluentMultiSplitterPane Size="25%">
            <FluentStack Orientation="Orientation.Vertical" Height="100%">
                <FluentStack Orientation="Orientation.Horizontal" Class="w-100">
                    <FluentText Typo="Typography.PaneHeader">Projection Templates</FluentText>
                    <FluentButton Appearance="ButtonAppearance.Outline" IconStart="@(new Icons.Regular.Size20.FormNew())" OnClick="StartNewTemplate">
                        New Template
                    </FluentButton>
                </FluentStack>

                @if (isLoading)
                {
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" Class="my-4">
                        <FluentSpinner />
                    </FluentStack>
                }
                else
                {
                    <div class="w-100">
                        <FluentDataGrid ShowHover="true"
                                        Items="@templates.AsQueryable()"
                                        GridTemplateColumns="auto 1fr"
                                        Pagination="new PaginationState { ItemsPerPage = 10 }"
                                        Class="w-100">
                            <ChildContent>
                                <SelectColumn SelectAll="true"
                                            OnSelect="@(x => SelectTemplate(x.Item))"
                                            Property="@(x => selectedTemplate is not null && x.Id == selectedTemplate.Id)"
                                            TGridItem="ProjectionProgramStepTemplate"
                                            SelectMode="DataGridSelectMode.Single"
                                            SelectFromEntireRow="true"></SelectColumn>
                                <PropertyColumn Property="x => x.Name" Title="Template"></PropertyColumn>
                            </ChildContent>
                            <EmptyContent>
                                No templates found.
                            </EmptyContent>
                        </FluentDataGrid>
                    </div>
                }
            </FluentStack>
        </FluentMultiSplitterPane>

        <FluentMultiSplitterPane Size="65%" Class="px-2">
            @if (selectedTemplate is null)
            {
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" Height="100%">
                    <FluentText>Select a template or create a new one.</FluentText>
                </FluentStack>
            }
            else
            {
                <FluentStack Orientation="Orientation.Vertical" Class="pe-3 h-100 overflow-y-auto" Style="gap: 12px;">
                    <FluentStack Orientation="Orientation.Horizontal" Class="w-75">
                        <FluentText Typo="Typography.PaneHeader">
                            @(selectedTemplate.Id == Guid.Empty ? "New Template" : "Edit Template")
                        </FluentText>
                        <FluentButton
                                      Appearance="ButtonAppearance.Primary"
                                      IconStart="@(new Icons.Regular.Size20.Save())"
                                      Loading="@isSaving"
                                      OnClick="SaveTemplateAsync"
                                      Class="me-2">
                            Save Template
                        </FluentButton>
                        <FluentButton
                                      Appearance="ButtonAppearance.Outline"
                                      IconStart="@(new Icons.Regular.Size20.BinRecycle())"
                                      Disabled="@(isSaving || selectedTemplate.Id == Guid.Empty)"
                                      OnClick="DeleteSelectedTemplateAsync">
                            Delete Template
                        </FluentButton>
                    </FluentStack>

                    <FluentGrid Class="w-100">
                        <FluentGridItem Xs="6">
                            <FluentTextInput Class="w-100"
                                             @bind-Value="selectedTemplate.Name"
                                             Label="Template Name"
                                             Appearance="TextInputAppearance.Outline"
                                             Required="true" />
                        </FluentGridItem>
                        <FluentGridItem Xs="6">
                            <FluentTextArea Class="w-100"
                                            @bind-Value="selectedTemplate.Description"
                                            Label="Description"
                                            Appearance="TextAreaAppearance.Outline" />
                        </FluentGridItem>
                    </FluentGrid>

                    <FluentDivider class="my-3"></FluentDivider>

                    <FluentText Typo="Typography.PaneHeader">Parameters</FluentText>

                    @if (selectedTemplate.Parameters.Count == 0)
                    {
                        <FluentText>No parameters configured.</FluentText>
                    }
                    else
                    {
                        @foreach (ProjectionProgramStepTemplateParameter parameter in selectedTemplate.Parameters)
                        {
                            <FluentCard Appearance="CardAppearance.Subtle" Class="mb-2">
                                <FluentGrid Spacing="3">
                                    <FluentGridItem Xs="3">
                                        <FluentTextInput Class="w-100"
                                                         @bind-Value="parameter.Name"
                                                         Label="Name"
                                                         Appearance="TextInputAppearance.Outline"
                                                         Required="true" />
                                    </FluentGridItem>
                                    <FluentGridItem Xs="3">
                                        <FluentTextArea Class="w-100"
                                                        @bind-Value="parameter.Description"
                                                        Label="Description"
                                                        Appearance="TextAreaAppearance.Outline" />
                                    </FluentGridItem>
                                    <FluentGridItem Xs="3">
                                        <FluentSelect Class="w-100"
                                                      @bind-Value="parameter.DataType"
                                                      TOption="string"
                                                      TValue="string"
                                                      Label="Data Type">
                                            @foreach (string dataType in dataTypeOptions)
                                            {
                                                <FluentOption Value="@dataType">@dataType</FluentOption>
                                            }
                                        </FluentSelect>

                                        <FluentCheckbox Class="pt-2" @bind-Value="parameter.IsRequired">
                                            Required="true"
                                        </FluentCheckbox>
                                    </FluentGridItem>
                                    <FluentGridItem Xs="1" Class="d-flex align-items-start justify-content-end mt-4">
                                        <FluentButton Appearance="ButtonAppearance.Outline"
                                                      IconStart="@(new Icons.Regular.Size20.BinRecycle())"
                                                      OnClick="() => RemoveParameter(parameter.Id)">
                                            Remove
                                        </FluentButton>
                                    </FluentGridItem>
                                </FluentGrid>
                            </FluentCard>
                        }
                    }

                    <FluentCard Appearance="CardAppearance.Subtle" Height="auto" Class="mt-2">
                        <FluentGrid Spacing="3">
                            <FluentGridItem Xs="3">
                                <FluentTextInput Class="w-100"
                                                 @bind-Value="newParameter.Name"
                                                 Label="Name"
                                                 Appearance="TextInputAppearance.Outline" />
                            </FluentGridItem>
                            <FluentGridItem Xs="3">
                                <FluentTextArea Class="w-100"
                                                @bind-Value="newParameter.Description"
                                                Label="Description"
                                                Appearance="TextAreaAppearance.Outline" />
                            </FluentGridItem>
                            <FluentGridItem Xs="3">
                                <FluentSelect Class="w-100"
                                              @bind-Value="newParameter.DataType"
                                              TOption="string"
                                              TValue="string"
                                              Label="Data Type">
                                    @foreach (string dataType in dataTypeOptions)
                                    {
                                        <FluentOption Value="@dataType">@dataType</FluentOption>
                                    }
                                </FluentSelect>

                                <FluentCheckbox Class="pt-2" @bind-Value="newParameter.IsRequired">
                                    Required="true"
                                </FluentCheckbox>
                            </FluentGridItem>
                            <FluentGridItem Xs="1" Class="d-flex align-items-start justify-content-end mt-4">
                                <FluentButton Appearance="ButtonAppearance.Primary"
                                              IconStart="@(new Icons.Regular.Size20.FormNew())"
                                              OnClick="AddParameter">
                                    Add
                                </FluentButton>
                            </FluentGridItem>
                        </FluentGrid>
                    </FluentCard>
                </FluentStack>
            }
        </FluentMultiSplitterPane>
    </FluentMultiSplitter>
</FluentCard>

@code {
    private readonly string[] dataTypeOptions = ["String", "Integer", "Float", "Boolean", "DateTime", "File", "VideoFile", "Dashboard", "VideoDevice"];

    private List<ProjectionProgramStepTemplate> templates = [];
    private ProjectionProgramStepTemplate? selectedTemplate;
    private ProjectionProgramStepTemplateParameter newParameter = CreateEmptyParameter();
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadTemplatesAsync();
    }

    private async Task LoadTemplatesAsync()
    {
        isLoading = true;

        Result<IEnumerable<ProjectionProgramStepTemplate>> result = await _projectionProgramService.GetProjectionProgramStepTemplatesAsync();

        if (!result.IsSuccess || result.Data is null)
        {
            _toastService.ShowError($"Failed to load projection templates: {result.Error}");
            templates = [];
        }
        else
        {
            templates = result.Data.OrderBy(x => x.Name).ToList();
        }

        isLoading = false;
    }

    private void SelectTemplate(ProjectionProgramStepTemplate template)
    {
        selectedTemplate = CloneTemplate(template);
        newParameter = CreateEmptyParameter();
    }

    private void StartNewTemplate()
    {
        selectedTemplate = new ProjectionProgramStepTemplate
        {
            Id = Guid.Empty,
            Name = "New Template",
            Description = string.Empty,
            IsActive = true,
            Parameters = []
        };

        newParameter = CreateEmptyParameter();
    }

    private void AddParameter()
    {
        if (selectedTemplate is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(newParameter.Name))
        {
            _toastService.ShowWarning("Parameter name is required.");
            return;
        }

        if (string.IsNullOrWhiteSpace(newParameter.DataType))
        {
            _toastService.ShowWarning("Parameter data type is required.");
            return;
        }

        selectedTemplate.Parameters.Add(new ProjectionProgramStepTemplateParameter
        {
            Id = Guid.NewGuid(),
            TemplateId = selectedTemplate.Id,
            Name = newParameter.Name.Trim(),
            Description = newParameter.Description?.Trim(),
            DataType = newParameter.DataType.Trim(),
            IsRequired = newParameter.IsRequired,
            IsActive = true
        });

        newParameter = CreateEmptyParameter();
    }

    private void RemoveParameter(Guid parameterId)
    {
        if (selectedTemplate is null)
        {
            return;
        }

        ProjectionProgramStepTemplateParameter? parameter = selectedTemplate.Parameters.FirstOrDefault(x => x.Id == parameterId);

        if (parameter is not null)
        {
            selectedTemplate.Parameters.Remove(parameter);
        }
    }

    private async Task SaveTemplateAsync()
    {
        if (selectedTemplate is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedTemplate.Name))
        {
            _toastService.ShowWarning("Template name is required.");
            return;
        }

        isSaving = true;

        Result<ProjectionProgramStepTemplate> saveResult = await _projectionProgramService.SaveProjectionProgramStepTemplateAsync(selectedTemplate);

        if (!saveResult.IsSuccess || saveResult.Data is null)
        {
            _toastService.ShowError($"Failed to save projection template: {saveResult.Error}");
            isSaving = false;
            return;
        }

        _toastService.ShowSuccess("Projection template saved.");

        await LoadTemplatesAsync();

        ProjectionProgramStepTemplate? reloaded = templates.FirstOrDefault(x => x.Id == saveResult.Data.Id);
        selectedTemplate = reloaded is null ? CloneTemplate(saveResult.Data) : CloneTemplate(reloaded);
        newParameter = CreateEmptyParameter();
        isSaving = false;
    }

    private async Task DeleteSelectedTemplateAsync()
    {
        if (selectedTemplate is null || selectedTemplate.Id == Guid.Empty)
        {
            return;
        }

        Result<bool> deleteResult = await _projectionProgramService.DeleteProjectionProgramStepTemplateAsync(selectedTemplate.Id);

        if (!deleteResult.IsSuccess)
        {
            _toastService.ShowError($"Failed to delete projection template: {deleteResult.Error}");
            return;
        }

        _toastService.ShowSuccess("Projection template deleted.");

        await LoadTemplatesAsync();
        selectedTemplate = null;
    }

    private static ProjectionProgramStepTemplateParameter CreateEmptyParameter()
    {
        return new ProjectionProgramStepTemplateParameter
        {
            Id = Guid.NewGuid(),
            TemplateId = Guid.Empty,
            Name = string.Empty,
            Description = string.Empty,
            DataType = "String",
            IsRequired = false,
            IsActive = true
        };
    }

    private static ProjectionProgramStepTemplate CloneTemplate(ProjectionProgramStepTemplate template)
    {
        return new ProjectionProgramStepTemplate
        {
            Id = template.Id,
            Name = template.Name,
            Description = template.Description,
            IsActive = template.IsActive,
            Parameters = template.Parameters
                .Where(x => x.IsActive)
                .Select(x => new ProjectionProgramStepTemplateParameter
                {
                    Id = x.Id,
                    TemplateId = template.Id,
                    Name = x.Name,
                    Description = x.Description,
                    IsRequired = x.IsRequired,
                    DataType = x.DataType,
                    IsActive = x.IsActive
                })
                .ToList()
        };
    }
}
