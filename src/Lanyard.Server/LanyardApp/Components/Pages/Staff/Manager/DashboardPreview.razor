@page "/manage/dashboards/preview/{dashboardId:guid}"
@attribute [Authorize(Roles = "Admin,Manager")]

@using Microsoft.AspNetCore.Authorization
@using Lanyard.App.Components.Kiosk.Widgets

@inject IDashboardService _dashboardService
@inject IToastService _toastService

<PageTitle>Dashboard Preview</PageTitle>

<FluentStack Orientation="Orientation.Vertical" Style="height: calc(100vh - 120px); min-height: 680px;">
    <FluentStack Orientation="Orientation.Horizontal" Class="w-100">
        <FluentText Typo="Typography.PaneHeader">Dashboard Preview</FluentText>
        <FluentButton Appearance="ButtonAppearance.Outline" Href="//manage/dashboards">
            Back to Dashboards
        </FluentButton>
    </FluentStack>

    @if (isLoading)
    {
        <FluentStack HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" Height="100%">
            <FluentSpinner />
        </FluentStack>
    }
    else if (dashboard is null)
    {
        <FluentCard Class="w-100">
            <FluentText>Dashboard not found.</FluentText>
        </FluentCard>
    }
    else if (!dashboard.Widgets.Any(x => x.IsActive))
    {
        <FluentCard Class="w-100">
            <FluentText>This dashboard has no active widgets.</FluentText>
        </FluentCard>
    }
    else
    {
        <div class="kiosk-dashboard-grid">
            @foreach (DashboardWidget widget in dashboard.Widgets.Where(x => x.IsActive).OrderBy(x => x.SortOrder))
            {
                <div class="kiosk-dashboard-widget-slot" style="@GetWidgetStyle(widget)">
                    <KioskDashboardWidgetHost Widget="widget" />
                </div>
            }
        </div>
    }
</FluentStack>

@code {
    [Parameter]
    public Guid dashboardId { get; set; }

    private Dashboard? dashboard;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        Result<Dashboard> result = await _dashboardService.GetDashboardForRenderAsync(dashboardId);

        if (!result.IsSuccess || result.Data is null)
        {
            dashboard = null;
            _toastService.ShowError($"Failed to load dashboard preview: {result.Error}");
            isLoading = false;
            return;
        }

        dashboard = result.Data;
        isLoading = false;
    }

    private static string GetWidgetStyle(DashboardWidget widget)
    {
        int gridColumnStart = widget.GridX + 1;
        int gridRowStart = widget.GridY + 1;

        return $"grid-column: {gridColumnStart} / span {Math.Max(1, widget.GridW)}; grid-row: {gridRowStart} / span {Math.Max(1, widget.GridH)};";
    }
}
