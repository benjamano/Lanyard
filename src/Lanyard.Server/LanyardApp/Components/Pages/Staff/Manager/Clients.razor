@page "/manage/clients"
@attribute [Authorize(Roles = "Admin")]

@using Lanyard.App.Components.Dmx
@using Microsoft.AspNetCore.Authorization
@using Lanyard.App.Components.Manager

@inject IClientService _clientService
@inject IToastService _toastService

<PageTitle>Clients</PageTitle>

<FluentCard Height="auto">
    <FluentText Typo="Typography.PaneHeader">
        Clients
    </FluentText>
    <FluentDataGrid ShowHover="true" Items="@clients.OrderBy(x => x.Name).AsQueryable()" GridTemplateColumns="2fr 2fr 1fr 1fr 1fr 1fr 1fr" Style="width: 100%;">
        <ChildContent>
            <PropertyColumn Property="x => x.Id" Title="Client ID"/>
            <TemplateColumn Sortable="true" Title="Name">
                @context.Name
                <FluentIcon OnClick="@(async () => await ShowUpdateClientNameDialog(context.Id))" Icon="Icons.Regular.Size20.Edit"
                            Class="ms-1" role="button"></FluentIcon>
            </TemplateColumn>
            <PropertyColumn Property="x => x.MostRecentIpAddress" Title="IP Address"/>
            <PropertyColumn IsDefaultSortColumn="true" InitialSortDirection="DataGridSortDirection.Descending" Sortable="true"
                            Property="x => x.LastLogin" Title="Last Login" />
            <TemplateColumn Title="Capabilities">
                @if (context.ProjectionEnabled)
                {
                    <FluentBadge Appearance="BadgeAppearance.Filled" Class="me-1">Projection</FluentBadge>
                }

                @if (context.DmxEnabled)
                {
                    <FluentBadge Appearance="BadgeAppearance.Filled" Class="me-1">DMX</FluentBadge>
                }

                <FluentIcon OnClick="() => OpenUpdateClientCapabilitiesCard(context.Id)"
                            Icon="Icons.Regular.Size20.Edit" Class="ms-1" role="button"></FluentIcon>
            </TemplateColumn>
            <PropertyColumn Sortable="true" Property="x => x.IsCurrentlyConnected" Title="Currently Connected" />
            <TemplateColumn Title="Session Length">
                @if (context.IsCurrentlyConnected)
                {
                    <span>
                        @(((TimeSpan)(now - context.LastLogin)!).ToString(@"hh\:mm\:ss"))s
                    </span>
                }
                else
                {
                    <span>--:--:--</span>
                }
            </TemplateColumn>
        </ChildContent>
        <LoadingContent>
            Loading...
        </LoadingContent>
    </FluentDataGrid>
</FluentCard>

<FluentDivider Class="my-2"></FluentDivider>

<FluentGrid Spacing="2">
    <FluentGridItem Xs="12" Sm="12" Md="6">
        <ClientProjectionCapabilities 
            UpdateClientCapabilities="GetClientsAsync" 
            IsShowing="@showClientCapabilitiesCard"
            clientId="@updatingClientId">
        </ClientProjectionCapabilities>
    </FluentGridItem>

    <FluentGridItem Xs="12" Sm="12" Md="6">
        <ClientMusicCapabilities 
            IsShowing="@showClientCapabilitiesCard"
            clientId="@updatingClientId">
        </ClientMusicCapabilities>
    </FluentGridItem>

    <FluentGridItem Xs="12" Sm="12" Md="6">
        <ClientDmxConfig ClientId="@updatingClientId" />
    </FluentGridItem>
</FluentGrid>

<FluentDialog @ref="updateClientNameDialog" Modal="true">
    <FluentDialogBody>
        <TitleTemplate>
            <FluentStack VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.Pen())" />
                <FluentText Typo="Typography.PaneHeader">Update Client Name</FluentText>
            </FluentStack>
        </TitleTemplate>
        <ChildContent>
            <EditForm Model="updateClientModel" OnValidSubmit="SaveNewClientName">
                <FluentTextInput @bind-Value="updateClientModel.Name" class="w-100" Label="New Client Name"
                                 Placeholder="Enter new client name..." />
                <FluentStack Orientation="Orientation.Horizontal" Class="mt-2">
                    <FluentButton OnClick="CloseUpdateClientNameDialog">Close</FluentButton>
                    <FluentButton Appearance="ButtonAppearance.Primary" Type="ButtonType.Submit"
                                  IconStart="@(new Icons.Regular.Size20.Save())">Save</FluentButton>
                </FluentStack>
            </EditForm>
        </ChildContent>
    </FluentDialogBody>
</FluentDialog>

@code {
    private bool showClientCapabilitiesCard = false;

    private FluentDialog? updateClientNameDialog;
    private UpdateClientModel updateClientModel = new();

    private Guid? updatingClientId = null;

    private class UpdateClientModel
    {
        public string Name { get; set; } = string.Empty;
    }

    private IEnumerable<ClientConnectedWithCapabilitiesDTO> clients = Array.Empty<ClientConnectedWithCapabilitiesDTO>();

    private PeriodicTimer? timer;
    private DateTime now;

    protected override async Task OnInitializedAsync()
    {
        await GetClientsAsync();

        now = DateTime.UtcNow;

        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _ = Task.Run(async () =>
        {
            while (await timer.WaitForNextTickAsync())
            {
                now = DateTime.UtcNow;
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    public void Dispose()
    {
        timer?.Dispose();
    }

    private async Task ShowUpdateClientNameDialog(Guid clientId)
    {
        updatingClientId = clientId;
        updateClientModel.Name = clients.FirstOrDefault(x => x.Id == clientId)?.Name ?? string.Empty;
        await updateClientNameDialog!.ShowAsync();
    }

    private async Task CloseUpdateClientNameDialog()
    {
        updatingClientId = null;
        await updateClientNameDialog!.HideAsync();
    }

    private async Task GetClientsAsync()
    {
        Result<IEnumerable<ClientConnectedWithCapabilitiesDTO>> result = await _clientService.GetClientsWithCapabilitiesAsync();

        if (result.IsSuccess)
        {
            clients = result.Data!;
        }
        else
        {
            _toastService.ShowError($"Failed to load connected clients, {result.Error}");
        }
    }

    private async Task SaveNewClientName()
    {
        if (updatingClientId == null) return;

        Result<Client?> getResult = await _clientService.GetClientFromIdAsync(updatingClientId ?? Guid.Empty);

        if (!getResult.IsSuccess || getResult.Data == null)
        {
            _toastService.ShowError($"An error occured when updating the name of this client, {getResult.Error}");
        }

        Client client = getResult.Data!;

        client.Name = updateClientModel.Name;

        Result<Client?> updateResult = await _clientService.UpdateClientAsync(client);

        if (updateResult.IsSuccess)
        {
            _toastService.ShowSuccess("Name updated!");
        }
        else
        {
            _toastService.ShowError($"An error occured when updating the name of this client, {updateResult.Error}");
        }

        await GetClientsAsync();

        await updateClientNameDialog!.HideAsync();
    }

    private void OpenUpdateClientCapabilitiesCard(Guid clientId)
    {
        updatingClientId = clientId;
        showClientCapabilitiesCard = true;
    }
}