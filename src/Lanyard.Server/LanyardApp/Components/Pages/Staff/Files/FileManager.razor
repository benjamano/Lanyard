@page "/files"
@using Lanyard.Infrastructure.Models
@using Lanyard.Infrastructure.DTO
@using Lanyard.App.Components.Files
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>File Manager</PageTitle>

<FluentCard>
    <FluentGrid class="h-100 w-100">
        <FluentGridItem Xs="1">
            <FolderTree SelectedFolderId="selectedFolderId" SelectedFolderIdChanged="OnFolderChanged" />
        </FluentGridItem>
        <FluentGridItem Xs="11" class="w-100">
            <AuthorizeView>
                <FileUploader SelectedFolderId="selectedFolderId" OnFileUploaded="OnFileUploaded" />
            </AuthorizeView>
            <FileList @ref="fileList" FolderId="selectedFolderId" OnFileDeleted="OnFileDeleted" OnFileRenamed="OnFileRenamed" />
        </FluentGridItem>
    </FluentGrid>
</FluentCard>

@code {
    private Guid? selectedFolderId;

    private FileList? fileList;

    private void OnFolderChanged(Guid? folderId)
    {
        // Changing the parameter re-triggers FileList.OnParametersSetAsync, which reloads.
        selectedFolderId = folderId;
        StateHasChanged();
    }

    private async Task OnFileUploaded(FileMetadata file)
    {
        if (fileList is not null)
            await fileList.RefreshAsync();
    }

    private async Task OnFileDeleted(Guid fileId)
    {
        if (fileList is not null)
            await fileList.RefreshAsync();
    }

    private async Task OnFileRenamed(FileMetadata file)
    {
        if (fileList is not null)
            await fileList.RefreshAsync();
    }
}
