@page "/music"

@attribute [Authorize]

@using Lanyard.App.Components.Music
@using Lanyard.Application.Services
@using Lanyard.Application.Services.Authentication
@using Lanyard.Infrastructure.DTO
@using Lanyard.Infrastructure.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using NAudio.Wave;

@inject MusicPlayerService _player
@inject IClientService _clientService
@inject IToastService _toastService
@inject IJSRuntime JS

@implements IDisposable

<PageTitle>Music</PageTitle>

<div class="music-page">
    <div class="music-content p-2">
        <div class="music-panes">
            <div class="music-pane music-playlists-pane">
                <Playlists OnSongsSelected="HandleSongsSelected" SelectedClientId="selectedClientId"></Playlists>
            </div>

            <div class="w-100">
                <SongList Songs="currentSongs" SelectedClientId="selectedClientId" AllowPlaying="allowPlaying"></SongList>
            </div>
        </div>
    </div>

    <div class="music-bottom-controls">
        <FluentStack Orientation="Orientation.Horizontal"
                     VerticalAlignment="VerticalAlignment.Center"
                     HorizontalGap="12"
                     Class="music-bottom-controls-stack">

            <div style="flex: 1;">
            <FluentGrid Style="width: 200px;">
                <FluentGridItem xs="12">
                    <FluentStack Orientation="Orientation.Horizontal"
                                VerticalAlignment="VerticalAlignment.Center"
                                HorizontalGap="8"
                                Width="auto">
                        @{
                            Icon volumeIcon = currentVolume switch
                            {
                                0 => new Icons.Regular.Size24.SpeakerMute(),
                                > 0 and <= 30 => new Icons.Regular.Size24.Speaker0(),
                                > 30 and <= 69 => new Icons.Regular.Size24.Speaker1(),
                                > 69 => new Icons.Regular.Size24.Speaker2(),
                                _ => new Icons.Regular.Size24.SpeakerMute()
                            };
                        }

                        <FluentButton IconStart="volumeIcon" Appearance="Appearance.Lightweight" Disabled="@(selectedClientId == null)" OnClick="MuteVolume"></FluentButton>
                        <FluentSlider Disabled="@(selectedClientId == null)" Min="0" Max="100" Step="1" TValue="int" @onchange="HandleVolumeChange" @bind-Value="currentVolume" Orientation="Orientation.Horizontal" Class="w-100 mt-3"></FluentSlider>
                    </FluentStack>
                </FluentGridItem>
            </FluentGrid>
            </div>

            <FluentStack Orientation="Orientation.Horizontal"
                        VerticalAlignment="VerticalAlignment.Center"
                        HorizontalGap="8"
                        Width="auto">

                @{
                    Icon shuffleIcon = isShuffleEnabled ? new Icons.Regular.Size24.ArrowShuffle() : new Icons.Regular.Size24.ArrowShuffleOff();
                }

                <FluentButton Appearance="Appearance.Stealth"
                            Title="Shuffle"
                            OnClick='ToggleShuffle'
                            Disabled="@(selectedClientId == null)"
                            IconStart="shuffleIcon">
                </FluentButton>

                <FluentButton Appearance="Appearance.Outline"
                            Title="Previous (Double-click) / Restart (Single-click)"
                            OnClick="RestartSong"
                            @ondblclick="PreviousSong"
                            Disabled="@(selectedClientId == null)"
                            Style="border-radius: 50%; width: 40px; height: 40px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Previous())" />
                </FluentButton>

                <FluentButton Appearance="Appearance.Accent"
                            Title="@(isPlaying ? "Pause" : "Play")"
                            OnClick="TogglePlay"
                            Disabled="@(selectedClientId == null)"
                            Style="border-radius: 50%; width: 40px; height: 40px;">
                    @if (isPlaying)
                    {
                        <FluentIcon Color="Color.Fill" Icon="Icons.Regular.Size20.Pause" />
                    }
                    else
                    {
                        <FluentIcon Color="Color.Fill" Icon="Icons.Regular.Size20.Play" />
                    }
                </FluentButton>

                <FluentButton Appearance="Appearance.Outline"
                            Title="Next"
                            OnClick="NextSong"
                            Disabled="@(selectedClientId == null)"
                            Style="border-radius: 50%; width: 40px; height: 40px;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Next())" />
                </FluentButton>

                @{
                    Icon repeatIcon = isRepeatEnabled ? new Icons.Regular.Size20.ArrowRepeatAll() : new Icons.Regular.Size20.ArrowRepeatAllOff();
                }

                <FluentButton Appearance="Appearance.Stealth"
                            Title="Repeat"
                            OnClick="ToggleRepeat"
                            Disabled="@(selectedClientId == null)"
                            IconStart="repeatIcon">
                </FluentButton>
            </FluentStack>

            <div style="flex: 1; display: flex; justify-content: flex-end;">
            <FluentStack Orientation="Orientation.Horizontal"
                         VerticalAlignment="VerticalAlignment.Center"
                         HorizontalGap="8"
                         Class="music-client-controls"
                         Width="auto">
                <FluentSelect @bind-Value="selectedClientIdString"
                              TOption="string"
                              Class="music-client-select"
                              Disabled="@(!(clients.Count > 1))">
                    @if (!clients.Any())
                    {
                        <FluentOption Value="">No connected clients</FluentOption>
                    }
                    else
                    {
                        @foreach (ClientConnectedWithCapabilitiesDTO client in clients)
                        {
                            <FluentOption Value="@client.Id.ToString()">@client.Name</FluentOption>
                        }
                    }
                </FluentSelect>

                <FluentButton Appearance="Appearance.Outline" OnClick="RefreshClientsAsync">
                    Refresh
                </FluentButton>
            </FluentStack>
            </div>
        </FluentStack>
    </div>
</div>

@code {
    private const string StorageSelectedClientKey = "staff.music.selectedClientId";

    private IEnumerable<PlaylistSongMember>? currentSongs;
    private bool isPlaying = false;
    private List<ClientConnectedWithCapabilitiesDTO> clients = [];
    private Guid? selectedClientId;
    private bool firstRenderCompleted;

    private bool allowPlaying = true;
    private int currentVolume = 0;
    private bool isShuffleEnabled = false;
    private bool isRepeatEnabled = false;

    private string selectedClientIdString
    {
        get => selectedClientId?.ToString() ?? string.Empty;
        set
        {
            if (Guid.TryParse(value, out Guid clientId))
            {
                SetSelectedClient(clientId);
                _ = PersistSelectedClientIdAsync(clientId);
            }
            else
            {
                SetSelectedClient(null);
                _ = ClearPersistedSelectedClientIdAsync();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _player.OnPlaybackStatusChanged += HandlePlaybackStateChanged;
        await LoadConnectedClientsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || firstRenderCompleted)
        {
            return;
        }

        firstRenderCompleted = true;

        Guid? restoredClientId = await GetPersistedSelectedClientIdAsync();

        if (restoredClientId.HasValue && clients.Any(x => x.Id == restoredClientId.Value))
        {
            SetSelectedClient(restoredClientId.Value);
        }
        else if (selectedClientId == null && clients.Any())
        {
            SetSelectedClient(clients[0].Id);
            await PersistSelectedClientIdAsync(clients[0].Id);
        }
        else if (!clients.Any())
        {
            await ClearPersistedSelectedClientIdAsync();
        }
    }

    private void HandlePlaybackStateChanged(Guid clientId, PlaybackState state)
    {
        if (selectedClientId != clientId)
        {
            return;
        }

        isPlaying = state == PlaybackState.Playing;
        InvokeAsync(StateHasChanged);
    }

    private async Task RefreshClientsAsync()
    {
        Guid? previousSelectedClientId = selectedClientId;

        await LoadConnectedClientsAsync();

        if (!clients.Any())
        {
            SetSelectedClient(null);
            await ClearPersistedSelectedClientIdAsync();
            return;
        }

        if (previousSelectedClientId.HasValue && !clients.Any(x => x.Id == previousSelectedClientId.Value))
        {
            SetSelectedClient(null);
            _toastService.ShowWarning("Selected client disconnected. Please select another client.");
            await ClearPersistedSelectedClientIdAsync();
            return;
        }

        if (selectedClientId == null || !clients.Any(x => x.Id == selectedClientId.Value))
        {
            Guid? restoredClientId = await GetPersistedSelectedClientIdAsync();
            Guid selectedId = restoredClientId.HasValue && clients.Any(x => x.Id == restoredClientId.Value)
                ? restoredClientId.Value
                : clients[0].Id;

            SetSelectedClient(selectedId);
            await PersistSelectedClientIdAsync(selectedId);
        }
    }

    private async Task LoadConnectedClientsAsync()
    {
        Result<IEnumerable<ClientConnectedWithCapabilitiesDTO>> result = await _clientService.GetClientsWithCapabilitiesAsync();

        if (!result.IsSuccess || result.Data == null)
        {
            _toastService.ShowError($"Failed to load clients: {result.Error}");
            clients = [];
            SetSelectedClient(null);
            return;
        }

        clients = result.Data
            .Where(x => x.IsCurrentlyConnected)
            .OrderBy(x => x.Name)
            .ToList();
    }

    private void SetSelectedClient(Guid? clientId)
    {
        selectedClientId = clientId;

        isPlaying = clientId.HasValue ? _player.GetCurrentPlaybackState(clientId.Value) == PlaybackState.Playing : false;
        currentVolume = clientId.HasValue ? _player.GetCurrentVolume(clientId.Value) : 0;
        isShuffleEnabled = clientId.HasValue ? _player.GetCurrentShuffleState(clientId.Value) : false;
        isRepeatEnabled = clientId.HasValue ? _player.GetCurrentRepeatState(clientId.Value) : false;

        InvokeAsync(StateHasChanged);
    }

    private async Task<Guid?> GetPersistedSelectedClientIdAsync()
    {
        try
        {
            string? value = await JS.InvokeAsync<string?>("localStorage.getItem", StorageSelectedClientKey);
            return Guid.TryParse(value, out Guid clientId) ? clientId : null;
        }
        catch (JSException)
        {
            return null;
        }
    }

    private async Task PersistSelectedClientIdAsync(Guid clientId)
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageSelectedClientKey, clientId.ToString());
        }
        catch (JSException)
        {
        }
    }

    private async Task ClearPersistedSelectedClientIdAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", StorageSelectedClientKey);
        }
        catch (JSException)
        {
        }
    }

    private async Task TogglePlay()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.TogglePlay(selectedClientId.Value);
    }

    private async Task RestartSong()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.Restart(selectedClientId.Value);
    }

    private async Task PreviousSong()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.Previous(selectedClientId.Value);
    }

    private async Task NextSong()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.Next(selectedClientId.Value);
    }

    private void HandleSongsSelected((IEnumerable<PlaylistSongMember> Songs, bool IsLocalSongs) args)
    {
        currentSongs = args.Songs;
        allowPlaying = !args.IsLocalSongs;
        StateHasChanged();
    }

    private async Task HandleVolumeChange(ChangeEventArgs e)
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        if (int.TryParse(e.Value?.ToString(), out int newVolume))
        {
            currentVolume = newVolume;
            await _player.SetVolume(selectedClientId.Value, newVolume);
        }
    }
    
    private async Task MuteVolume()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        currentVolume = 0;

        await _player.SetVolume(selectedClientId.Value, 0);
    }

    private async Task ToggleShuffle()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        isShuffleEnabled = await _player.ToggleShuffle(selectedClientId.Value);
    }

    private async Task ToggleRepeat()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        isRepeatEnabled = await _player.ToggleRepeat(selectedClientId.Value);
    }

    public void Dispose()
    {
        _player.OnPlaybackStatusChanged -= HandlePlaybackStateChanged;
    }
}
