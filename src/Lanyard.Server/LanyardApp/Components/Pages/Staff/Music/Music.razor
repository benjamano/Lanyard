@page "/music"

@attribute [Authorize]

@using Lanyard.App.Components.Clients
@using Lanyard.App.Components.Music
@using Lanyard.Application.Services
@using Lanyard.Application.Services.Authentication
@using Lanyard.Infrastructure.DTO
@using Lanyard.Infrastructure.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using NAudio.Wave;

@inject MusicPlayerService _player
@inject IClientService _clientService
@inject IToastService _toastService
@inject IPlaylistService _playlistService
@inject IJSRuntime JS

@implements IDisposable

<PageTitle>Music</PageTitle>

<div class="music-page">
    <div class="music-content">
        <div class="music-panes">
            <div class="music-pane music-playlists-pane">
                <Playlists OnSongsSelected="HandleSongsSelected" SelectedClientId="selectedClientId" InitialPlaylistId="initialPlaylistId"></Playlists>
            </div>

            <div class="w-100">
                <SongList Songs="currentSongs" SelectedClientId="selectedClientId" AllowPlaying="allowPlaying"></SongList>
            </div>
        </div>
    </div>

    <FluentCard class="music-bottom-controls" Appearance="CardAppearance.Filled" Margin="@Margin.Top3">
        <FluentStack Orientation="Orientation.Horizontal"
                     VerticalAlignment="VerticalAlignment.Center"
                     HorizontalGap="12"
                     Class="music-bottom-controls-stack">

            <div style="flex: 1;">
                <FluentGrid Style="width: 200px;">
                    <FluentGridItem Xs="12">
                        <FluentStack Orientation="Orientation.Horizontal"
                                    VerticalAlignment="VerticalAlignment.Center"
                                    HorizontalGap="8"
                                    Width="auto">
                            @{
                                Icon volumeIcon = currentVolume switch
                                {
                                    0 => new Icons.Regular.Size24.SpeakerMute(),
                                    > 0 and <= 20 => new Icons.Regular.Size24.Speaker0(),
                                    > 20 and <= 70 => new Icons.Regular.Size24.Speaker1(),
                                    > 70 => new Icons.Regular.Size24.Speaker2(),
                                    _ => new Icons.Regular.Size24.SpeakerMute()
                                };
                            }

                            <FluentButton IconStart="volumeIcon" Appearance="ButtonAppearance.Subtle" Disabled="@(selectedClientId == null)" OnClick="ToggleMuteVolume"></FluentButton>
                            <FluentSlider Disabled="@(selectedClientId == null)" Min="0" Max="100" Step="1" TValue="int" Value="currentVolume" ValueChanged="(volume) => HandleVolumeChange(volume)" Orientation="Orientation.Horizontal" Class="w-100 mt-3"></FluentSlider>
                        </FluentStack>
                    </FluentGridItem>
                </FluentGrid>
            </div>

            <FluentStack Orientation="Orientation.Vertical" Width="auto" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center">
                <FluentStack Orientation="Orientation.Horizontal"
                            VerticalAlignment="VerticalAlignment.Center"
                            HorizontalGap="8"
                            Width="auto">

                    @{
                        Icon shuffleIcon = isShuffleEnabled ? new Icons.Regular.Size24.ArrowShuffle() : new Icons.Regular.Size24.ArrowShuffleOff();
                    }

                    <FluentButton Appearance="ButtonAppearance.Subtle"
                                Title="Shuffle"
                                OnClick='ToggleShuffle'
                                Disabled="@(selectedClientId == null)"
                                IconStart="shuffleIcon">
                    </FluentButton>

                    <FluentButton Appearance="ButtonAppearance.Outline"
                                Title="Previous (Double-click) / Restart (Single-click)"
                                OnClick="RestartSong"
                                @ondblclick="PreviousSong"
                                Disabled="@(selectedClientId == null)"
                                Style="border-radius: 50%;"
                                IconStart="@(new Icons.Regular.Size32.Previous())">
                    </FluentButton>

                    @{
                        Icon playIcon = isPlaying ? new Icons.Regular.Size32.Pause() : new Icons.Regular.Size32.Play();
                    }

                    <FluentButton Appearance="ButtonAppearance.Primary"
                                Title="@(isPlaying ? "Pause" : "Play")"
                                OnClick="TogglePlay"
                                Disabled="@(selectedClientId == null)"
                                Style="border-radius: 50%;"
                                IconStart="playIcon">
                    </FluentButton>

                    <FluentButton Appearance="ButtonAppearance.Outline"
                                Title="Next"
                                OnClick="NextSong"
                                Disabled="@(selectedClientId == null)"
                                Style="border-radius: 50%;"
                                IconStart="@(new Icons.Regular.Size32.Next())">
                    </FluentButton>

                    @{
                        Icon repeatIcon = isRepeatEnabled ? new Icons.Regular.Size20.ArrowRepeatAll() : new Icons.Regular.Size20.ArrowRepeatAllOff();
                    }

                    <FluentButton Appearance="ButtonAppearance.Subtle"
                                Title="Repeat"
                                OnClick="ToggleRepeat"
                                Disabled="@(selectedClientId == null)"
                                IconStart="repeatIcon">
                    </FluentButton>
                </FluentStack>

                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                    <div @onclick="() => showTimeLeftInsteadOfElapsed = !showTimeLeftInsteadOfElapsed" role="button">
                        @if (showTimeLeftInsteadOfElapsed)
                        {
                            <FluentText Color="Color.Info">-@TimeSpan.FromSeconds(currentSongLength - currentSongTime).ToString(@"mm\:ss")</FluentText>
                        }
                        else
                        {
                            <FluentText Color="Color.Info">@TimeSpan.FromSeconds(currentSongTime).ToString(@"mm\:ss")</FluentText>
                        }
                    </div>
                    <FluentSlider Style="Width: 750px;" Value="currentSongTime" Min="0" Max="@(currentSongLength != 0 ? currentSongLength : 1)" Step="1" TValue="double" Orientation="Orientation.Horizontal" Disabled="@(selectedClientId == null || currentSongLength == 0)" ValueChanged="(double newValue) => OnSongTimeChanged(newValue)" Class="mt-3"></FluentSlider>
                    <FluentText Color="Color.Info">@TimeSpan.FromSeconds(currentSongLength).ToString(@"mm\:ss")</FluentText>
                </FluentStack>
            </FluentStack>

            <ClientSelector OnClientSelected="SetSelectedClient" />
        </FluentStack>
    </FluentCard>
</div>

@code {
    private const string StorageSelectedClientKey = "staff.music.selectedClientId";

    private IEnumerable<PlaylistSongMember>? currentSongs;
    private bool isPlaying = false;
    private List<ClientConnectedWithCapabilitiesDTO> clients = [];
    private Guid? selectedClientId;
    private bool firstRenderCompleted;

    private bool allowPlaying = true;
    private int currentVolume = 0;
    private bool isShuffleEnabled = false;
    private bool isRepeatEnabled = false;
    private float currentSongTime = 0.0f;
    private int currentSongLength = 0;
    private Timer? songTimeTimer;
    private bool showTimeLeftInsteadOfElapsed = false;

    private Guid? initialPlaylistId;

    private string selectedClientIdString
    {
        get => selectedClientId?.ToString() ?? string.Empty;
        set
        {
            if (Guid.TryParse(value, out Guid clientId))
            {
                SetSelectedClient(clientId);
                _ = PersistSelectedClientIdAsync(clientId);
            }
            else
            {
                SetSelectedClient(null);
                _ = ClearPersistedSelectedClientIdAsync();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _player.OnPlaybackStatusChanged += HandlePlaybackStateChanged;
        _player.OnShuffleStateChanged += HandleShuffleStateChanged;

        await LoadConnectedClientsAsync();

        await LoadFirstPlaylistAsync();
    }

    private async Task LoadFirstPlaylistAsync()
    {
        Result<IEnumerable<Playlist>> playlistsResult = await _playlistService.GetActivePlaylistsAsync();

        if (!playlistsResult.IsSuccess || playlistsResult.Data == null)
        {
            _toastService.ShowError($"Failed to load playlists: {playlistsResult.Error}");
            return;
        }

        Playlist? firstPlaylist = playlistsResult.Data.FirstOrDefault();

        if (firstPlaylist != null)
        {
            currentSongs = firstPlaylist.Members?.Select(x=> new PlaylistSongMember
            {
                SongId = x.SongId,
                Song = x.Song,
                PlaylistId = firstPlaylist.Id,
                Playlist = firstPlaylist
            })
            .OrderByDescending(x=> x.Song?.CreateDate)
            .ToList();

            initialPlaylistId = firstPlaylist.Id;

            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || firstRenderCompleted)
        {
            return;
        }

        firstRenderCompleted = true;

        Guid? restoredClientId = await GetPersistedSelectedClientIdAsync();

        if (restoredClientId.HasValue && clients.Any(x => x.Id == restoredClientId.Value))
        {
            SetSelectedClient(restoredClientId.Value);
        }
        else if (selectedClientId == null && clients.Any())
        {
            SetSelectedClient(clients[0].Id);
            await PersistSelectedClientIdAsync(clients[0].Id);
        }
        else if (!clients.Any())
        {
            await ClearPersistedSelectedClientIdAsync();
        }
    }

    private void HandlePlaybackStateChanged(Guid clientId, PlaybackState state)
    {
        if (selectedClientId != clientId)
        {
            return;
        }

        isPlaying = state == PlaybackState.Playing;

        currentSongTime = selectedClientId.HasValue ? _player.GetCurrentSongTime(selectedClientId.Value) : 0;
        currentSongLength = selectedClientId.HasValue ? _player.GetCurrentSongLength(selectedClientId.Value) : 0;

        if (isPlaying)
        {
            startSongTimeTimer();
        }
        else
        {
            stopSongTimeTimer();
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleShuffleStateChanged(Guid clientId, bool isEnabled)
    {
        if (selectedClientId != clientId)
        {
            return;
        }

        isShuffleEnabled = isEnabled;

        InvokeAsync(StateHasChanged);
    }

    private async Task RefreshClientsAsync()
    {
        Guid? previousSelectedClientId = selectedClientId;

        await LoadConnectedClientsAsync();

        if (!clients.Any())
        {
            SetSelectedClient(null);
            await ClearPersistedSelectedClientIdAsync();
            return;
        }

        if (previousSelectedClientId.HasValue && !clients.Any(x => x.Id == previousSelectedClientId.Value))
        {
            SetSelectedClient(null);
            _toastService.ShowWarning("Selected client disconnected. Please select another client.");
            await ClearPersistedSelectedClientIdAsync();
            return;
        }

        if (selectedClientId == null || !clients.Any(x => x.Id == selectedClientId.Value))
        {
            Guid? restoredClientId = await GetPersistedSelectedClientIdAsync();
            Guid selectedId = restoredClientId.HasValue && clients.Any(x => x.Id == restoredClientId.Value)
                ? restoredClientId.Value
                : clients[0].Id;

            SetSelectedClient(selectedId);
            await PersistSelectedClientIdAsync(selectedId);
        }
    }

    private async Task LoadConnectedClientsAsync()
    {
        Result<IEnumerable<ClientConnectedWithCapabilitiesDTO>> result = await _clientService.GetClientsWithCapabilitiesAsync();

        if (!result.IsSuccess || result.Data == null)
        {
            _toastService.ShowError($"Failed to load clients: {result.Error}");
            clients = [];
            SetSelectedClient(null);
            return;
        }

        clients = result.Data
            .Where(x => x.IsCurrentlyConnected)
            .OrderBy(x => x.Name)
            .ToList();
    }

    private void SetSelectedClient(Guid? clientId)
    {
        selectedClientId = clientId;

        isPlaying = clientId.HasValue ? _player.GetCurrentPlaybackState(clientId.Value) == PlaybackState.Playing : false;
        currentVolume = clientId.HasValue ? _player.GetCurrentVolume(clientId.Value) : 0;
        isShuffleEnabled = clientId.HasValue ? _player.GetCurrentShuffleState(clientId.Value) : false;
        isRepeatEnabled = clientId.HasValue ? _player.GetCurrentRepeatState(clientId.Value) : false;
        currentSongTime = clientId.HasValue ? _player.GetCurrentSongTime(clientId.Value) : 0;
        currentSongLength = clientId.HasValue ? _player.GetCurrentSongLength(clientId.Value) : 0;

        if (currentSongLength == 0)
        {
            stopSongTimeTimer();
        }
        else
        {
            startSongTimeTimer();
        }

        InvokeAsync(StateHasChanged);
    }

    private void stopSongTimeTimer()
    {
        if (songTimeTimer != null)
        {
            songTimeTimer.Dispose();
            songTimeTimer = null;
        }
    }

    private void startSongTimeTimer()
    {
        stopSongTimeTimer();

        songTimeTimer = new Timer(async _ =>
        {
            if (selectedClientId.HasValue)
            {
                currentSongTime += 0.1f;

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                stopSongTimeTimer();
            }
        }, null, TimeSpan.Zero, TimeSpan.FromMilliseconds(100));
    }

    private async Task<Guid?> GetPersistedSelectedClientIdAsync()
    {
        try
        {
            string? value = await JS.InvokeAsync<string?>("localStorage.getItem", StorageSelectedClientKey);
            return Guid.TryParse(value, out Guid clientId) ? clientId : null;
        }
        catch (JSException)
        {
            return null;
        }
    }

    private async Task PersistSelectedClientIdAsync(Guid clientId)
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageSelectedClientKey, clientId.ToString());
        }
        catch (JSException)
        {
        }
    }

    private async Task ClearPersistedSelectedClientIdAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", StorageSelectedClientKey);
        }
        catch (JSException)
        {
        }
    }

    private async Task TogglePlay()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.TogglePlay(selectedClientId.Value);
    }

    private async Task RestartSong()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.RestartOrPrevious(selectedClientId.Value);
    }

    private async Task PreviousSong()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.Previous(selectedClientId.Value);
    }

    private async Task NextSong()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        await _player.Next(selectedClientId.Value);
    }

    private void HandleSongsSelected((IEnumerable<PlaylistSongMember> Songs, bool IsLocalSongs) args)
    {
        currentSongs = args.Songs;
        allowPlaying = !args.IsLocalSongs;
        StateHasChanged();
    }

    private async Task HandleVolumeChange(int newVolume)
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        currentVolume = newVolume;
        
        await _player.SetVolume(selectedClientId.Value, newVolume);
    }
    
    private async Task ToggleMuteVolume()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        currentVolume = currentVolume == 0 ? 25 : 0;

        await _player.SetVolume(selectedClientId.Value, currentVolume);
    }

    private async Task ToggleShuffle()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        isShuffleEnabled = await _player.ToggleShuffle(selectedClientId.Value);
    }

    private async Task ToggleRepeat()
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        isRepeatEnabled = await _player.ToggleRepeat(selectedClientId.Value);
    }

    private async Task OnSongTimeChanged(double newTime)
    {
        if (selectedClientId == null)
        {
            _toastService.ShowWarning("Select a connected client first.");
            return;
        }

        if (Math.Abs(newTime - currentSongTime) < 0.5) return;

        currentSongTime = (float)newTime;

        await _player.Seek(selectedClientId.Value, currentSongTime);
    }

    public void Dispose()
    {
        _player.OnPlaybackStatusChanged -= HandlePlaybackStateChanged;
        _player.OnShuffleStateChanged -= HandleShuffleStateChanged;
        
        stopSongTimeTimer();
    }
}
