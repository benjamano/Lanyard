@page "/kiosk/{clientId}/{projectionProgramId}"

@using Lanyard.Application.Services
@using Lanyard.App.Components.Kiosk

@inject IProjectionProgramService _projectionProgramService
@inject IClientService _clientService
@inject IToastService _toastService

<PageTitle>Kiosk</PageTitle>

@if (errorMessage == null && (projectionProgram == null || clientProjectionSettings == null))
{
    <FluentCard Height="auto">
        <FluentStack Orientation="@Orientation.Vertical"
                        VerticalGap="10">
            <FluentStack HorizontalGap="10">
                <FluentText Size="@TextSize.Size700">
                    Loading...
                </FluentText>

                <FluentSpinner Size="SpinnerSize.Large" />
            </FluentStack>
            <FluentText Color="@Color.Info">
                Client Id: @clientId
                <br />
                Projection Program Id: @projectionProgramId
            </FluentText>
        </FluentStack>
    </FluentCard>
}
else if (errorMessage is not null)
{
    <FluentCard Height="auto">
        <FluentStack Orientation="@Orientation.Vertical"
                        VerticalGap="10">
            <FluentStack HorizontalGap="10">
                <FluentText Size="@TextSize.Size700">
                    Error
                </FluentText>
            </FluentStack>
            <FluentStack Orientation="@Orientation.Horizontal"
                        HorizontalGap="10">
                <FluentIcon Value="@(new Icons.Regular.Size24.ErrorCircle())" 
                            Color="@Color.Error" />
                <FluentText Color="@Color.Error">
                    @errorMessage
                </FluentText>
            </FluentStack>
        </FluentStack>
    </FluentCard>
}
else if (projectionProgram is not null && clientProjectionSettings is not null)
{
    <KioskDisplay @ref="kioskDisplay"
                    ProjectionProgram="@projectionProgram"
                    ClientId="clientGuid"
                    RepeatCount="clientProjectionSettings.RepeatNumberOfTimes"
                    RepeatInfinitely="clientProjectionSettings.RepeatInfinitely" />

    <KioskDebugInfo Hidden="@(clientProjectionSettings.ShowDebugMode)" 
                    CurrentStep="CurrentStep" 
                    StepsCount="projectionProgram.ProjectionProgramSteps.Count()" />
}


@code {
    [Parameter]
    public string clientId { get; set; } = string.Empty;

    [Parameter]
    public string projectionProgramId { get; set; } = string.Empty;

    public ProjectionProgramStep? CurrentStep { get; set; } = null;

    private ClientProjectionSettings? clientProjectionSettings { get; set; } = null;

    private ProjectionProgram? projectionProgram { get; set; } = null;

    public KioskDisplay kioskDisplay { get; set; } = default!;

    private Guid clientGuid;

    private string? errorMessage { get; set; } = null;

    protected async override Task OnInitializedAsync()
    {
        if (!Guid.TryParse(projectionProgramId, out Guid projectionProgramGuid))
        {
            errorMessage = "Invalid projection program id.";

            return;
        }

        if (!Guid.TryParse(clientId, out clientGuid))
        {
            errorMessage = "Invalid client id.";

            return;
        }

        Result<ProjectionProgram> getResult = await _projectionProgramService.GetProjectionProgramAsync(projectionProgramGuid);

        if (!getResult.IsSuccess || getResult.Data is null)
        {
            errorMessage = getResult.Error ?? "Projection program not found.";

            return;
        }

        projectionProgram = getResult.Data;

        Result<IEnumerable<ClientProjectionSettings>> settingsResult = await _clientService.GetClientProjectionSettingsAsync(clientGuid);

        if (settingsResult.IsSuccess && settingsResult.Data is not null)
        {
            clientProjectionSettings = settingsResult.Data
                .FirstOrDefault(x => x.ProjectionProgramId == projectionProgramGuid);
        }

        clientProjectionSettings ??= new ClientProjectionSettings
        {
            ClientId = clientGuid,
            ProjectionProgramId = projectionProgramGuid
        };

        StateHasChanged();
    }

    private bool _processingStarted;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!_processingStarted
            && kioskDisplay is not null
            && projectionProgram is not null
            && clientProjectionSettings is not null)
        {
            _processingStarted = true;

            kioskDisplay.StartProcessing();
        }
    }
}