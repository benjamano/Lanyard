@using Lanyard.Application.Services.Authentication
@using System.Globalization

@inject NavigationManager NavigationManager

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <ImportMap />

    <link rel="icon" type="image/png" href="favicon.png" />
    <link href="_content/Microsoft.FluentUI.AspNetCore.Components/Microsoft.FluentUI.AspNetCore.Components.bundle.scp.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="@Assets["app.js"]"></script>
    <script src="@Assets["js/autoLogout.js"]"></script>
    <link rel="stylesheet" href="Lanyard.App.styles.css" />
    <HeadOutlet @rendermode="PageRenderMode" />

    <style>
        @@media (prefers-color-scheme: dark) {
            body {
                background-color: #292929;
                color: #ffffff;
            }
        }
    </style>

    @if (NavigationManager.Uri.Contains("/", StringComparison.OrdinalIgnoreCase))
    {
        <link rel="manifest" href="manifest.webmanifest" />
        <meta name="theme-color" content="#0d6efd" />
    }
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    <FluentProviders />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="https://kit.fontawesome.com/9d35a24d36.js" crossorigin="anonymous"></script>
    <script src="/_framework/aspnetcore-browser-refresh.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <ReconnectModal />
    @if (NavigationManager.Uri.Contains("/", StringComparison.OrdinalIgnoreCase))
    {
        <text>
            <script>
                if ('serviceWorker' in navigator) {
                    navigator.serviceWorker.register('/service-worker.js');
                }
            </script>
        </text>
    }

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>
</body>

</html>

@inject ISecurityService SecurityService

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;

    protected override async Task OnInitializedAsync()
    {
        Result<UserProfile> result = await SecurityService.GetCurrentUserProfileAsync();
        
        if (result.IsSuccess && !string.IsNullOrEmpty(result.Data?.PreferredCulture))
        {
            CultureInfo culture = new CultureInfo(result.Data.PreferredCulture);
            CultureInfo.DefaultThreadCurrentCulture = culture;
            CultureInfo.DefaultThreadCurrentUICulture = culture;
        }
    }
}
