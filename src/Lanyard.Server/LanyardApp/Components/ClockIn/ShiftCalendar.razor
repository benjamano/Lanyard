@inject IToastService _toastService

<FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center">
    <FluentCalendar TValue="DateTime" DisabledDateFunc="(date => AmIOnShift(date) == false)" DisabledSelectable="false">
        <DaysTemplate>
            @if (context.IsInactive == false && AmIOnShift(context.Date))
            {
                <FluentText class="pt-1"
                            Color="@(context.Date.Date == DateTime.Today && context.IsSelected == false ? Color.Default : Color.Primary)"
                            Typo="Typography.Body"
                            @onclick="() => ShowShiftDetails(context.Date)">
                    @context.DayNumber
                </FluentText>
            }
            else
            {
                <FluentText class="pt-1"
                            Color="@(context.Date.Date == DateTime.Today && context.IsSelected == false ? Color.Default : Color.Info)"
                            Typo="Typography.Body">
                    @context.DayNumber
                </FluentText>
            }
        </DaysTemplate>
    </FluentCalendar>
    <FluentText Typo="Typography.Body" Color="Color.Info">Click on a Day to view Shift Details</FluentText>
</FluentStack>

@code {
    protected override async Task OnInitializedAsync()
    {
    }

    private bool AmIOnShift(DateTime date)
    {
        return date.Day % 2 == 0;
    }

    private void ShowShiftDetails(DateTime date)
    {
        _toastService.ShowInfo($"Shift details for {date.ToShortDateString()}");   
    }
}