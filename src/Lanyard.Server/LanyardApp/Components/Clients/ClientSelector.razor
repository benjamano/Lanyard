@using Lanyard.Application.Services.Authentication
@using Lanyard.Infrastructure.DTO
@using Mono.TextTemplating

@inject IToastService _toastService
@inject IClientService _clientService
@inject ILogger<ClientSelector> _logger

<FluentStack Orientation="Orientation.Horizontal"
            VerticalAlignment="VerticalAlignment.Center"
            HorizontalGap="8"
            Class="music-client-controls"
            Width="auto">
    <FluentSelect Value="@(selectedClientId?.ToString() ?? string.Empty)"
                ValueChanged="(newValue) => OnSelectedClientChanged(newValue)"
                TOption="Guid"
                Class="music-client-select"
                Disabled="@(!(clients.Count() > 0))">
        @if (!clients.Any())
        {
            <FluentOption Value="">No connected clients</FluentOption>
        }
        else if (clients.Count() == 1)
        {
            <FluentOption Value="@clients.First().Id.ToString()">@clients.First().Name</FluentOption>
        }
        else
        {
            <FluentOption Value="">Select a client</FluentOption>

            @foreach (Client client in clients)
            {
                <FluentOption Value="@client.Id.ToString()">@client.Name</FluentOption>
            }
        }
    </FluentSelect>

    <FluentButton Appearance="Appearance.Outline" OnClick="RefreshClientsAsync">
        Refresh
    </FluentButton>
</FluentStack>

@code {
    [Parameter]
    public EventCallback<Guid?> OnClientSelected { get; set; }

    private IEnumerable<Client> clients = [];

    private Guid? selectedClientId;

    protected override async Task OnInitializedAsync()
    {
        await RefreshClientsAsync();
    }

    private async Task RefreshClientsAsync()
    {
        Result<IEnumerable<Client>> result = await _clientService.GetConnectedClientsAsync();

        if (result.IsSuccess && result.Data != null)
        {
            clients = result.Data;

            if (clients.Count() == 1)
            {
                selectedClientId = clients.First().Id;
                
                await OnClientSelected.InvokeAsync(selectedClientId);
            }
        }
        else
        {
            _logger.LogError("Error loading connected clients: {Message}", result.Error);
            _toastService.ShowError("Failed to load connected clients.");
        }
    }

    private async Task OnSelectedClientChanged(string newValue)
    {
        selectedClientId = Guid.TryParse(newValue, out Guid clientId) ? clientId : (Guid?)null;

        if (selectedClientId.HasValue)
        {
            await OnClientSelected.InvokeAsync(selectedClientId.Value);
        }
        else
        {
            await OnClientSelected.InvokeAsync(null);
        }
    }
}