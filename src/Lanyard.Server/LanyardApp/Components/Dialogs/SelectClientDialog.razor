@using Lanyard.Infrastructure.Models

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center" HorizontalGap="2">
            <FluentIcon Value="@(new Icons.Regular.Size24.Desktop())" />
            <FluentText Weight="TextWeight.Semibold" Color="Color.Default" Size="@TextSize.Size700">
                Select Client
            </FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        <FluentSelect TOption="Client"
                      TValue="string"
                      Items="@Clients"
                      OptionText="@(c => c?.Name ?? string.Empty)"
                      OptionValue="@(c => c?.Id.ToString())"
                      Label="Client"
                      Placeholder="Select a client..."
                      Value="@_selectedValue"
                      ValueChanged="@OnValueChanged"
                      Style="width: 100%;" />
    </ChildContent>
    <ActionTemplate>
        <FluentButton Appearance="ButtonAppearance.Primary"
                      Disabled="@(_selectedClientId == null)"
                      OnClick="@ConfirmAsync">
            Ok
        </FluentButton>
        <FluentButton OnClick="@CancelAsync">Cancel</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code {
    [Parameter]
    public required IEnumerable<Client> Clients { get; set; }

    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    private Guid? _selectedClientId;
    private string _selectedValue = string.Empty;

    private void OnValueChanged(string? newValue)
    {
        if (Guid.TryParse(newValue, out Guid id))
        {
            _selectedClientId = id;
            _selectedValue = newValue ?? string.Empty;
        }
        else
        {
            _selectedClientId = null;
            _selectedValue = string.Empty;
        }
    }

    private async Task ConfirmAsync()
    {
        if (_selectedClientId.HasValue)
        {
            await Dialog.CloseAsync(_selectedClientId.Value);
        }
    }

    private async Task CancelAsync()
    {
        await Dialog.CancelAsync();
    }
}
