@using Lanyard.Application.Services.Authentication
@using Lanyard.Infrastructure.DataAccess
@using Lanyard.Infrastructure.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context
@inject IToastService ToastService

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size24.MusicNote2())" />
            <FluentText Typo="Typography.PaneHeader">Add to Playlist</FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        @if (isLoading)
        {
            <FluentStack HorizontalAlignment="HorizontalAlignment.Center" VerticalGap="8">
                <FluentSpinner />
                <FluentText>Loading playlists...</FluentText>
            </FluentStack>
        }
        else if (!Playlists.Any())
        {
            <FluentStack VerticalGap="16">
                <FluentText Style="text-align: center; color: var(--neutral-foreground-hint);">
                    No playlists available. Create a playlist first.
                </FluentText>
            </FluentStack>
        }
        else
        {
            <FluentSelect TOption="Playlist"
                          TValue="string"
                          Items="@Playlists"
                          OptionText="@(p => p?.Name ?? string.Empty)"
                          OptionValue="@(p => p?.Id.ToString())"
                          Value="@(Content.Playlist?.Id.ToString() ?? string.Empty)"
                          ValueChanged="@OnPlaylistSelected"
                          Placeholder="Select Playlist"
                          Label="Playlist"
                          Style="width: 100%;" />
        }
    </ChildContent>
    <ActionTemplate>
        <FluentButton Appearance="ButtonAppearance.Primary"
                      Disabled="@(Content.Playlist is null || !Playlists.Any())"
                      OnClick="@ConfirmAsync">
            Add to Playlist
        </FluentButton>
        <FluentButton OnClick="@CancelAsync">Cancel</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code {
    [Parameter]
    public SongPlaylistSelection Content { get; set; } = default!;

    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    private bool isLoading = true;
    private IEnumerable<Playlist> Playlists = Enumerable.Empty<Playlist>();

    protected override async Task OnInitializedAsync()
    {
        await LoadPlaylists();
    }

    private async Task LoadPlaylists()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            Playlists = await _context.Playlists
                .AsNoTracking()
                .Where(p => p.DeleteDate == null)
                .OrderByDescending(p => p.CreateDate)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to load playlists: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void OnPlaylistSelected(string? playlistId)
    {
        if (Guid.TryParse(playlistId, out Guid parsedPlaylistId))
        {
            Content.Playlist = Playlists.FirstOrDefault(p => p.Id == parsedPlaylistId);
        }
        else
        {
            Content.Playlist = null;
        }
    }

    private async Task ConfirmAsync()
    {
        await Dialog.CloseAsync(Content.Playlist);
    }

    private async Task CancelAsync()
    {
        await Dialog.CancelAsync();
    }
}
