<FluentCard Appearance="CardAppearance.Filled" Height="100%">
    <FluentStack Height="100%" Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" VerticalGap="4">
        <FluentText Size="TextSize.Size900" Style="font-variant-numeric: tabular-nums;">
            @_currentTime
        </FluentText>
        @if (ShowDate == true)
        {
            <FluentText Size="TextSize.Size300" Color="Color.Info">
                @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
            </FluentText>
        }
    </FluentStack>
</FluentCard>

@implements IDisposable

@code {
    private string _currentTime = string.Empty;
    private Timer? _timer;
    private string _timeFormat = "HH:mm:ss";
    private int _timerIntervalMs = 1000;

    [Parameter]
    public bool? ShowMilliseconds { get; set; } = false;

    [Parameter]
    public bool? Is24HourFormat { get; set; } = true;

    [Parameter]
    public bool? ShowDate { get; set; } = true;

    protected override void OnInitialized()
    {
        ConfigureClockFormat();
        _currentTime = DateTime.Now.ToString(_timeFormat);
        _timer = new Timer(UpdateClock, null, 0, _timerIntervalMs);
    }

    protected override void OnParametersSet()
    {
        ConfigureClockFormat();
        _timer?.Change(0, _timerIntervalMs);
    }

    private void ConfigureClockFormat()
    {
        bool includeMilliseconds = ShowMilliseconds == true;
        bool use24HourFormat = Is24HourFormat != false;

        if (use24HourFormat)
        {
            _timeFormat = includeMilliseconds ? "HH:mm:ss.fff" : "HH:mm:ss";
        }
        else
        {
            _timeFormat = includeMilliseconds ? "hh:mm:ss.fff tt" : "hh:mm:ss tt";
        }

        _timerIntervalMs = includeMilliseconds ? 50 : 1000;
    }

    private void UpdateClock(object? state)
    {
        _currentTime = DateTime.Now.ToString(_timeFormat);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}