@using Lanyard.App.Components.Layout.Staff
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.Extensions.Hosting

@inject IWebHostEnvironment HostEnvironment
@inject NavigationManager Navigation

<CascadingAuthenticationState>
    <LayoutView Layout="@GetLayout()">
        <Router AppAssembly="@typeof(Program).Assembly" NotFoundPage="typeof(StaffNotFound)">
            <Found Context="routeData">
                <RouteView RouteData="@routeData" />
            </Found>
        </Router>
    </LayoutView>
</CascadingAuthenticationState>

@code {
    private Type GetLayout()
    {
        return Navigation.Uri.Contains("/kiosk") || Navigation.Uri.Contains("/video-publisher")
            ? typeof(EmptyLayout)
            : typeof(MainLayout);
    }

    private void OnNavigateHandler(NavigationContext context)
    {

    }
}