@implements IAsyncDisposable
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IDialogService DialogService

@code {
    private static readonly TimeSpan InactivityTimeout = TimeSpan.FromMinutes(30);

    private static readonly TimeSpan MaxSessionDuration = TimeSpan.FromHours(2);
    @* private static readonly TimeSpan MaxSessionDuration = TimeSpan.FromSeconds(10); *@

    private static readonly TimeSpan WarningLeadTime = TimeSpan.FromMinutes(1);
    @* private static readonly TimeSpan WarningLeadTime = TimeSpan.FromHours(2); *@
    private static readonly string[] ExemptPrefixes = ["/kiosk", "/HandleLogin", "/HandleLogout", "/login"];

    private DateTime _sessionStart;
    private DateTime _lastActivity;
    private System.Threading.Timer? _ticker;
    private DotNetObjectReference<AutoLogoutManager>? _selfRef;
    private bool _warningShown;
    private bool _disposed;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;

        AuthenticationState auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated != true)
            return;

        _initialized  = true;
        _sessionStart = DateTime.UtcNow;
        _lastActivity = DateTime.UtcNow;

        _selfRef = DotNetObjectReference.Create(this);
        
        try
        {
            await JS.InvokeVoidAsync("autoLogout.dispose");
        }
        catch { }

        _ticker = new System.Threading.Timer(
            _ => InvokeAsync(CheckTimers),
            null,
            TimeSpan.FromSeconds(2),
            TimeSpan.FromSeconds(2));
    }

    [JSInvokable]
    public void OnUserActivity() => _lastActivity = DateTime.UtcNow;

    private async Task CheckTimers()
    {
        if (_disposed || _warningShown || IsExemptPage())
            return;

        DateTime now = DateTime.UtcNow;
        TimeSpan inactivityRemaining = InactivityTimeout - (now - _lastActivity);
        TimeSpan sessionRemaining = MaxSessionDuration - (now - _sessionStart);
        TimeSpan timeUntilLogout = TimeSpan.FromTicks(Math.Min(inactivityRemaining.Ticks, sessionRemaining.Ticks));

        if (timeUntilLogout <= TimeSpan.Zero)
            await PerformLogoutAsync();
        else if (timeUntilLogout <= WarningLeadTime)
            await ShowWarningAsync((int)timeUntilLogout.TotalSeconds);
    }

    private bool IsExemptPage()
    {
        string path = new Uri(Nav.Uri).AbsolutePath;
        return ExemptPrefixes.Any(prefix => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase));
    }

    private async Task ShowWarningAsync(int secondsRemaining)
    {
        _warningShown = true;

        DialogResult result = await DialogService.ShowDialogAsync<AutoLogoutWarningDialog>(options =>
        {
            options.Header.Title = "Session expiring";
            options.Width = "380px";
            options.Modal = true;
            options.Parameters.Add(nameof(AutoLogoutWarningDialog.Content), secondsRemaining);
        });

        if (result.Cancelled)
        {
            await PerformLogoutAsync();
        }
        else
        {
            _lastActivity = DateTime.UtcNow;
            _sessionStart = DateTime.UtcNow;
            _warningShown = false;
        }
    }

    private async Task PerformLogoutAsync()
    {
        _disposed = true;
        _ticker?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("autoLogout.dispose");
        }
        catch { }

        // Capture the page the user was on so re-login can return them here.
        string returnUrl = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/');
        string target = Nav.GetUriWithQueryParameters(
            "/HandleLogout",
            new Dictionary<string, object?> { ["ReturnUrl"] = returnUrl });
        Nav.NavigateTo(target, forceLoad: true);
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _ticker?.Dispose();
        _selfRef?.Dispose();

        try
        {
            await JS.InvokeVoidAsync("autoLogout.dispose");
        }
        catch { }
    }
}
