@implements IAsyncDisposable

<FluentDialogBody>
    <ChildContent>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" HorizontalAlignment="@HorizontalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size48.Timer())" Color="@Color.Warning" />

            <FluentText Typo="Typography.Body">
                Your session will expire due to inactivity or reaching the maximum session length.
                You will be logged out in <strong>@_secondsLeft second@(_secondsLeft == 1 ? "" : "s")</strong>.
            </FluentText>

            <FluentButton OnClick="async () => await Dialog.CancelAsync()" Appearance="ButtonAppearance.Primary">Log out now</FluentButton>
            <FluentButton OnClick="async () => await Dialog.CloseAsync()" Appearance="ButtonAppearance.Default">Stay logged in</FluentButton>
        </FluentStack>
    </ChildContent>
</FluentDialogBody>

@code {
    [Parameter]
    public int Content { get; set; }

    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    private int _secondsLeft;
    private System.Threading.Timer? _ticker;

    protected override void OnInitialized()
    {
        _secondsLeft = Math.Max(Content, 1);

        _ticker = new System.Threading.Timer(
            _ => InvokeAsync(TickAsync),
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(1));
    }

    private async Task TickAsync()
    {
        _secondsLeft--;
        StateHasChanged();

        if (_secondsLeft <= 0)
        {
            _ticker?.Dispose();
            await Dialog.CancelAsync();
        }
    }

    public ValueTask DisposeAsync()
    {
        _ticker?.Dispose();
        return ValueTask.CompletedTask;
    }
}
