@inherits LayoutComponentBase

@inject NavigationManager NavigationManager

<FluentProviders />

<FluentLayout>
    <FluentLayoutItem Area="LayoutArea.Header">
        <FluentStack VerticalAlignment="VerticalAlignment.Top">
            <FluentLayoutHamburger Visible="true"/>
            <FluentSpacer Width="10px"></FluentSpacer>
            <FluentLink Href="/" Class="nav-brand">
                <FluentText Weight="TextWeight.Bold" Size="TextSize.Size500" Style="color:white;">
                    <span>
                        Lan<span class="nav-brand-flip">y</span>ard
                    </span>
                </FluentText>
            </FluentLink>
        </FluentStack>
    </FluentLayoutItem>

    <FluentLayoutItem Area="LayoutArea.Navigation" Height="auto">
        <NavMenu />
    </FluentLayoutItem>

    <FluentLayoutItem Area="LayoutArea.Content" Padding="@Padding.All3">
        <AutoLogoutManager />
        @Body
    </FluentLayoutItem>

    <FluentLayoutItem Area="LayoutArea.Footer" Height="auto">
        <Footer />
    </FluentLayoutItem>
</FluentLayout>

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
    }
}
