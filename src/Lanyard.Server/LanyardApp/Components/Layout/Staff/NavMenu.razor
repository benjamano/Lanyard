@inject NavigationManager NavigationManager
@inject ISecurityService SecurityService
@inject AuthenticationStateProvider AuthStateProvider

<FluentStack Orientation="Orientation.Vertical" VerticalAlignment="VerticalAlignment.SpaceBetween" HorizontalAlignment="HorizontalAlignment.Stretch" Height="100%">
    <FluentNav UseSingleExpanded="true" Density="NavDensity.Medium" Padding="@Padding.All3">
        @if (_isAuthenticated)
        {
            <FluentNavItem Href="/"
                            IconRest="@(new Icons.Regular.Size20.Home())"
                            IconActive="@(new Icons.Filled.Size20.Home())"
                            Match="NavLinkMatch.All">
                Home
            </FluentNavItem>

            @if (_canControlMusic)
            {
                <FluentNavItem Href="/music"
                                IconRest="@(new Icons.Regular.Size20.MusicNote2())"
                                IconActive="@(new Icons.Filled.Size20.MusicNote2())">
                    Music
                </FluentNavItem>
            }

            @if (_canClockIn)
            {
                <FluentNavCategory Title="Rota"
                                    IconRest="@(new Icons.Regular.Size20.CalendarLtr())"
                                    IconActive="@(new Icons.Filled.Size20.CalendarLtr())">
                    <FluentNavItem Href="/rota/clockin">Clock In</FluentNavItem>
                    <FluentNavItem Href="/rota">Rota</FluentNavItem>
                </FluentNavCategory>
            }

            @if (_isManager)
            {
                <FluentNavSectionHeader Title="Management" />

                <FluentNavItem Href="/files"
                                IconRest="@(new Icons.Regular.Size20.Folder())"
                                IconActive="@(new Icons.Filled.Size20.Folder())">
                    File Manager
                </FluentNavItem>

                <FluentNavCategory Title="Manage"
                                    IconRest="@(new Icons.Regular.Size20.Settings())"
                                    IconActive="@(new Icons.Filled.Size20.Settings())">
                    <FluentNavItem Href="/manage/roles">Roles</FluentNavItem>
                    <FluentNavItem Href="/manage/users">Users</FluentNavItem>
                </FluentNavCategory>
            }

            @if (_isAdmin)
            {
                <FluentNavSectionHeader Title="Clients" />
                
                <FluentNavCategory Title="Clients"
                                    IconRest="@(new Icons.Regular.Size20.Laptop())"
                                    IconActive="@(new Icons.Filled.Size20.Laptop())">
                    <FluentNavItem Href="/manage/clients" IconRest="@(new Icons.Regular.Size20.LaptopSettings())" IconActive="@(new Icons.Filled.Size20.LaptopSettings())">Clients</FluentNavItem>
                    <FluentNavItem Href="/manage/projectionprograms" IconRest="@(new Icons.Regular.Size20.ProjectionScreenTextSparkle())" IconActive="@(new Icons.Filled.Size20.ProjectionScreenTextSparkle())">Projection</FluentNavItem>
                    <FluentNavItem Href="/manage/projectiontemplates" IconRest="@(new Icons.Regular.Size20.BookTemplate())" IconActive="@(new Icons.Filled.Size20.BookTemplate())">Templates</FluentNavItem>
                    <FluentNavItem Href="/automation" IconRest="@(new Icons.Regular.Size20.SettingsCogMultiple())" IconActive="@(new Icons.Filled.Size20.SettingsCogMultiple())">Automation</FluentNavItem>

                    @if (_canManageDmx)
                    {
                        <FluentNavItem Href="/dmx">DMX Control</FluentNavItem>
                    }
                </FluentNavCategory>
            }

            <FluentNavSectionHeader Title="Dashboards" />
            <FluentNavItem Href="/manage/dashboards" IconRest="@(new Icons.Regular.Size20.DataArea())" IconActive="@(new Icons.Filled.Size20.DataArea())">Dashboards</FluentNavItem>
        }
    </FluentNav>

    <div class="w-100">
        <FluentDivider />
        <FluentNav Margin="Margin.Top2" Density="NavDensity.Medium" Padding="@Padding.All3">
            @if (_isAuthenticated)
            {
                <FluentNavItem Href="/account/manage"
                                IconRest="@(new Icons.Regular.Size20.Person())"
                                IconActive="@(new Icons.Filled.Size20.Person())">
                    @_displayName
                </FluentNavItem>
                <FluentNavItem Href="/api/auth/logout"
                                IconRest="@(new Icons.Regular.Size20.SignOut())"
                                IconActive="@(new Icons.Filled.Size20.SignOut())">
                    Logout
                </FluentNavItem>
            }
            else
            {
                <FluentNavItem Href="/login"
                                IconRest="@(new Icons.Regular.Size20.ArrowEnter())"
                                IconActive="@(new Icons.Filled.Size20.ArrowEnter())">
                    Login
                </FluentNavItem>
            }
        </FluentNav>
    </div>
</FluentStack>

@code {
    private bool _isAuthenticated;
    private bool _isAdmin;
    private bool _isManager;
    private bool _canControlMusic;
    private bool _canClockIn;
    private bool _canManageDmx;
    private string? _displayName;

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState state = await AuthStateProvider.GetAuthenticationStateAsync();
        System.Security.Claims.ClaimsPrincipal user = state.User;

        _isAuthenticated = user.Identity?.IsAuthenticated == true;
        _isAdmin = user.IsInRole("Admin");
        _isManager = _isAdmin || user.IsInRole("Manager");
        _canControlMusic = _isAdmin || user.IsInRole("CanControlMusic");
        _canClockIn = _isAdmin || user.IsInRole("CanClockIn");
        _canManageDmx = _isAdmin || user.IsInRole("CanManageDmxSystems");

        if (_isAuthenticated)
        {
            string? name = await SecurityService.GetCurrentUserName();
            _displayName = name?.Length > 20 ? name[..20] + "…" : name;
        }
    }
}
