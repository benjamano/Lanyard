@using Lanyard..Services.Authentication
@implements IDisposable

@inject NavigationManager NavigationManager
@inject ISecurityService SecurityService

<nav class="navbar navbar-expand-lg border-bottom shadow-sm">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <FluentIcon Value="@(new Icons.Regular.Size24.Apps())" Color="Color.FillInverse" class="me-2" />
            <span style="font-size: 1.5rem; font-weight: 700;">Lanyard</span>
        </a>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto me-0">
                <li class="nav-item">
                    <a class="nav-link d-flex align-items-center px-3" href="/">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Home())" Color="Color.FillInverse" class="me-2" />
                        <span>Home</span>
                    </a>
                </li>

                <AuthorizeView Roles="Admin,CanControlMusic">
                    <Authorized>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center px-3" href="//music">
                                <FluentIcon Value="@(new Icons.Regular.Size20.MusicNote2())" Color="Color.FillInverse" class="me-2" />
                                <span>Music</span>
                            </a>
                        </li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Admin,CanClockIn">
                    <Authorized>
                        <li class="nav-item">
                            <div class="nav-dropdown">
                                <span class="nav-link nav-dropdown-toggle d-flex align-items-center px-3">
                                    <FluentIcon Value="@(new Icons.Regular.Size20.CalendarLtr())" Color="Color.FillInverse" class="me-2" />
                                    <span>Rota</span>
                                </span>
                                <div class="nav-dropdown-menu">
                                    <a class="nav-dropdown-item d-flex align-items-center" href="//rota/clockin">
                                        <FluentIcon Value="@(new Icons.Regular.Size20.Clock())" Color="Color.FillInverse" class="me-2" />
                                        <span>Clock In</span>
                                    </a>
                                    <a class="nav-dropdown-item d-flex align-items-center" href="//rota">
                                        <FluentIcon Value="@(new Icons.Regular.Size20.CalendarLtr())" Color="Color.FillInverse" class="me-2" />
                                        <span>Rota</span>
                                    </a>
                                </div>
                            </div>
                        </li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Admin,Manager">
                    <Authorized>
                        <li class="nav-item">
                            <div class="nav-dropdown">
                                <span class="nav-link nav-dropdown-toggle d-flex align-items-center px-3">
                                    <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" Color="Color.FillInverse" class="me-2" />
                                    <span>Manage</span>
                                </span>
                                <div class="nav-dropdown-menu">
                                    <a class="nav-dropdown-item d-flex align-items-center" href="//manage/roles">
                                        <FluentIcon Value="@(new Icons.Regular.Size20.ShieldTask())" Color="Color.FillInverse" class="me-2" />
                                        <span>Roles</span>
                                    </a>
                                    <a class="nav-dropdown-item d-flex align-items-center" href="//manage/users">
                                        <FluentIcon Value="@(new Icons.Regular.Size20.People())" Color="Color.FillInverse" class="me-2" />
                                        <span>Users</span>
                                    </a>
                                    <a class="nav-dropdown-item d-flex align-items-center" href="//manage/dashboards">
                                        <FluentIcon Value="@(new Icons.Regular.Size20.GridDots())" Color="Color.FillInverse" class="me-2" />
                                        <span>Dashboards</span>
                                    </a>
                                    <a class="nav-dropdown-item d-flex align-items-center" href="//manage/projectionprograms">
                                        <FluentIcon Value="@(new Icons.Regular.Size20.ProjectionScreenText())" Color="Color.FillInverse" class="me-2" />
                                        <span>Projection</span>
                                    </a>
                                    <AuthorizeView Roles="Admin" Context="_context">
                                    <Authorized>
                                            <a class="nav-dropdown-item d-flex align-items-center" href="//manage/clients">
                                                <FluentIcon Value="@(new Icons.Regular.Size20.Tv())" Color="Color.FillInverse" class="me-2" />
                                                <span>Clients</span>
                                            </a>
                                    </Authorized>
                                </AuthorizeView>
                                    <AuthorizeView Roles="Admin" Context="_context">
                                        <Authorized>
                                            <a class="nav-dropdown-item d-flex align-items-center" href="//manage/projectiontemplates">
                                                <FluentIcon Value="@(new Icons.Regular.Size20.ProjectionScreenText())" Color="Color.FillInverse" class="me-2" />
                                                <span>Projection Templates</span>
                                            </a>
                                        </Authorized>
                                    </AuthorizeView>
                                    <AuthorizeView Roles="Admin" Context="_context">
                                        <Authorized>
                                            <a class="nav-dropdown-item d-flex align-items-center" href="//automation">
                                                <FluentIcon Value="@(new Icons.Regular.Size20.Flash())" Color="Color.FillInverse" class="me-2" />
                                                <span>Automation</span>
                                            </a>
                                        </Authorized>
                                    </AuthorizeView>
                                </div>
                            </div>
                        </li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Admin,CanClockIn">
                    <Authorized>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center px-3" href="//files">
                                <FluentIcon Value="@(new Icons.Regular.Size20.Folder())" Color="Color.FillInverse" class="me-2" />
                                <span>File Manager</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center px-3" href="/">
                                <FluentIcon Value="@(new Icons.Regular.Size20.WebAsset())" Color="Color.FillInverse" class="me-2" />
                                <span>Customer Site</span>
                            </a>
                        </li>
                    </Authorized>
                </AuthorizeView>
            
            </ul>

            <ul class="navbar-nav ms-auto">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center px-3" href="//account/manage">
                                <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Color="Color.FillInverse" class="me-2" />
                                <span>@(userName?.Length > 20 ? userName.Substring(0, 20) + "..." : userName)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center px-3" href="/api/auth/logout">
                                <FluentIcon Value="@(new Icons.Regular.Size20.SignOut())" Color="Color.FillInverse" class="me-2" />
                                <span>Logout</span>
                            </a>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center px-3" href="//login">
                                <FluentIcon Value="@(new Icons.Regular.Size20.ArrowEnter())" Color="Color.FillInverse" class="me-2" />
                                <span>Login</span>
                            </a>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

@inject AuthenticationStateProvider Auth

@code {
    private string? userName;

    protected override async Task OnInitializedAsync()
    {
        userName = await SecurityService.GetCurrentUserName();
    }

    public void Dispose()
    {
    }
}

