@using Lanyard.Infrastructure.Models

@inject HttpClient Http
@inject IFileService _fileService
@inject IToastService _toastService

<FluentButton IconEnd="@(new Icons.Regular.Size20.Rename())" OnClick="ShowRenameDialogAsync"></FluentButton>
<FluentButton IconEnd="@(new Icons.Regular.Size20.BinRecycle())" OnClick="DeleteFile"></FluentButton>

<FluentDialog @ref="_renameDialog" Modal="true">
    <FluentDialogBody>
        <TitleTemplate>Rename File</TitleTemplate>
        <ChildContent>
            <FluentTextInput @bind-Value="renameValue" Label="New Name" Style="width: 100%;" />
        </ChildContent>
        <ActionTemplate>
            <FluentButton Appearance="ButtonAppearance.Primary" OnClick="ConfirmRenameAsync">Rename</FluentButton>
            <FluentButton Appearance="ButtonAppearance.Outline" OnClick="CloseRenameDialogAsync">Cancel</FluentButton>
        </ActionTemplate>
    </FluentDialogBody>
</FluentDialog>

@code {
    [Parameter] public FileMetadata File { get; set; } = default!;
    [Parameter] public EventCallback<Guid> OnFileDeleted { get; set; }
    [Parameter] public EventCallback<FileMetadata> OnFileRenamed { get; set; }

    private FluentDialog? _renameDialog;
    private string renameValue = string.Empty;
    private string renameValueExtensions = string.Empty;

    private async Task DeleteFile()
    {
        Result<bool> result = await _fileService.DeleteFileAsync(File.Id, CancellationToken.None);

        if (result?.Success == true)
        {
            await OnFileDeleted.InvokeAsync(File.Id);
        }
    }

    private async Task ShowRenameDialogAsync()
    {
        renameValueExtensions = Path.GetExtension(File.FileName);
        renameValue = Path.GetFileNameWithoutExtension(File.FileName);
        await _renameDialog!.ShowAsync();
    }

    private async Task CloseRenameDialogAsync()
    {
        await _renameDialog!.HideAsync();
    }

    private async Task ConfirmRenameAsync()
    {
        if (!string.IsNullOrWhiteSpace(renameValue))
        {
            string fullName = renameValue + renameValueExtensions;

            Result<FileMetadata> result = await _fileService.RenameFileAsync(File.Id, fullName, CancellationToken.None);

            if (result?.Success == true && result.Data != null)
            {
                await OnFileRenamed.InvokeAsync(result.Data);
                await CloseRenameDialogAsync();
            }
            else
            {
                _toastService.ShowError($"Failed to rename file, {result?.Error}");
            }
        }
        else
        {
            _toastService.ShowError("Invalid file name!");
        }
    }
}
