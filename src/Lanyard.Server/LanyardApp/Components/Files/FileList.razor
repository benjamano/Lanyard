@using Lanyard.Infrastructure.Models
@inject HttpClient Http
@inject IFileService _fileService
@inject IToastService _toastService

<div class="file-list-wrapper w-100">
    <FluentDataGrid Items="@(files?.AsQueryable())" AutoItemsPerPage="true" ItemSize="46" Virtualize="true" GridTemplateColumns="2fr 1fr 1fr 1fr 0.6fr" class="file-list-grid w-100">
        <ChildContent>
            <PropertyColumn Property="x => x.FileName" Title="Name" />
            <PropertyColumn Property="x => x.FileSize" Title="Size" Class="file-list-col-size" />
            <PropertyColumn Property="x => x.ContentType" Title="Type" Class="file-list-col-type" />
            <PropertyColumn Property="x => x.UploadedAt" Title="Uploaded" Class="file-list-col-uploaded" />
            <TemplateColumn Title="Actions" Align="DataGridCellAlignment.End">
                <FileActionsMenu File="context" OnFileDeleted="OnFileDeleted" OnFileRenamed="OnFileRenamed" />
            </TemplateColumn>
        </ChildContent>
        <LoadingContent>
            Loading... <FluentSpinner></FluentSpinner>
        </LoadingContent>
    </FluentDataGrid>
</div>

@code {
    [Parameter] public Guid? FolderId { get; set; }
    [Parameter] public EventCallback<Guid> OnFileDeleted { get; set; }
    [Parameter] public EventCallback<FileMetadata> OnFileRenamed { get; set; }

    private List<FileMetadata>? files;

    protected override async Task OnParametersSetAsync()
    {
        await LoadFilesAsync();
    }

    public async Task RefreshAsync()
    {
        await LoadFilesAsync();
        StateHasChanged();
    }

    private async Task LoadFilesAsync()
    {
        Result<IReadOnlyList<FileMetadata>> result = await _fileService.ListFilesAsync(FolderId, CancellationToken.None);

        if (result?.Success == true && result.Data != null)
        {
            files = result.Data.ToList();
        }
        else
        {
            _toastService.ShowError($"Failed to load files, {result?.Error}");
        }
    }
}
