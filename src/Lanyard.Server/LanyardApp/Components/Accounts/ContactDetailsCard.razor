@using Lanyard.Application.Services.Authentication
@using System.Linq.Expressions
@inject IToastService ToastService

<EditForm EditContext="@_editContext">
    <DataAnnotationsValidator />
    <FluentStack Orientation="Orientation.Vertical">
        <FluentTextInput @bind-Value="model.Email"
                            Label="Email Address"
                            TextInputType="TextInputType.Email"
                            Width="61%"
                            Message="@GetValidationMessage(() => model.Email)"
                            MessageCondition="@(f => !string.IsNullOrEmpty(f.Message))"
                            MessageState="MessageState.Error">
            <EndTemplate>
                <FluentIcon Value="@(new Icons.Regular.Size16.Mail())" Slot="end" />
            </EndTemplate>
        </FluentTextInput>
        <FluentTextInput @bind-Value="model.PhoneNumber"
                            Label="Phone Number"
                            TextInputType="TextInputType.Telephone"
                            Width="61%"
                            Message="@GetValidationMessage(() => model.PhoneNumber)"
                            MessageCondition="@(f => !string.IsNullOrEmpty(f.Message))"
                            MessageState="MessageState.Error">
            <EndTemplate>
                <FluentIcon Value="@(new Icons.Regular.Size16.Phone())" Slot="end" />
            </EndTemplate>
        </FluentTextInput>
        <FluentDatePicker TValue="DateTime?" @bind-Value="model.DateOfBirth"
                            Label="Date of Birth"
                            Width="61%"
                            Message="@GetValidationMessage(() => model.DateOfBirth)"
                            MessageCondition="@(f => !string.IsNullOrEmpty(f.Message))"
                            MessageState="MessageState.Error">
        </FluentDatePicker>
    </FluentStack>
</EditForm>

@code {
    private ContactDetailsModel model = new();
    private EditContext _editContext = default!;

    [Parameter]
    public bool DontShowCard { get; set; } = false;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(model);
    }

    protected override async Task OnInitializedAsync()
    {
        Result<UserProfile> getResult = await _securityService.GetCurrentUserProfileAsync();

        if (getResult.IsSuccess && getResult.Data is not null)
        {
            model.Email = getResult.Data.Email;
            model.PhoneNumber = getResult.Data.PhoneNumber;
            model.DateOfBirth = getResult.Data.DateOfBirth;
        }
    }

    public async Task HandleSave()
    {
        Result<UserProfile> getResult = await _securityService.GetCurrentUserProfileAsync();

        if (getResult.IsSuccess && getResult.Data is not null)
        {
            getResult.Data.Email = model.Email;
            getResult.Data.PhoneNumber = model.PhoneNumber;
            getResult.Data.DateOfBirth = model.DateOfBirth;

            await _securityService.UpdateUserProfileAsync(getResult.Data);

            ToastService.ShowSuccess("Details Saved!");
        }
    }

    private string? GetValidationMessage<T>(Expression<Func<T>> accessor)
    {
        FieldIdentifier fieldId = FieldIdentifier.Create(accessor);
        return _editContext.GetValidationMessages(fieldId).FirstOrDefault();
    }

    private class ContactDetailsModel
    {
        [EmailAddress(ErrorMessage = "Invalid email address.")]
        public string? Email { get; set; }

        [Phone(ErrorMessage = "Invalid phone number.")]
        public string? PhoneNumber { get; set; }

        public DateTime? DateOfBirth { get; set; }
    }
}
