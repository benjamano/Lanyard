@using Lanyard.Application.Services.Authentication
@using System.Linq.Expressions
@inject IToastService ToastService

<EditForm EditContext="@_editContext">
    <DataAnnotationsValidator />
    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Start" Width="100%">
        <FluentTextInput @bind-Value="model.UserName"
                            Label="User Name"
                            ReadOnly="true"
                            Disabled="true"
                            Width="61%">
                            
            <EndTemplate>
                <FluentIcon Value="@(new Icons.Regular.Size16.Person())" Slot="start" />
            </EndTemplate>
        </FluentTextInput>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Start" HorizontalGap="8" Width="75%">
            <FluentTextInput @bind-Value="model.FirstName"
                                Label="First Name"
                                Required="true"
                                Placeholder="Enter your first name"
                                Width="100%"
                                Message="@GetValidationMessage(() => model.FirstName)"
                                MessageCondition="@(f => !string.IsNullOrEmpty(f.Message))"
                                MessageState="MessageState.Error">
                <EndTemplate>
                    <FluentIcon Value="@(new Icons.Regular.Size16.Person())" Slot="start" />
                </EndTemplate>
            </FluentTextInput>
            <FluentTextInput @bind-Value="model.LastName"
                                Label="Last Name"
                                Required="true"
                                Placeholder="Enter your last name"
                                Width="100%"
                                Message="@GetValidationMessage(() => model.LastName)"
                                MessageCondition="@(f => !string.IsNullOrEmpty(f.Message))"
                                MessageState="MessageState.Error">
                <EndTemplate>
                    <FluentIcon Value="@(new Icons.Regular.Size16.Person())" Slot="start" />
                </EndTemplate>
            </FluentTextInput>
        </FluentStack>
        <FluentCheckbox @bind-Value="model.Use24HourFormat" Label="Prefer 24-Hour Format for Time Display" />
    </FluentStack>
</EditForm>

@code {
    private UserDetailsModel model = new();
    private EditContext _editContext = default!;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(model);
    }

    protected override async Task OnInitializedAsync()
    {
        Result<UserProfile> getResult = await _securityService.GetCurrentUserProfileAsync();

        if (getResult.IsSuccess && getResult.Data is not null)
        {
            model.UserName = getResult.Data.UserName!;
            model.FirstName = getResult.Data.FirstName;
            model.LastName = getResult.Data.LastName;

            model.Use24HourFormat = getResult.Data.PreferredCulture == "en-GB";
        }
    }

    public async Task HandleSave()
    {
        Result<UserProfile> getResult = await _securityService.GetCurrentUserProfileAsync();

        if (getResult.IsSuccess && getResult.Data is not null)
        {
            getResult.Data.FirstName = model.FirstName;
            getResult.Data.LastName = model.LastName;
            
            getResult.Data.PreferredCulture = model.Use24HourFormat ? "en-GB" : "en-US";

            await _securityService.UpdateUserProfileAsync(getResult.Data);

            ToastService.ShowSuccess("Details Saved!");
        }
    }

    private string? GetValidationMessage<T>(Expression<Func<T>> accessor)
    {
        FieldIdentifier fieldId = FieldIdentifier.Create(accessor);
        return _editContext.GetValidationMessages(fieldId).FirstOrDefault();
    }

    private class UserDetailsModel
    {
        public string UserName { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "First name is required.")]
        public string? FirstName { get; set; }
        
        [Required(ErrorMessage = "Last name is required.")]
        public string? LastName { get; set; }

        public bool Use24HourFormat { get; set; } = false;
    }
}
