@using Lanyard.App.Components.ProjectionPrograms
@using Lanyard.Application.Services
@using Lanyard.Infrastructure.Models
@using Lanyard.Infrastructure.DTO
@using Lanyard.Infrastructure.DTO.Dmx
@using Lanyard.Infrastructure.DataAccess
@using Lanyard.Shared.Enum
@using System.Text.Json
@using Microsoft.EntityFrameworkCore

@inject IToastService _toastService
@inject IAutomationRuleService _ruleService
@inject IClientService _clientService
@inject IDbContextFactory<ApplicationDbContext> _dbContextFactory
@inject IPlaylistService _playlistService
@inject IProjectionProgramService _projectionProgramService
@inject IDmxSceneService _dmxSceneService
@inject ILogger<AddEditAutomationRuleDialog> _logger

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size20.Flash())" />
            <FluentText Typo="Typography.PaneHeader">@_steps[_currentStepIndex]</FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        @if (_currentStepIndex == 0)
        {
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <FluentTextInput Label="Rule Name"
                                 @bind-Value="_ruleName"
                                 Required="true"
                                 Appearance="TextInputAppearance.Outline"
                                 Style="width: 100%;" />

                <FluentSelect Label="Trigger Client"
                              TOption="ClientConnectedDTO"
                              TValue="string"
                              Items="@_clients"
                              OptionText="@(c => c?.Name ?? string.Empty)"
                              OptionValue="@(c => c?.Id.ToString())"
                              @bind-Value="_triggerClientIdString"
                              Style="width: 100%;" />

                <FluentSelect Label="Trigger Event"
                              TOption="string"
                              TValue="string"
                              @bind-Value="_triggerEventString"
                              Style="width: 100%;">
                    <FluentOption Value="@GameStatus.InGame.ToString()">In Game</FluentOption>
                    <FluentOption Value="@GameStatus.NotStarted.ToString()">Not Started</FluentOption>
                </FluentSelect>
            </FluentStack>
        }
        else if (_currentStepIndex == 1)
        {
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                @for (int i = 0; i < _actionRows.Count; i++)
                {
                    int index = i;
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                        <div>
                            <FluentSelect TOption="string"
                                TValue="string"
                                Label="Action Type"
                                Value="@_actionRows[index].ActionType"
                                ValueChanged="@((string? type) => OnRowActionTypeChangedAsync(index, type))"
                                Style="width: 180px;">
                                <FluentOption Value="@AutomationActionTypes.MusicControl">Music Control</FluentOption>
                                <FluentOption Value="@AutomationActionTypes.StartProjectionProgram">Start Projection Program</FluentOption>
                                <FluentOption Value="@AutomationActionTypes.DmxSceneControl">DMX Scene Control</FluentOption>
                            </FluentSelect>
                        </div>
                        <div>
                            <FluentSelect TOption="ClientConnectedDTO"
                                TValue="string"
                                Label="Target Client"
                                Items="@_clients"
                                OptionText="@(c => c?.Name ?? string.Empty)"
                                OptionValue="@(c => c?.Id.ToString())"
                                Value="@_actionRows[index].TargetClientIdString"
                                ValueChanged="@((string? id) => OnRowClientChangedAsync(index, id))"
                                Style="flex: 1;" />
                        </div>
                        @if (_actionRows[index].ActionType == AutomationActionTypes.StartProjectionProgram)
                        {
                            <div>
                                <FluentSelect TOption="ProjectionProgram"
                                    TValue="string"
                                    Label="Projection Program"
                                    Placeholder="Select Program"
                                    Items="@_programs"
                                    OptionText="@(p => p?.Name ?? string.Empty)"
                                    OptionValue="@(p => p?.Id.ToString())"
                                    Value="@_actionRows[index].ProjectionProgramIdString"
                                    ValueChanged="@((string? id) => _actionRows[index].ProjectionProgramIdString = id ?? string.Empty)"
                                    Style="flex: 1;" />
                            </div>
                            <div>
                                <FluentSelect TOption="string"
                                    TValue="string"
                                    Label="Screen"
                                    Value="@_actionRows[index].DisplayIndexString"
                                    ValueChanged="@((string? screen) => _actionRows[index].DisplayIndexString = screen ?? "default")"
                                    Style="width: 160px;">
                                    <FluentOption TValue="string" Value="default">Client default</FluentOption>
                                    @foreach (ClientAvailableScreen screen in _actionRows[index].Screens)
                                    {
                                        <FluentOption TValue="string" Value="@screen.Index.ToString()">@($"{screen.Name} ({screen.Width}x{screen.Height})")</FluentOption>
                                    }
                                </FluentSelect>
                            </div>
                        }
                        else if (_actionRows[index].ActionType == AutomationActionTypes.DmxSceneControl)
                        {
                            <div>
                                <FluentSelect TOption="string"
                                    TValue="string"
                                    Label="Operation"
                                    Value="@_actionRows[index].DmxOperation"
                                    ValueChanged="@((string? op) => _actionRows[index].DmxOperation = op ?? DmxSceneControlActionExecutor.StartScene)"
                                    Style="width: 150px;">
                                    <FluentOption Value="@DmxSceneControlActionExecutor.StartScene">Start Scene</FluentOption>
                                    <FluentOption Value="@DmxSceneControlActionExecutor.StopScene">Stop Scene</FluentOption>
                                    <FluentOption Value="@DmxSceneControlActionExecutor.StopAllScenes">Stop All Scenes</FluentOption>
                                </FluentSelect>
                            </div>
                            @if (_actionRows[index].DmxOperation != DmxSceneControlActionExecutor.StopAllScenes)
                            {
                                <div>
                                    <FluentSelect TOption="DmxSceneDTO"
                                        TValue="string"
                                        Label="Scene"
                                        Placeholder="Select Scene"
                                        Items="@_actionRows[index].Scenes"
                                        OptionText="@(s => s?.Name ?? string.Empty)"
                                        OptionValue="@(s => s?.Id.ToString())"
                                        Value="@_actionRows[index].SceneIdString"
                                        ValueChanged="@((string? id) => _actionRows[index].SceneIdString = id ?? string.Empty)"
                                        Style="flex: 1;" />
                                </div>
                            }
                        }
                        else
                        {
                            <div>
                                <FluentSelect TOption="string"
                                    TValue="string"
                                    Label="Operation"
                                    Value="@_actionRows[index].Operation"
                                    ValueChanged="@((string? op) => _actionRows[index].Operation = op ?? "Play")"
                                    Style="width: 120px;">
                                    <FluentOption Value="@("Play")">Play</FluentOption>
                                    <FluentOption Value="@("Pause")">Pause</FluentOption>
                                </FluentSelect>
                            </div>
                            <div>
                                <FluentSelect TOption="Playlist"
                                    TValue="string"
                                    Label="Playlist"
                                    Placeholder="Select Playlist"
                                    Items="@_playlists"
                                    OptionText="@(p => p?.Name ?? string.Empty)"
                                    OptionValue="@(p => p?.Id.ToString())"
                                    Value="@(_actionRows[index].PlaylistId?.ToString() ?? string.Empty)"
                                    ValueChanged="@((string? id) => _actionRows[index].PlaylistId = Guid.TryParse(id, out Guid playlistId) ? playlistId : (Guid?)null)"
                                    Style="flex: 1;" />
                            </div>
                        }
                        <FluentButton IconStart="new Icons.Regular.Size20.Dismiss()"
                            Disabled="@(_actionRows.Count <= 1)"
                            OnClick="@(() => RemoveActionRow(index))" />
                    </FluentStack>
                }

                <div>
                    <FluentButton Appearance="ButtonAppearance.Outline"
                                  IconStart="new Icons.Regular.Size20.Add()"
                                  OnClick="AddActionRow">
                        Add Action
                    </FluentButton>
                </div>

                @if (_actionRows.Count == 0)
                {
                    <FluentText Color="Color.Error">At least one action is required.</FluentText>
                }
            </FluentStack>
        }
    </ChildContent>
    <ActionTemplate>
        @if (_currentStepIndex == 0)
        {
            <FluentButton Appearance="ButtonAppearance.Primary"
                          Disabled="@(string.IsNullOrWhiteSpace(_ruleName) || string.IsNullOrEmpty(_triggerClientIdString))"
                          OnClick="GoToStep2Async">
                Next
            </FluentButton>
            <FluentButton OnClick="CancelDialogAsync">Cancel</FluentButton>
        }
        else if (_currentStepIndex == 1)
        {
            <FluentButton OnClick="GoToStep1Async">Previous</FluentButton>
            <FluentButton Appearance="ButtonAppearance.Primary"
                          Loading="@_isSaving"
                          Disabled="@(_actionRows.Count == 0 || _actionRows.Any(r => !IsRowValid(r)))"
                          OnClick="SaveRuleAsync">
                Save Rule
            </FluentButton>
            <FluentButton OnClick="CancelDialogAsync">Cancel</FluentButton>
        }
    </ActionTemplate>
</FluentDialogBody>

@code {
    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    [Parameter]
    public AutomationRule? Content { get; set; }

    private sealed class ActionRow
    {
        public Guid? ExistingActionId { get; set; }
        public string ActionType { get; set; } = AutomationActionTypes.MusicControl;
        public string TargetClientIdString { get; set; } = string.Empty;
        public string Operation { get; set; } = "Play";
        public Guid? PlaylistId { get; set; }
        public string ProjectionProgramIdString { get; set; } = string.Empty;
        public string DisplayIndexString { get; set; } = "default";
        public List<ClientAvailableScreen> Screens { get; set; } = [];
        public string DmxOperation { get; set; } = DmxSceneControlActionExecutor.StartScene;
        public string SceneIdString { get; set; } = string.Empty;
        public List<DmxSceneDTO> Scenes { get; set; } = [];
    }

    private static bool IsRowValid(ActionRow row)
    {
        if (string.IsNullOrEmpty(row.TargetClientIdString))
        {
            return false;
        }

        return row.ActionType switch
        {
            AutomationActionTypes.StartProjectionProgram => !string.IsNullOrEmpty(row.ProjectionProgramIdString),
            AutomationActionTypes.DmxSceneControl => row.DmxOperation == DmxSceneControlActionExecutor.StopAllScenes
                || !string.IsNullOrEmpty(row.SceneIdString),
            _ => true
        };
    }

    private int _currentStepIndex = 0;
    private List<string> _steps = ["Rule Details", "Actions"];

    private string _ruleName = string.Empty;
    private string _triggerClientIdString = string.Empty;
    private string _triggerEventString = GameStatus.InGame.ToString();
    private List<ActionRow> _actionRows = [];
    private IEnumerable<ClientConnectedDTO> _clients = [];
    private bool _isSaving = false;

    private IEnumerable<Playlist> _playlists { get; set; } = [];
    private IEnumerable<ProjectionProgram> _programs { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        Result<IEnumerable<ClientConnectedDTO>> clientResult = await _clientService.GetClientsAsync();
        _clients = clientResult.Data ?? [];

        if (Content != null)
        {
            _ruleName = Content.Name;
            _triggerClientIdString = Content.TriggerClientId.ToString();
            _triggerEventString = Content.TriggerEvent.ToString();

            foreach (AutomationRuleAction action in Content.Actions.Where(a => a.IsActive).OrderBy(a => a.SortOrder))
            {
                JsonDocument doc = JsonDocument.Parse(action.ParametersJson);

                ActionRow row = new ActionRow
                {
                    ExistingActionId = action.Id,
                    ActionType = action.ActionType
                };

                if (doc.RootElement.TryGetProperty("TargetClientId", out JsonElement targetClientElement) &&
                    targetClientElement.ValueKind == JsonValueKind.String &&
                    targetClientElement.TryGetGuid(out Guid targetId))
                {
                    row.TargetClientIdString = targetId.ToString();
                }

                if (action.ActionType == AutomationActionTypes.StartProjectionProgram)
                {
                    if (doc.RootElement.TryGetProperty("ProjectionProgramId", out JsonElement programElement) &&
                        programElement.ValueKind == JsonValueKind.String &&
                        programElement.TryGetGuid(out Guid programId))
                    {
                        row.ProjectionProgramIdString = programId.ToString();
                    }

                    if (doc.RootElement.TryGetProperty("DisplayIndex", out JsonElement displayElement) &&
                        displayElement.ValueKind == JsonValueKind.Number)
                    {
                        row.DisplayIndexString = displayElement.GetInt32().ToString();
                    }
                }
                else if (action.ActionType == AutomationActionTypes.DmxSceneControl)
                {
                    if (doc.RootElement.TryGetProperty("Operation", out JsonElement dmxOperationElement))
                    {
                        row.DmxOperation = dmxOperationElement.GetString() ?? DmxSceneControlActionExecutor.StartScene;
                    }

                    if (doc.RootElement.TryGetProperty("SceneId", out JsonElement sceneElement) &&
                        sceneElement.ValueKind == JsonValueKind.String &&
                        sceneElement.TryGetGuid(out Guid sceneId))
                    {
                        row.SceneIdString = sceneId.ToString();
                    }
                }
                else if (action.ActionType == AutomationActionTypes.MusicControl)
                {
                    if (doc.RootElement.TryGetProperty("Operation", out JsonElement operationElement))
                    {
                        row.Operation = operationElement.GetString() ?? "Play";
                    }

                    if (doc.RootElement.TryGetProperty("PlaylistId", out JsonElement playlistElement) &&
                        playlistElement.ValueKind == JsonValueKind.String &&
                        playlistElement.TryGetGuid(out Guid playlistId))
                    {
                        row.PlaylistId = playlistId;
                    }
                }

                _actionRows.Add(row);

                if (!string.IsNullOrEmpty(row.TargetClientIdString))
                {
                    if (row.ActionType == AutomationActionTypes.StartProjectionProgram)
                    {
                        await LoadScreensForRowAsync(_actionRows.Count - 1);
                    }
                    else if (row.ActionType == AutomationActionTypes.DmxSceneControl)
                    {
                        await LoadScenesForRowAsync(_actionRows.Count - 1);
                    }
                }
            }
        }
        else
        {
            _triggerClientIdString = _clients.FirstOrDefault()?.Id.ToString() ?? string.Empty;
            _actionRows.Add(new ActionRow
            {
                TargetClientIdString = _clients.FirstOrDefault()?.Id.ToString() ?? string.Empty
            });
        }

        Result<IEnumerable<Playlist>> playlistResult = await _playlistService.GetActivePlaylistsAsync();

        if (playlistResult.IsSuccess)
        {
            _playlists = playlistResult.Data ?? [];
        }
        else
        {
            _toastService.ShowError(playlistResult.Error ?? "Failed to load playlists.");
            _logger.LogError("Failed to load playlists: {Error}", playlistResult.Error);
        }

        Result<IEnumerable<ProjectionProgram>> programResult = await _projectionProgramService.GetProjectionProgramsAsync();

        if (programResult.IsSuccess)
        {
            _programs = programResult.Data ?? [];
        }
        else
        {
            _toastService.ShowError(programResult.Error ?? "Failed to load projection programs.");
            _logger.LogError("Failed to load projection programs: {Error}", programResult.Error);
        }
    }

    private async Task OnRowActionTypeChangedAsync(int index, string? newType)
    {
        ActionRow row = _actionRows[index];
        row.ActionType = newType ?? AutomationActionTypes.MusicControl;

        if (string.IsNullOrEmpty(row.TargetClientIdString))
        {
            return;
        }

        if (row.ActionType == AutomationActionTypes.StartProjectionProgram && row.Screens.Count == 0)
        {
            await LoadScreensForRowAsync(index);
        }
        else if (row.ActionType == AutomationActionTypes.DmxSceneControl && row.Scenes.Count == 0)
        {
            await LoadScenesForRowAsync(index);
        }
    }

    private async Task OnRowClientChangedAsync(int index, string? newClientId)
    {
        ActionRow row = _actionRows[index];
        row.TargetClientIdString = newClientId ?? string.Empty;

        // Display indices are per-client, so reset the screen choice when the client changes.
        row.DisplayIndexString = "default";
        row.Screens = [];

        // Scenes are per-client too, so the same reset applies.
        row.SceneIdString = string.Empty;
        row.Scenes = [];

        if (string.IsNullOrEmpty(row.TargetClientIdString))
        {
            return;
        }

        if (row.ActionType == AutomationActionTypes.StartProjectionProgram)
        {
            await LoadScreensForRowAsync(index);
        }
        else if (row.ActionType == AutomationActionTypes.DmxSceneControl)
        {
            await LoadScenesForRowAsync(index);
        }
    }

    private async Task LoadScreensForRowAsync(int index)
    {
        ActionRow row = _actionRows[index];

        if (!Guid.TryParse(row.TargetClientIdString, out Guid clientId))
        {
            row.Screens = [];
            return;
        }

        Result<IEnumerable<ClientAvailableScreen>> result = await _clientService.GetClientAvailableScreensAsync(clientId);

        if (result.IsSuccess && result.Data != null)
        {
            row.Screens = result.Data
                .Where(x => x.IsActive)
                .OrderBy(x => x.Index)
                .ToList();
        }
        else
        {
            row.Screens = [];
            _toastService.ShowError($"Failed to load screens, {result.Error}");
        }
    }

    private async Task LoadScenesForRowAsync(int index)
    {
        ActionRow row = _actionRows[index];

        if (!Guid.TryParse(row.TargetClientIdString, out Guid clientId))
        {
            row.Scenes = [];
            return;
        }

        Result<IEnumerable<DmxSceneDTO>> result = await _dmxSceneService.GetScenesForClientAsync(clientId);

        if (result.IsSuccess && result.Data != null)
        {
            row.Scenes = result.Data
                .Where(x => x.IsActive)
                .OrderBy(x => x.Name)
                .ToList();
        }
        else
        {
            row.Scenes = [];
            _toastService.ShowError($"Failed to load DMX scenes, {result.Error}");
        }
    }

    private async Task GoToStep2Async()
    {
        _currentStepIndex = 1;
        await Task.CompletedTask;
    }

    private async Task GoToStep1Async()
    {
        _currentStepIndex = 0;
        await Task.CompletedTask;
    }

    private void AddActionRow()
    {
        _actionRows.Add(new ActionRow());
    }

    private void RemoveActionRow(int index)
    {
        if (_actionRows.Count > 1)
        {
            _actionRows.RemoveAt(index);
        }
    }

    private async Task SaveRuleAsync()
    {
        _isSaving = true;

        Guid triggerClientId = Guid.Parse(_triggerClientIdString);
        GameStatus triggerEvent = Enum.Parse<GameStatus>(_triggerEventString);

        List<AutomationRuleAction> newActions = [];
        for (int i = 0; i < _actionRows.Count; i++)
        {
            ActionRow row = _actionRows[i];
            Guid targetClientId = Guid.Parse(row.TargetClientIdString);

            string parametersJson;
            if (row.ActionType == AutomationActionTypes.StartProjectionProgram)
            {
                parametersJson = JsonSerializer.Serialize(new
                {
                    TargetClientId = targetClientId,
                    ProjectionProgramId = Guid.Parse(row.ProjectionProgramIdString),
                    DisplayIndex = int.TryParse(row.DisplayIndexString, out int displayIndex) ? displayIndex : (int?)null
                });
            }
            else if (row.ActionType == AutomationActionTypes.DmxSceneControl)
            {
                parametersJson = JsonSerializer.Serialize(new
                {
                    TargetClientId = targetClientId,
                    Operation = row.DmxOperation,
                    SceneId = Guid.TryParse(row.SceneIdString, out Guid sceneId) ? sceneId : (Guid?)null
                });
            }
            else
            {
                parametersJson = JsonSerializer.Serialize(new
                {
                    TargetClientId = targetClientId,
                    Operation = row.Operation,
                    PlaylistId = row.PlaylistId
                });
            }

            newActions.Add(new AutomationRuleAction
            {
                Id = row.ExistingActionId ?? Guid.NewGuid(),
                ActionType = row.ActionType,
                ParametersJson = parametersJson,
                SortOrder = i,
                IsActive = true
            });
        }

        Result<AutomationRule> saveResult;

        if (Content != null)
        {
            List<Guid> removedActionIds = Content.Actions
                .Where(a => a.IsActive)
                .Select(a => a.Id)
                .Where(id => !_actionRows.Select(r => r.ExistingActionId).Contains(id))
                .ToList();

            if (removedActionIds.Count > 0)
            {
                await using ApplicationDbContext ctx = await _dbContextFactory.CreateDbContextAsync();
                List<AutomationRuleAction> actionsToRemove = await ctx.AutomationRuleActions
                    .Where(a => removedActionIds.Contains(a.Id))
                    .ToListAsync();
                foreach (AutomationRuleAction action in actionsToRemove)
                {
                    action.IsActive = false;
                }
                await ctx.SaveChangesAsync();
            }

            AutomationRule updatedRule = new AutomationRule
            {
                Id = Content.Id,
                Name = _ruleName,
                TriggerClientId = triggerClientId,
                TriggerEvent = triggerEvent,
                IsActive = true,
                CreateDate = Content.CreateDate,
                Actions = newActions
            };
            foreach (AutomationRuleAction action in newActions)
            {
                action.AutomationRuleId = updatedRule.Id;
            }
            saveResult = await _ruleService.UpdateRuleAsync(updatedRule);
        }
        else
        {
            AutomationRule newRule = new AutomationRule
            {
                Id = Guid.NewGuid(),
                Name = _ruleName,
                TriggerClientId = triggerClientId,
                TriggerEvent = triggerEvent,
                Actions = newActions
            };
            saveResult = await _ruleService.CreateRuleAsync(newRule);
        }

        if (saveResult.IsSuccess)
        {
            _toastService.ShowSuccess("Rule saved.");
            await Dialog.CloseAsync(true);
        }
        else
        {
            _toastService.ShowError(saveResult.Error ?? "Save failed.");
            _isSaving = false;
        }
    }

    private async Task CancelDialogAsync()
    {
        await Dialog.CancelAsync();
    }
}
