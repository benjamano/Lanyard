@using Lanyard.Infrastructure.Models
@using Lanyard.Infrastructure.DTO
@using Lanyard.Application.Services
@using System.Text.Json

@inject IClientService _clientService

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size24.Pen())" />
            <FluentText Typo="Typography.PaneHeader">Execution Detail</FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentText><strong>Rule:</strong> @Content.RuleName</FluentText>
            <FluentText><strong>Trigger Event:</strong> @Content.TriggerEvent</FluentText>
            <FluentText><strong>Executed At:</strong> @Content.ExecutedAt.ToLocalTime().ToString("g")</FluentText>
            <FluentText>
                <strong>Overall:</strong>
                @if (Content.OverallSuccess)
                {
                    <FluentIcon Icon="Icons.Regular.Size20.CheckmarkCircle" Color="Color.Success" />
                    <span> Success</span>
                }
                else
                {
                    <FluentIcon Icon="Icons.Regular.Size20.DismissCircle" Color="Color.Error" />
                    <span> Failed</span>
                }
            </FluentText>

            <FluentDivider />

            <FluentText Typo="Typography.H6">Actions</FluentText>

            @foreach (AutomationRuleActionExecution ae in Content.ActionExecutions)
            {
                <FluentCard Appearance="CardAppearance.Subtle">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" VerticalGap="16">
                        @if (ae.Success)
                        {
                            <FluentIcon Icon="Icons.Regular.Size20.CheckmarkCircle" Color="Color.Success" />
                        }
                        else
                        {
                            <FluentIcon Icon="Icons.Regular.Size20.DismissCircle" Color="Color.Error" />
                        }
                        <FluentStack Orientation="Orientation.Vertical">
                            <FluentText><strong>Type:</strong> @(ae.AutomationRuleAction?.ActionType ?? "Unknown")</FluentText>
                            <FluentText><strong>Target:</strong> @ResolveTargetClient(ae)</FluentText>
                            @if (!string.IsNullOrEmpty(ae.ErrorMessage))
                            {
                                <FluentText Color="Color.Error"><strong>Error:</strong> @ae.ErrorMessage</FluentText>
                            }
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }

            @if (Content.ActionExecutions.Count == 0)
            {
                <FluentText>No action execution records.</FluentText>
            }
        </FluentStack>
    </ChildContent>
    <ActionTemplate>
        <FluentButton OnClick="@CloseAsync" Appearance="ButtonAppearance.Outline">Close</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code {
#nullable enable

    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    [Parameter]
    public AutomationRuleExecution Content { get; set; } = default!;

    private IEnumerable<ClientConnectedDTO> _clients = [];

    protected override async Task OnInitializedAsync()
    {
        Result<IEnumerable<ClientConnectedDTO>> result = await _clientService.GetClientsAsync();
        if (result.IsSuccess)
        {
            _clients = result.Data ?? [];
        }
    }

    private string ResolveTargetClient(AutomationRuleActionExecution ae)
    {
        if (ae.AutomationRuleAction is null)
        {
            return "Unknown";
        }
        try
        {
            JsonDocument doc = JsonDocument.Parse(ae.AutomationRuleAction.ParametersJson);
            Guid targetId = doc.RootElement.GetProperty("TargetClientId").GetGuid();
            return _clients.FirstOrDefault(c => c.Id == targetId)?.Name ?? targetId.ToString();
        }
        catch
        {
            return "Unknown";
        }
    }

    private async Task CloseAsync()
    {
        await Dialog.CancelAsync();
    }
}
