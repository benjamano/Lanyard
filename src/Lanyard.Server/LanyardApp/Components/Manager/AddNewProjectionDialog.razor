@using Lanyard.Application.Services.Authentication
@using Lanyard.Infrastructure.Models
@using Lanyard.Application.Services

@inject IToastService _toastService
@inject IClientService _clientService
@inject IProjectionProgramService _projectionService

<FluentDialogBody>
    <TitleTemplate>
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size24.ProjectionScreenText())" />
            <FluentText Typo="Typography.PaneHeader">
                @(steps.Count() <= currentStepIndex ? "Finish" : steps[currentStepIndex])
            </FluentText>
        </FluentStack>
    </TitleTemplate>
    <ChildContent>
        @if (currentStepIndex == 0)
        {
            <FluentDataGrid ShowHover="true" Items="@projectionSettings.AsQueryable()" GridTemplateColumns="auto 1fr 1fr 1fr">
                <SelectColumn SelectAll="true" OnSelect="@(x=> UpdateSelectedScreen(x.Item))" Property="@(x=> x == selectedScreen)" TGridItem="ClientAvailableScreen" SelectMode="DataGridSelectMode.Single" SelectFromEntireRow="true"></SelectColumn>
                <PropertyColumn Property="x => x.Index" Title="Display Number" />
                <PropertyColumn Property="x => x.Name" Title="Screen Name" />
                <TemplateColumn Title="Size">
                    @context.Width x @(context.Height)px
                </TemplateColumn>
            </FluentDataGrid>
        }
        else if (currentStepIndex == 1)
        {
            <FluentStack>
                <EditForm Model="newClientProjectionSettings">
                    <DataAnnotationsValidator />
                    <FluentValidationSummary />
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Left">
                        <FluentCheckbox Class="mb-2" @bind-Value="newClientProjectionSettings.RepeatInfinitely">
                            Repeat Infinitely
                        </FluentCheckbox>
                        <FluentCheckbox Class="mb-2" @bind-Value="newClientProjectionSettings.IsDarkTheme">
                            Dark Mode Theme
                        </FluentCheckbox>
                        <AuthorizeView Roles="Admin" Context="_context">
                            <Authorized>
                                <FluentCheckbox Class="mb-2" @bind-Value="newClientProjectionSettings.ShowDebugMode">
                                    Debug Mode
                                </FluentCheckbox>
                            </Authorized>
                        </AuthorizeView>
                    </FluentStack>

                    <FluentTextInput @bind-Value="_repeatNumberStr"
                                     Label="Repeat Number of Times (0 for run once)"
                                     TextInputType="TextInputType.Number"
                                     Appearance="TextInputAppearance.Outline"
                                     Disabled="@newClientProjectionSettings.RepeatInfinitely" />

                    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Left">
                        <div>
                            <FluentTextInput @bind-Value="_widthStr"
                                             Label="Width"
                                             TextInputType="TextInputType.Number"
                                             Appearance="TextInputAppearance.Outline"
                                             Required="true" />
                        </div>
                        <div>
                            <FluentTextInput @bind-Value="_heightStr"
                                             Label="Height"
                                             TextInputType="TextInputType.Number"
                                             Appearance="TextInputAppearance.Outline"
                                             Required="true" />
                        </div>
                    </FluentStack>
                </EditForm>
            </FluentStack>
        }
        else if (currentStepIndex == 2)
        {
            <FluentStack Orientation="Orientation.Vertical">
                <FluentDataGrid class="w-100" ShowHover="true" Items="@projectionPrograms.AsQueryable()" GridTemplateColumns="auto 1fr">
                    <SelectColumn SelectAll="true" OnSelect="@(x => UpdateSelectedProjectionProgram(x.Item))" Property="@(x => x == newClientProjectionSettings.ProjectionProgram)" TGridItem="ProjectionProgram" SelectMode="DataGridSelectMode.Single" SelectFromEntireRow="true"></SelectColumn>
                    <PropertyColumn Property="x => x.Name" Title="Name"></PropertyColumn>
                </FluentDataGrid>

                <FluentStack HorizontalAlignment="HorizontalAlignment.Right">
                    <a href="/manage/projectionprograms" target="_blank" style="text-decoration: none">
                        <FluentButton Appearance="ButtonAppearance.Outline" IconStart="new Icons.Regular.Size20.FormNew()">
                            Create New Program
                        </FluentButton>
                    </a>
                </FluentStack>
            </FluentStack>
        }
        else if (currentStepIndex == 3)
        {
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                <FluentCard Appearance="CardAppearance.Subtle">
                    <FluentText Typo="Typography.H6">Screen Selection</FluentText>
                    @if (selectedScreen is not null)
                    {
                        <FluentStack>
                            <FluentText>Display Number: @selectedScreen.Index</FluentText>
                            <FluentText>Screen Name: @selectedScreen.Name</FluentText>
                            <FluentText>Resolution: @selectedScreen.Width x @selectedScreen.Height px</FluentText>
                        </FluentStack>
                    }
                    else
                    {
                        <FluentText>No screen selected.</FluentText>
                    }
                </FluentCard>

                <FluentCard Appearance="CardAppearance.Subtle">
                    <FluentText Typo="Typography.H6">Screen Settings</FluentText>
                    <FluentStack>
                        <FluentText>Full Screen: @(newClientProjectionSettings.IsFullScreen ? "Yes" : "No")</FluentText>
                        <FluentText>Borderless: @(newClientProjectionSettings.IsBorderless ? "Yes" : "No")</FluentText>
                        <FluentText>Width: @selectedScreen?.Width</FluentText>
                        <FluentText>Height: @selectedScreen?.Height</FluentText>
                    </FluentStack>
                </FluentCard>

                <FluentCard Appearance="CardAppearance.Subtle">
                    <FluentText Typo="Typography.H6">Projection Program</FluentText>
                    @if (newClientProjectionSettings.ProjectionProgram is not null)
                    {
                        <FluentText>Name: @newClientProjectionSettings.ProjectionProgram.Name</FluentText>
                        <FluentText>Description: @newClientProjectionSettings.ProjectionProgram.Description</FluentText>
                    }
                    else
                    {
                        <FluentText>No program selected.</FluentText>
                    }
                </FluentCard>
            </FluentStack>
        }
    </ChildContent>
    <ActionTemplate>
        <FluentButton OnClick="HandleGoBack" Loading="@isCreating" Disabled="@previousButtonIsDisabled" IconStart="new Icons.Regular.Size20.ArrowPrevious()">Previous</FluentButton>
        <FluentButton OnClick="HandleNextPage" Loading="@isCreating" Disabled="@nextButtonIsDisabled" IconStart="new Icons.Regular.Size20.ArrowNext()">@nextButtonText</FluentButton>
        <FluentButton OnClick="CancelDialog" Loading="@isCreating" IconStart="new Icons.Regular.Size20.CalendarCancel()">Cancel</FluentButton>
    </ActionTemplate>
</FluentDialogBody>

@code {
    [CascadingParameter]
    public required IDialogInstance Dialog { get; set; }

    [Parameter]
    public Guid Content { get; set; }

    private ClientProjectionSettings newClientProjectionSettings = new();

    private IEnumerable<ClientAvailableScreen> projectionSettings = Array.Empty<ClientAvailableScreen>();
    private IEnumerable<ProjectionProgram> projectionPrograms = Array.Empty<ProjectionProgram>();

    private ClientAvailableScreen? selectedScreen;

    private string _repeatNumberStr = "0";
    private string _widthStr = "1920";
    private string _heightStr = "1080";

    private int currentStepIndex = 0;
    private List<string> steps = new()
    {
        "Select Screen",
        "Configure Screen Settings",
        "Select Projection Program",
        "Review & Confirm"
    };

    private string nextButtonText = "Next";
    private bool previousButtonIsDisabled = true;
    private bool nextButtonIsDisabled = true;
    private bool isCreating = false;

    protected override async Task OnInitializedAsync()
    {
        newClientProjectionSettings.ClientId = Content;

        Result<IEnumerable<ClientAvailableScreen>> result = await _clientService.GetClientAvailableScreensAsync(Content);

        if (result.IsSuccess)
        {
            projectionSettings = result.Data!;
        }
        else
        {
            _toastService.ShowError($"Failed to load projection settings, {result.Error}");
            await CancelDialog();
        }

        Result<IEnumerable<ProjectionProgram>> programResult = await _projectionService.GetProjectionProgramsAsync();

        if (programResult.IsSuccess)
        {
            projectionPrograms = programResult.Data!;
        }
        else
        {
            _toastService.ShowError($"Failed to load projection programs, {programResult.Error}");
            await CancelDialog();
        }
    }

    private async Task UpdateSelectedScreen(ClientAvailableScreen? clientAvailableScreen)
    {
        selectedScreen = clientAvailableScreen;

        if (selectedScreen != null)
        {
            newClientProjectionSettings.Width = selectedScreen.Width;
            newClientProjectionSettings.Height = selectedScreen.Height;
            newClientProjectionSettings.DisplayIndex = selectedScreen.Index;
            _widthStr = selectedScreen.Width.ToString();
            _heightStr = selectedScreen.Height.ToString();
            nextButtonIsDisabled = false;
        }
        else
        {
            nextButtonIsDisabled = true;
        }
    }

    private async Task UpdateSelectedProjectionProgram(ProjectionProgram? projectionProgram)
    {
        newClientProjectionSettings.ProjectionProgram = projectionProgram;
        newClientProjectionSettings.ProjectionProgramId = projectionProgram?.Id ?? Guid.Empty;
        nextButtonIsDisabled = projectionProgram is null;
    }

    private async Task HandleNextPage()
    {
        if (currentStepIndex == 1)
        {
            if (int.TryParse(_repeatNumberStr, out int repeatNum))
                newClientProjectionSettings.RepeatNumberOfTimes = repeatNum;
            if (int.TryParse(_widthStr, out int width))
                newClientProjectionSettings.Width = width;
            if (int.TryParse(_heightStr, out int height))
                newClientProjectionSettings.Height = height;
        }

        currentStepIndex++;

        if (currentStepIndex >= steps.Count)
        {
            currentStepIndex--;
            await AddNewClientProjection();
            return;
        }

        nextButtonText = currentStepIndex == steps.Count - 1 ? "Finish" : "Next";
        previousButtonIsDisabled = false;

        await HandleCurrentStep();
    }

    private async Task HandleCurrentStep()
    {
        switch (currentStepIndex)
        {
            case 0:
                nextButtonIsDisabled = selectedScreen == null;
                break;
            case 1:
                nextButtonIsDisabled = false;
                break;
            case 2:
                nextButtonIsDisabled = newClientProjectionSettings.ProjectionProgram == null;
                break;
        }
    }

    private async Task HandleGoBack()
    {
        currentStepIndex--;
        nextButtonText = "Next";
        previousButtonIsDisabled = currentStepIndex == 0;
        await HandleCurrentStep();
    }

    private async Task CancelDialog()
    {
        await Dialog.CancelAsync();
    }

    private async Task AddNewClientProjection()
    {
        isCreating = true;

        Result<Guid> addResult = await _clientService.AddClientProjectionAsync(newClientProjectionSettings);

        if (addResult.IsSuccess)
        {
            _toastService.ShowSuccess("Projection added successfully!");
            await Dialog.CancelAsync();
        }
        else
        {
            _toastService.ShowError($"An error occured, {addResult.Error}");
            isCreating = false;
        }
    }
}
