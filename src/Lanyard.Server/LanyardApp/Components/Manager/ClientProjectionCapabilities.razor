@inject IClientService _clientService
@inject IToastService _toastService

@if (ClientId != null)
{
    <FluentStack Orientation="@Orientation.Horizontal" HorizontalAlignment="@HorizontalAlignment.Right" VerticalAlignment="@VerticalAlignment.Center" Margin="@Margin.Bottom2">
        <FluentButton IconStart="new Icons.Regular.Size20.Add()" OnClick="OpenAddProjectionDialog">Add Projection</FluentButton>
    </FluentStack>

    <FluentStack>
        <FluentDataGrid ShowHover="true" Items="@projectionSettings.OrderBy(x => x.DisplayIndex).AsQueryable()" GridTemplateColumns="1fr 1fr 1fr 1fr 1fr" Style="width: 100%;"">
            <ChildContent>
                <PropertyColumn Property="x => x.DisplayIndex" Title="Display" />
                <PropertyColumn Property="x => x.ProjectionProgram!.Name" Title="Program Name" />
                <PropertyColumn Property="x => x.IsFullScreen" Title="Is Full Screen" />
                <PropertyColumn Property="x => x.IsBorderless" Title="Is Borderless" />
                <TemplateColumn Title="Size">
                    @context.Width x @context.Height px
                </TemplateColumn>
                <TemplateColumn Title="Delete">
                    <FluentIcon Value="@(new Icons.Regular.Size20.BinRecycle())" OnClick="() => DeleteClientProjectionSettings(context.Id)"></FluentIcon>
                </TemplateColumn>
            </ChildContent>
            <LoadingContent>
                Loading...
            </LoadingContent>
            <EmptyContent>
                No Projections set for this Client!
            </EmptyContent>
        </FluentDataGrid>
    </FluentStack>
}

@code {
    [Parameter]
    public Guid? ClientId { get; set; }

    [Parameter]
    public EventCallback UpdateClientCapabilities { get; set; }

    private IEnumerable<ClientProjectionSettings> projectionSettings = Array.Empty<ClientProjectionSettings>();

    protected override async Task OnParametersSetAsync()
    {
        if (ClientId != null)
        {
            await RefreshCapabilities();
        }
    }

    public async Task RefreshCapabilities()
    {
        Result<IEnumerable<ClientProjectionSettings>> result = await _clientService.GetClientProjectionSettingsAsync(ClientId!.Value);

        if (result.IsSuccess)
        {
            projectionSettings = result.Data!;
        }
        else
        {
            _toastService.ShowError($"Failed to load client projection settings, {result.Error}");
        }
    }

    private async Task OpenAddProjectionDialog()
    {
        if (ClientId != null)
        {
            await _dialogService.ShowDialogAsync<AddNewProjectionDialog>(options =>
            {
                options.Header.Title = "Add Projection";
                options.Width = "50%";
                options.Modal = true;
                options.Parameters.Add(nameof(AddNewProjectionDialog.Content), ClientId.Value);
            });

            await RefreshCapabilities();
        }
    }

    private async Task DeleteClientProjectionSettings(Guid projectionSettingsId)
    {
        Result<bool> result = await _clientService.DeleteClientProjectionSettingsAsync(projectionSettingsId);

        if (result.IsSuccess)
        {
            await RefreshCapabilities();

            if (projectionSettings.Any() == false)
            {
                await UpdateClientCapabilities.InvokeAsync();
            }
        }
        else
        {
            _toastService.ShowError($"An error occured when deleting the projection, {result.Error}");
        }
    }
}