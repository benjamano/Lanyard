<FluentCard Class="kiosk-widget-card" Style="height: auto; width: 100%;">
    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" Height="100%">
        <FluentText Typo="Typography.H6">@(string.IsNullOrWhiteSpace(Widget.Title) ? "Music Controls" : Widget.Title)</FluentText>
        <FluentText Typo="Typography.Body">Music controls placeholder</FluentText>
    </FluentStack>
</FluentCard>

@code {
    [Parameter, EditorRequired]
    public DashboardWidget Widget { get; set; } = default!;
}
