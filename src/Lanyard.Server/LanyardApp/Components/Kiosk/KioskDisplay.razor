@implements IDisposable
@using Lanyard.App.Components.Kiosk.Templates
@using Lanyard.App.Components.Pages.Staff.Dashboards

@inject IToastService _toastService
@inject ILogger<KioskDisplay> _logger

@if (CurrentProjectionStep?.Template?.Name == KioskTemplateConstants.TemplateNames.ShowText)
{
    <KioskShowTextTemplate Step="CurrentProjectionStep" />
}
else if (CurrentProjectionStep?.Template?.Name == KioskTemplateConstants.TemplateNames.PlayVideo)
{
    <KioskPlayVideoTemplate Step="CurrentProjectionStep" />
}
else if (CurrentProjectionStep?.Template?.Name == KioskTemplateConstants.TemplateNames.Dashboard)
{
    <RenderDashboardTemplate Step="CurrentProjectionStep" />
}
else if (CurrentProjectionStep?.Template?.Name == KioskTemplateConstants.TemplateNames.LiveCapture)
{
    <KioskLiveCaptureTemplate Step="CurrentProjectionStep" ClientId="ClientId" ViewerToken="@ViewerToken" />
}

@code {
    [Parameter]
    public ProjectionProgram projectionProgram { get; set; } = new() { Name = "" };

    [Parameter]
    public Guid ClientId { get; set; }

    [Parameter]
    public string? ViewerToken { get; set; }

    [Parameter]
    public bool RepeatInfinitely { get; set; } = true;

    [Parameter]
    public int RepeatCount { get; set; } = 0;

    public ProjectionProgramStep CurrentProjectionStep { get; set; } = new();

    private CancellationTokenSource? _cts;
    private Task? _processingTask;
    private readonly HashSet<Guid> _loggedUnsupportedTemplateStepIds = [];

    public void StartProcessing()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        _processingTask = ProcessStepsAsync(_cts.Token);
    }

    private async Task ProcessStepsAsync(CancellationToken cancellationToken)
    {
        bool runLoop = true;
        int runCount = 0;

        while (runLoop && !cancellationToken.IsCancellationRequested)
        {
            foreach (ProjectionProgramStep step in projectionProgram.ProjectionProgramSteps)
            {
                if (cancellationToken.IsCancellationRequested)
                {
                    return;
                }

                if (step.Template == null)
                {
                    _toastService.ShowError("A step without a template was found, skipping...");
                    continue;
                }

                if (!string.Equals(step.Template.Name, KioskTemplateConstants.TemplateNames.Delay, StringComparison.Ordinal))
                {
                    CurrentProjectionStep = step;

                    StateHasChanged();
                }

                try
                {
                    await Task.Delay(step.HoldForMilliseconds == 0 ? 5000 : step.HoldForMilliseconds, cancellationToken);
                }
                catch (TaskCanceledException)
                {
                    return;
                }
            }

            if (!RepeatInfinitely && runCount == RepeatCount)
            {
                runLoop = false;
            }

            runCount++;
        }
    } 
    
    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
