<FluentDesignTheme @bind-Mode="@Mode" @bind-OfficeColor="@SelectedColour" OnLoaded="@OnLoaded" OnLuminanceChanged="@OnLuminanceChanged" StorageName="theme" />

@code {
    public DesignThemeModes Mode { get; set; }

    public OfficeColor? SelectedColour { get; set; }

    public List<OfficeColor> Colours { get; set; } = new();

    void OnLoaded(LoadedEventArgs e)
    {
        Colours = [OfficeColor.OneNote, OfficeColor.Word, OfficeColor.Stream, OfficeColor.PowerApps];

        //ONENNOTE or WORD or STREAM or POWERAPPS

        Random random = new Random();

        SelectedColour = Colours[random.Next(0, 3)];
    }

    void OnLuminanceChanged(LuminanceChangedEventArgs e)
    {
    }

    void PickRandomColor()
    {
        SelectedColour = OfficeColorUtilities.GetRandom();
    }
}