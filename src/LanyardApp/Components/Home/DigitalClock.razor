
<FluentCard MinimalStyle="true">
    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" VerticalAlignment="VerticalAlignment.Center" VerticalGap="4">
        <FluentLabel Typo="Typography.H2" Style="font-variant-numeric: tabular-nums;">
            @_currentTime
        </FluentLabel>
        <FluentLabel Typo="Typography.Body" Color="Color.Info">
            @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
        </FluentLabel>
    </FluentStack>
</FluentCard>

@code {
    private string _currentTime = string.Empty;
    private Timer? _timer;
    private string _timeFormat = "HH:mm:ss";

    protected override async Task OnInitializedAsync()
    {
        DetectTimeFormat();
        _currentTime = DateTime.Now.ToString(_timeFormat);
        _timer = new Timer(UpdateClock, null, 0, 1000);
    }

    private void DetectTimeFormat()
    {
        string? shortTimePattern = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.ShortTimePattern;
        if (shortTimePattern.Contains("tt"))
        {
            _timeFormat = "hh:mm:ss tt";
        }
        else
        {
            _timeFormat = "HH:mm:ss";
        }
    }

    private void UpdateClock(object? state)
    {
        _currentTime = DateTime.Now.ToString(_timeFormat);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}