<FluentCard MinimalStyle="true">
    <FluentLabel Typo="Typography.H5">
        Your Tasks Today
    </FluentLabel>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="1" Class="mt-2">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Left">
            <FluentIcon Icon="Icons.Filled.Size20.HomeHeart" Class="pt-1"/>

            <FluentStack Orientation="Orientation.Vertical" Class="mb-1 mt-1" VerticalGap="0">
                <FluentLabel Typo="Typography.Body" Color="Color.Accent">
                    Inflatable
                </FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Info">
                    9:00 AM - 10:00 AM
                </FluentLabel>
            </FluentStack>
        </FluentStack>

        <FluentDivider Style="width: 100%;" Role="DividerRole.Separator"></FluentDivider>

        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Left">
            <FluentIcon Icon="Icons.Filled.Size20.DeskSparkle" Class="pt-1"/>

            <FluentStack Orientation="Orientation.Vertical" Class="mb-1 mt-1" VerticalGap="0">
                <FluentLabel Typo="Typography.Body" Color="Color.Accent">
                    Snack Bar
                </FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Info">
                    10:00 AM - 12:00 PM
                </FluentLabel>
            </FluentStack>
        </FluentStack>

        <FluentDivider Style="width: 100%;" Role="DividerRole.Separator"></FluentDivider>

        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Left">
            <FluentIcon Icon="Icons.Filled.Size20.LaserTool" Class="pt-1"/>

            <FluentStack Orientation="Orientation.Vertical" Class="mb-1 mt-1" VerticalGap="0">
                <FluentLabel Typo="Typography.Body" Color="Color.Accent">
                    Laser Tag
                </FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Info">
                    12:00 PM - 13:00 PM
                </FluentLabel>
            </FluentStack>
        </FluentStack>

        <FluentDivider Style="width: 100%;" Role="DividerRole.Separator"></FluentDivider>
    </FluentStack>
</FluentCard>