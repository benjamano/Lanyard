@page "/redirect-to-lanyard-server"

@inject NavigationManager NavigationManager

<FluentLabel Typo="Typography.H3">Redirecting to Lanyard Server...</FluentLabel>

@code {
    string? environmentName = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT");

    protected override void OnInitialized()
    {
        if (environmentName == "Production")
        {
            NavigationManager.NavigateTo("");
        }
        else{
            NavigationManager.NavigateTo(Environment.GetEnvironmentVariable("LANYARD_SERVER_URL") ?? "https://localhost:7175");
        }
    }
}