@page "/cookies"
@layout MainLayout

<PageTitle>Cookie Policy - Play2Day</PageTitle>

<section class="legal-page">
    <div class="container" style="max-width: 800px; margin: 0 auto; padding: 40px 20px;">
        <h1>Cookie Policy</h1>
        <p><em>Last updated: @DateTime.UtcNow.ToString("d MMMM yyyy")</em></p>

        <p>
            A cookie is a small text file stored on your device. We use only
            <strong>strictly-necessary</strong> cookies — those required for the website and our
            staff systems to work securely. Because these are essential, they do not require your
            consent, but we list them here for transparency.
        </p>

        <table style="width: 100%; border-collapse: collapse; margin-top: 16px;">
            <thead>
                <tr style="text-align: left; border-bottom: 1px solid #ccc;">
                    <th style="padding: 8px;">Cookie</th>
                    <th style="padding: 8px;">Purpose</th>
                    <th style="padding: 8px;">Expiry</th>
                </tr>
            </thead>
            <tbody>
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 8px;">Authentication</td>
                    <td style="padding: 8px;">Keeps you signed in to staff systems</td>
                    <td style="padding: 8px;">Up to 14 days</td>
                </tr>
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 8px;">Antiforgery token</td>
                    <td style="padding: 8px;">Protects forms against cross-site request forgery</td>
                    <td style="padding: 8px;">Session</td>
                </tr>
            </tbody>
        </table>

        <p style="margin-top: 16px;">
            We do <strong>not</strong> use analytics, advertising, or tracking cookies. If this ever
            changes, we will ask for your consent before setting any non-essential cookies.
        </p>

        <p>
            Questions? Contact <a href="mailto:privacy@play2day.com">privacy@play2day.com</a>.
        </p>
    </div>
</section>
